            <option value="paused">⏸️ En pause</option>
          </select>
        </div>
        <div><label>Priorité</label>
          <select id="pf-priority">
            <option value="P0">P0 — Bloquant</option>
            <option value="P1">P1 — Impact direct</option>
            <option value="P2">P2 — Différable</option>
          </select>
        </div>
      </div>
      <div class="cc-form-row"><label>Description / Next step</label><textarea id="pf-desc" rows="2" placeholder="Ce qu'il reste à faire..."></textarea></div>
      <div class="cc-form-row"><label>Avancement (%)</label><input id="pf-pct" type="number" min="0" max="100" value="0" style="width:100px"></div>
      <div class="cc-form-actions">
        <button class="cc-add-btn" onclick="ccSaveProject()">Sauvegarder</button>
        <button class="cc-add-btn secondary" onclick="ccToggleForm('proj-form')">Annuler</button>
      </div>
    </div>

    <div class="card" style="padding:0;overflow:hidden">
      <table class="cc-table">
        <thead>
          <tr>
            <th>Horizon</th>
            <th>Priorité</th>
            <th>Projet</th>
            <th>Statut</th>
            <th>Avancement</th>
            <th>Next Step</th>
            <th></th>
          </tr>
        </thead>
        <tbody id="proj-tbody"></tbody>
      </table>
    </div>
  </div><!-- /cc-projects -->

  <!-- ── OKR ── -->
  <div class="cc-section" id="cc-okr">
    <div class="section-toolbar">
      <h3>Objectifs → Key Results → Tasks</h3>
      <button class="cc-add-btn secondary" onclick="ccToggleForm('okr-form')">+ Nouvel objectif</button>
    </div>

    <div class="cc-form" id="okr-form">
      <div class="cc-form-grid">
        <div><label>Objectif (O)</label><input id="of-title" placeholder="ex: Lancer campagne Meta Nellio"></div>
        <div><label>Horizon</label>
          <select id="of-horizon">
            <option value="CT">Court Terme</option>
            <option value="MT">Moyen Terme</option>
            <option value="LT">Long Terme</option>
          </select>
        </div>
      </div>
      <div class="cc-form-row"><label>Key Results (un par ligne)</label><textarea id="of-krs" rows="3" placeholder="KR1: Lancer 1 campagne CBO avant le 15/03&#10;KR2: Obtenir un ROAS > 2 sur 72h&#10;KR3: Identifier 1 angle winner"></textarea></div>
      <div class="cc-form-actions">
        <button class="cc-add-btn" onclick="ccSaveObjective()">Créer</button>
        <button class="cc-add-btn secondary" onclick="ccToggleForm('okr-form')">Annuler</button>
      </div>
    </div>

    <div id="okr-list"></div>
  </div><!-- /cc-okr -->

  <!-- ── TO-DO ── -->
  <div class="cc-section" id="cc-todo">
    <div class="section-toolbar">
      <h3>To-Do List Complète</h3>
      <select id="todo-filter" onchange="ccRenderTodo()" style="width:auto;font-size:12px;padding:6px 10px">
        <option value="all">Toutes</option>
        <option value="open">Ouvertes</option>
        <option value="done">Terminées</option>
        <option value="P0">P0 seulement</option>
        <option value="P1">P1 seulement</option>
      </select>
    </div>

    <div class="todo-add-bar">
      <input id="todo-input" placeholder="Nouvelle tâche..." onkeydown="if(event.key==='Enter')ccAddTodo()">
      <select id="todo-priority" style="width:130px;font-size:13px">
        <option value="P0">P0 Bloquant</option>
        <option value="P1" selected>P1 Impact</option>
        <option value="P2">P2 Différable</option>
      </select>
      <select id="todo-project" style="width:160px;font-size:13px">
        <option value="">— Projet —</option>
      </select>
      <button class="cc-add-btn" onclick="ccAddTodo()">Ajouter</button>
    </div>

    <div id="todo-list"></div>
  </div><!-- /cc-todo -->

