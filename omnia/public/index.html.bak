    <!-- hidden clipAvatarSelect (backend compat — synced by JS) -->
    <input type="hidden" id="clipAvatarSelect" value="A3-e">

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:10px">
      <!-- NIVEAU 1 : Core Avatar -->
      <div class="form-group" style="margin-bottom:0">
        <label style="font-size:11px;color:var(--accent);font-weight:700;text-transform:uppercase;letter-spacing:.5px">① Core Avatar</label>
        <select id="clipCoreAvatar" onchange="onCoreAvatarChange()" style="font-size:13px">
          <option value="A1">👩‍💼 A1 — Professionnelle Surchargée</option>
          <option value="A2">👩‍👧 A2 — Mère en Surcharge</option>
          <option value="A3" selected>🔥 A3 — En Risque Burnout</option>
          <option value="A4">🧬 A4 — Biohacker / Wellness</option>
        </select>
      </div>
      <!-- NIVEAU 2 : Sub-Avatar (dynamique) -->
      <div class="form-group" style="margin-bottom:0">
        <label style="font-size:11px;color:var(--accent);font-weight:700;text-transform:uppercase;letter-spacing:.5px">② Sub-Avatar</label>
        <select id="clipSubAvatar" onchange="onSubAvatarChange()" style="font-size:13px">
          <!-- Populated by onCoreAvatarChange() on load -->
        </select>
      </div>
    </div>

    <!-- Hook verbatim du sub-avatar (badge info) -->
    <div id="subAvatarHookBadge" style="padding:7px 12px;background:rgba(108,99,255,0.1);border-left:3px solid var(--accent);border-radius:0 6px 6px 0;font-size:12px;color:var(--text2);margin-bottom:10px;font-style:italic"></div>

    <!-- NIVEAU 3 : Angle (dynamique — recommandé en premier) -->
    <div class="form-group">
      <label style="font-size:11px;color:var(--accent);font-weight:700;text-transform:uppercase;letter-spacing:.5px">③ Angle / Messaging <span style="font-weight:400;font-size:10px;color:var(--text2);text-transform:none">— desire_map.md</span></label>
      <select id="clipAngle" onchange="onAngleChange()" style="font-size:13px">
        <!-- Populated dynamically — recommended ⭐ first -->
      </select>
    </div>

    <!-- ── Scène ── -->
    <div class="form-group">
      <label>Type de scène</label>
      <select id="clipSceneType" onchange="onSceneTypeChange()">
        <option value="Hook">🎣 Hook</option>
        <option value="Problem">😰 Problème</option>
        <option value="Solution">✨ Solution</option>
        <option value="CTA">📣 CTA</option>
        <option value="Testimonial" selected>💬 Témoignage</option>

      </select>
    </div>

    <!-- ── Ligne 2 : Provider + Durée ── -->
    <div class="grid-2" style="margin-top:4px">
      <div class="form-group">
        <label>Provider</label>
        <select id="clipProvider" onchange="updateClipModels();scheduleVisualPromptGen()">
          <option value="kie">🔵 kie.ai</option>
          <option value="higgsfield">🟣 Higgsfield</option>
          <option value="heygen">🟢 HeyGen</option>
        </select>
        <!-- Bannière capacités provider -->
        <div id="providerCapBanner" style="margin-top:7px;padding:8px 10px;border-radius:6px;font-size:11px;line-height:1.5;display:none"></div>
      </div>
      <div class="form-group">
        <label>Durée</label>
        <select id="clipDuration" onchange="updateClipCost()">
          <option value="5">5 secondes</option>
          <option value="10">10 secondes</option>
          <option value="15" selected>15 secondes</option>
          <option value="20">20 secondes</option>
        </select>
      </div>
    </div>

    <!-- ── Ligne 3 : Modèle + Format ── -->
    <div class="grid-2" style="margin-top:4px">
      <div class="form-group">
        <label>Modèle de génération</label>
        <select id="clipModel" onchange="onModelChange()">
          <option value="sora-2-pro-text-to-video">Sora 2 Pro T2V 🗣⭐ — ~100 cr/clip</option>
          <option value="sora-2-text-to-video">Sora 2 T2V 🗣 — 40 cr/clip ($0.20)</option>
          <option value="sora-2-pro-image-to-video">Sora 2 Pro I2V 🖼⭐ — ~100 cr/clip</option>
          <option value="sora-2-image-to-video">Sora 2 I2V 🖼→🎬 — 40 cr/clip ($0.20)</option>
          <option value="kling-3.0">Kling 3.0 T2V — 40 cr/seconde</option>
        </select>
      </div>
      <div class="form-group">
        <label>Format vidéo</label>
        <select id="clipFormat" onchange="updateClipCost();scheduleVisualPromptGen()">
          <option value="9:16" selected>📱 9:16 — Vertical (Reels / TikTok)</option>
          <option value="4:5">🖼 4:5 — Portrait (Instagram Feed)</option>
          <option value="1:1">⬛ 1:1 — Carré (Instagram)</option>
          <option value="16:9">🖥 16:9 — Horizontal (YouTube)</option>
        </select>
      </div>
    </div>

    <!-- ── Ligne 4 : Nombre de générations ── -->
    <div class="form-group">
      <label>Nombre de variantes</label>
      <select id="clipNumVariants" onchange="updateClipCost()" style="width:auto">
        <option value="1">1 variante</option>
        <option value="2">2 variantes</option>
        <option value="3" selected>3 variantes</option>
        <option value="4">4 variantes</option>
        <option value="5">5 variantes</option>
        <option value="6">6 variantes</option>
      </select>
    </div>

    <!-- ── Ligne 4 : Controls spécifiques au provider ── -->
    <!-- kie.ai : Personnage Sora 2 -->
    <div id="clipKieControls" class="form-group">
      <label>Personnage Sora 2 <span style="font-weight:400;color:var(--text2)">(optionnel — consistance visuelle)</span></label>
      <select id="clipCharacter">
        <option value="">Aucun — description physique générique</option>
      </select>
    </div>

    <!-- HeyGen : Avatar + Voix -->
    <div id="clipHeygenControls" style="display:none">
      <!-- Avatar picker -->
      <div class="form-group">
        <label>Avatar HeyGen</label>
        <div id="heygenAvatarPickerBtn" onclick="openAvatarPicker()"
             style="display:flex;align-items:center;gap:12px;padding:10px 14px;background:var(--surface2);border:1px solid var(--border);border-radius:8px;cursor:pointer;transition:border-color .2s"
             onmouseenter="this.style.borderColor='var(--accent)'" onmouseleave="this.style.borderColor='var(--border)'">
          <div style="width:52px;height:52px;border-radius:8px;overflow:hidden;background:#222;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:24px" id="heygenSelectedThumb">👤</div>
          <div style="flex:1;min-width:0">
            <div id="heygenSelectedName" style="font-weight:600;font-size:13px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">Sélectionner un avatar...</div>
            <div id="heygenSelectedMeta" style="font-size:11px;color:var(--text2);margin-top:2px">1287 disponibles · cliquer pour choisir</div>
          </div>
          <span style="color:var(--text2);font-size:12px">▼</span>
        </div>
        <input type="hidden" id="clipHeygenAvatar">
      </div>
      <!-- Voice picker -->
      <div class="form-group">
        <label>Voix DE</label>
        <div style="display:flex;gap:8px;margin-bottom:8px">
          <input type="text" id="heygenVoiceSearch" placeholder="🔍 Filtrer par nom..."
                 oninput="filterHeygenVoices()" style="flex:1;font-size:12px">
          <select id="heygenVoiceLangFilter" onchange="filterHeygenVoices()" style="width:130px;font-size:12px">
            <option value="de">🇩🇪 Allemand</option>
            <option value="all">Toutes langues</option>
          </select>
        </div>
        <div id="heygenVoiceList"
             style="max-height:220px;overflow-y:auto;display:flex;flex-direction:column;gap:3px;border:1px solid var(--border);border-radius:8px;padding:6px"></div>
        <input type="hidden" id="clipHeygenVoice">
      </div>
    </div>

    <!-- ── Prompt UGC Unifié ── script DE + visuel Sora 2 en 1 génération ── -->
    <div id="clipVisualPromptSection" class="form-group" style="margin-top:4px">
      <label style="display:flex;align-items:center;gap:6px;flex-wrap:wrap">
        Prompt UGC
        <button onclick="generateClipPrompt()" id="btnGenPrompt" class="btn btn-primary" style="padding:3px 14px;font-size:11px;display:inline-flex;align-items:center;gap:5px">
          ⚡ <span id="genPromptLabel">Générer</span>
        </button>
        <span id="genPromptStatus" style="font-size:10px;color:var(--accent);display:none">⏳ Génération...</span>
      </label>
      <!-- Script DE (traduction pour lecture) -->
      <div id="clipScriptFR" style="display:none;margin-bottom:6px;padding:6px 10px;background:rgba(78,205,196,0.08);border-left:3px solid var(--accent2);border-radius:0 6px 6px 0;font-size:11px;color:var(--text2);line-height:1.5">
        <span style="font-size:10px;text-transform:uppercase;letter-spacing:0.5px;color:var(--accent2);font-weight:700">🇩🇪 Script DE généré</span><br>
        <span id="clipScriptFRText"></span>
      </div>
      <textarea id="clipVisualPrompt" rows="6"
                placeholder="Cliquer ⚡ Générer — ou écrire manuellement (English pour Sora 2)&#10;&#10;Ex: German woman, 42, lying in dark bedroom 3am, phone glowing on nightstand showing 03:00, wide awake, exhausted eyes. She looks at camera: &quot;Ich wache seit Wochen um 3 Uhr auf. Heute nicht mehr.&quot; iPhone 15 Pro handheld, 9:16 vertical, raw authentic UGC, no ring light.&#10;Negative: studio, professional lighting, bottle, can, jar, round container"></textarea>
      <!-- Script DE caché — utilisé pour HeyGen TTS -->
      <input type="hidden" id="clipScript">
      <!-- Traduction FR du prompt complet — pour vérification -->
      <div id="clipPromptTranslation" style="display:none;margin-top:8px;padding:10px 12px;background:rgba(108,99,255,0.06);border-left:3px solid var(--accent);border-radius:0 6px 6px 0;font-size:11px;color:var(--text2);line-height:1.7">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px">
          <span style="font-size:10px;text-transform:uppercase;letter-spacing:0.5px;color:var(--accent);font-weight:700">🇫🇷 Traduction du prompt</span>
          <button onclick="document.getElementById('clipPromptTranslation').style.display='none'" style="background:none;border:none;cursor:pointer;color:var(--text2);font-size:12px;padding:0 4px" title="Fermer">✕</button>
        </div>
        <span id="clipPromptTranslationText" style="white-space:pre-wrap"></span>
      </div>
      <small id="consistencyHint" style="color:#888;font-size:11px;margin-top:4px;display:block"></small>

      <!-- ── Image produit (optionnel) ── -->
      <div style="margin-top:10px;border:1px solid var(--border);border-radius:8px;overflow:hidden">
        <div style="padding:8px 12px;background:rgba(255,255,255,0.03);border-bottom:1px solid var(--border);font-size:12px;font-weight:600;display:flex;align-items:center;gap:8px">
          🖼 Image produit
          <span style="font-weight:400;color:var(--text2);font-size:11px">— optionnel · requis pour les modèles I2V (🖼→🎬)</span>
        </div>
        <div style="padding:10px 12px">
          <!-- Tabs -->
          <div style="display:flex;gap:4px;margin-bottom:10px">
            <button class="img-tab-btn active" onclick="switchImgTab('assets',this)" style="padding:4px 10px;font-size:11px;border-radius:4px;border:1px solid var(--accent);background:rgba(108,99,255,0.2);cursor:pointer;color:var(--text)">📦 Assets Nellio</button>
            <button class="img-tab-btn" onclick="switchImgTab('upload',this)" style="padding:4px 10px;font-size:11px;border-radius:4px;border:1px solid var(--border);background:transparent;cursor:pointer;color:var(--text)">📤 Upload</button>
            <button class="img-tab-btn" onclick="switchImgTab('url',this)" style="padding:4px 10px;font-size:11px;border-radius:4px;border:1px solid var(--border);background:transparent;cursor:pointer;color:var(--text)">🔗 URL</button>
          </div>
          <!-- Tab: Assets Nellio -->
          <div id="imgTabAssets">
            <div id="brandAssetsGrid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(72px,1fr));gap:6px">
              <div style="color:var(--text2);font-size:11px;grid-column:1/-1">⏳ Chargement...</div>
            </div>
          </div>
          <!-- Tab: Upload -->
          <div id="imgTabUpload" style="display:none">
            <input type="file" id="imgUploadInput" accept="image/*" onchange="handleImgUpload(this)"
                   style="display:none">
            <button onclick="document.getElementById('imgUploadInput').click()" class="btn btn-secondary" style="width:100%;font-size:12px">
              📤 Choisir un fichier image (JPG, PNG, WebP)
            </button>
            <div id="imgUploadStatus" style="margin-top:6px;font-size:11px;color:var(--text2)"></div>
          </div>
          <!-- Tab: URL -->
          <div id="imgTabUrl" style="display:none">
            <input type="url" id="imgUrlInput" placeholder="https://drinknellio.com  ou  https://cdn.shopify.com/.../image.png"
                   oninput="onImgUrlInput(this.value)" style="width:100%;font-size:12px">
          <div id="imgUrlStatus" style="margin-top:5px;font-size:11px;color:var(--text2)"></div>
          <div id="imgUrlGallery" style="display:none;margin-top:8px;display:none"></div>
          </div>
          <!-- Preview image sélectionnée -->
          <div id="imgSelectedPreview" style="display:none;margin-top:10px;display:none;align-items:center;gap:10px;padding:8px;background:rgba(78,205,196,0.07);border-radius:6px;border:1px solid rgba(78,205,196,0.2)">
            <img id="imgSelectedThumb" style="height:64px;width:48px;object-fit:cover;border-radius:4px">
            <div style="flex:1;min-width:0">
              <div id="imgSelectedName" style="font-size:11px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis"></div>
              <div id="imgSelectedUrl" style="font-size:10px;color:var(--text2);white-space:nowrap;overflow:hidden;text-overflow:ellipsis"></div>
            </div>
            <button onclick="clearSelectedImage()" style="padding:4px 8px;font-size:11px;border-radius:4px;border:1px solid var(--border);background:transparent;cursor:pointer;color:var(--text2)" title="Supprimer">✕</button>
          </div>
        </div>
      </div>
    </div>

    <!-- ── Fond de scène HeyGen ── -->
    <div id="heygenBgSection" style="display:none" class="form-group">
      <label>Fond de scène HeyGen</label>
      <div style="display:flex;gap:8px;margin-bottom:10px;flex-wrap:wrap">
        <label style="display:flex;align-items:center;gap:6px;cursor:pointer;padding:8px 12px;border-radius:6px;border:1px solid var(--border);font-size:12px;flex:1;min-width:110px" id="bgLabelColor">
          <input type="radio" name="heygenBg" value="color" checked onchange="updateHeygenBg()" style="accent-color:var(--accent)"> 🎨 Fond uni
        </label>
        <label style="display:flex;align-items:center;gap:6px;cursor:pointer;padding:8px 12px;border-radius:6px;border:1px solid var(--border);font-size:12px;flex:1;min-width:110px" id="bgLabelNellio">
          <input type="radio" name="heygenBg" value="nellio" onchange="updateHeygenBg()" style="accent-color:var(--accent)">
          <img src="/assets/brand/nellio_16.png" style="height:18px;border-radius:3px"> Packaging
        </label>
        <label style="display:flex;align-items:center;gap:6px;cursor:pointer;padding:8px 12px;border-radius:6px;border:1px solid var(--border);font-size:12px;flex:1;min-width:110px">
          <input type="radio" name="heygenBg" value="custom" onchange="updateHeygenBg()" style="accent-color:var(--accent)"> 🔗 URL custom
        </label>
      </div>
      <!-- Couleur unie -->
      <div id="bgColorPicker" style="display:flex;align-items:center;gap:8px">
        <input type="color" id="heygenBgColor" value="#f8f4f0" oninput="updateHeygenBg()" style="width:40px;height:32px;border:none;background:none;cursor:pointer">
        <span style="font-size:12px;color:var(--text2)">Couleur de fond</span>
      </div>
      <!-- URL custom -->
      <div id="bgCustomUrl" style="display:none;margin-top:8px">
        <input type="url" id="heygenBgUrl" placeholder="https://... (image JPG/PNG/WebP)" oninput="updateHeygenBg()" style="width:100%">
      </div>
      <!-- Preview fond -->
      <div id="bgPreview" style="margin-top:10px;height:60px;border-radius:8px;border:1px solid var(--border);overflow:hidden;display:flex;align-items:center;justify-content:center;font-size:11px;color:var(--text2)">
        <span>Aperçu fond</span>
      </div>
    </div>

    <!-- ── Warnings clés API ── -->
    <div id="higgsfieldKeyWarning" style="display:none;background:rgba(255,180,0,0.1);border:1px solid rgba(255,180,0,0.3);border-radius:6px;padding:10px;font-size:12px;color:#ffb400;margin-bottom:12px">
      ⚠️ <strong>Higgsfield</strong> — Clé API non configurée. Définir <code>HIGGSFIELD_API_KEY=key:secret</code> dans les variables d'environnement du serveur, puis redémarrer.
    </div>
    <div id="heygenKeyWarning" style="display:none;background:rgba(255,180,0,0.1);border:1px solid rgba(255,180,0,0.3);border-radius:6px;padding:10px;font-size:12px;color:#ffb400;margin-bottom:12px">
      ⚠️ <strong>HeyGen</strong> — Clé API non configurée. Récupérer sur <a href="https://app.heygen.com/settings?nav=API" target="_blank" style="color:#ffb400">app.heygen.com → Settings → API</a>, puis définir <code>HEYGEN_API_KEY=...</code> côté serveur.
    </div>

    <button onclick="generateClipVariants()" id="clipGenerateBtn" class="btn btn-primary" style="width:100%;padding:14px;font-size:15px">
      🎬 Générer 3 variantes <span id="clipCostLabel" style="opacity:0.6;font-size:12px">(40 crédits × 3 = 120 crédits)</span>
    </button>
  </div>

  <!-- SECTION B : COMPARAISON 3 VARIANTES -->
  <div id="variantSection" style="display:none;margin-top:24px">
    <div class="card">
      <div class="card-title">Choisissez la meilleure variante</div>
      <div id="variantPollStatus" style="display:none;margin-bottom:12px">
        <!-- Fiche de suivi génération -->
        <div style="background:rgba(255,255,255,0.03);border:1px solid var(--border);border-radius:8px;padding:12px 14px;font-size:12px">
          <div style="display:flex;align-items:center;gap:8px;margin-bottom:10px">
            <div class="spinner" style="flex-shrink:0;width:14px;height:14px;border-width:2px"></div>
            <span id="variantPollText" style="color:var(--text1);font-weight:600;font-size:13px">Génération en cours...</span>
          </div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:4px 16px;color:var(--text2)">
            <div>🤖 <span style="color:var(--text1)" id="genMetaModel">—</span></div>
            <div>⏱ <span style="color:var(--text1)" id="genMetaElapsed">0s</span></div>
            <div>📊 <span style="color:var(--text1)" id="genMetaState">—</span></div>
            <div>🎬 <span style="color:var(--text1)" id="genMetaDuration">—</span></div>
          </div>
          <!-- Barre de progression (kie.ai only) -->
          <div id="genProgressBar" style="margin-top:10px;display:none">
            <div style="display:flex;justify-content:space-between;margin-bottom:4px;font-size:11px;color:var(--text2)">
              <span>Progression</span><span id="genProgressPct">0%</span>
            </div>
            <div style="height:4px;background:rgba(255,255,255,0.08);border-radius:2px;overflow:hidden">
              <div id="genProgressFill" style="height:100%;background:var(--accent);border-radius:2px;transition:width 0.5s ease;width:0%"></div>
            </div>
          </div>
          <!-- Poll interval indicator -->
          <div style="margin-top:8px;font-size:10px;color:var(--text2);opacity:0.6">
            🔄 Poll UI toutes les <strong>10s</strong> · <span id="genMetaVariants">0/0</span> variante(s) prête(s)
          </div>
        </div>
      </div>
      <div id="variantCards" style="display:flex;flex-wrap:wrap;gap:12px;margin-top:12px;align-items:flex-start"></div>

      <!-- Lightbox plein écran -->
      <div id="variantLightbox" onclick="closeLightbox()" style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,0.92);align-items:center;justify-content:center;cursor:zoom-out">
        <video id="lbVideo" loop controls playsinline style="max-height:82vh;max-width:88vw;border-radius:8px;box-shadow:0 0 60px rgba(0,0,0,0.8)"></video>
        <!-- Barre d'action lightbox -->
        <div style="position:absolute;top:16px;right:16px;display:flex;gap:8px;align-items:center">
          <button id="lbOpenTab" style="background:rgba(50,200,100,0.85);border:none;color:#fff;font-size:12px;font-weight:600;padding:6px 12px;border-radius:6px;cursor:pointer" title="Son garanti — ouvre dans un onglet Chrome">🔊 Son garanti</button>
          <button onclick="closeLightbox()" style="background:rgba(255,255,255,0.1);border:none;color:#fff;font-size:20px;padding:6px 12px;border-radius:6px;cursor:pointer">✕</button>
        </div>
      </div>
    </div>
  </div>

  <!-- SECTION C : PROJET EN COURS -->
  <div id="studioProjectPanel" style="display:none;margin-top:24px;padding:20px;background:rgba(255,255,255,0.03);border-radius:12px;border:1px solid rgba(255,255,255,0.1)">
    <h3 style="margin-bottom:16px;font-size:16px">📁 Projet en cours : <span id="studioProjectName" style="color:var(--accent)">--</span></h3>

    <div id="studioClipsList" style="display:flex;flex-direction:column;gap:8px;margin-bottom:20px"></div>

    <div style="display:flex;gap:16px;flex-wrap:wrap;align-items:flex-start">
      <div style="flex:1;min-width:240px">
        <label style="font-size:12px;color:var(--text2);display:block;margin-bottom:6px">Script complet pour voiceover DE</label>
        <textarea id="fullScriptDE" rows="6" placeholder="Script complet en allemand (agrégé depuis les clips)..."></textarea>
        <button onclick="generateProjectVoiceover()" class="btn btn-secondary" style="margin-top:8px;width:100%">
          🎵 Générer voiceover DE complet (ElevenLabs)
        </button>
      </div>
      <div style="display:flex;flex-direction:column;gap:10px;padding-top:22px">
        <button onclick="exportProjectZip()" class="btn btn-primary" style="white-space:nowrap">
          📦 Exporter ZIP (MP4 clips)
        </button>
        <small style="color:var(--text2);font-size:11px;text-align:center">Pour CapCut / Premiere</small>
      </div>
    </div>
  </div>
  </div><!-- /studio-pane-ugc -->

  <!-- ════ PANE B-ROLL ════ -->
  <div class="studio-pane" id="studio-pane-broll">
    <div class="grid-2">
      <div>
        <div class="card">
          <div class="card-title">Templates B-Roll Nellio</div>
          <div id="brollTemplates" style="display:flex;flex-direction:column;gap:8px"></div>
        </div>
        <div class="card">
          <div class="card-title">Prompt custom</div>
          <div class="form-group">
            <label>Nom</label>
            <input type="text" id="brName" placeholder="ex: Nellio-product-hand">
          </div>
          <div class="form-group">
            <label>Prompt Kling 3.0 (anglais, cinématique)</label>
            <textarea id="brPrompt" placeholder="Cinematic product shot, Nellio UltraCalm..." style="min-height:100px"></textarea>
          </div>
          <div class="form-group">
            <label>Durée (secondes)</label>
            <select id="brDuration">
              <option value="3">3s</option>
              <option value="5" selected>5s</option>
              <option value="10">10s</option>
            </select>
          </div>
          <div class="alert alert-info" style="margin-bottom:12px;font-size:12px">
            💰 Kling 3.0 = 40 crédits/seconde → 5s = 200 crédits ($1)
          </div>
          <button class="btn btn-primary" onclick="generateBroll()" style="width:100%">🎥 Générer B-Roll</button>
        </div>
      </div>
      <div>
        <div class="card">
          <div class="card-title">B-Roll Library</div>
          <div id="brStatus" style="font-size:13px;color:var(--text2);margin-bottom:12px"></div>
          <div id="brLibrary" style="display:flex;flex-direction:column;gap:8px"></div>
          <button class="btn btn-secondary btn-sm" style="margin-top:12px" onclick="refreshBrolls()">🔄 Rafraîchir</button>
        </div>
      </div>
    </div>
  </div><!-- /studio-pane-broll -->

  <!-- ════ PANE VOICEOVER ════ -->
  <div class="studio-pane" id="studio-pane-voiceover">
    <div class="grid-2">
      <div>
        <div class="card">
          <div class="card-title">Générer un voiceover</div>
          <div class="form-group">
            <label>Texte DE (script ou hook)</label>
            <textarea id="voText" placeholder="Coller le texte allemand ici..." style="min-height:150px"></textarea>
          </div>
          <div class="form-group">
            <label>Voix</label>
            <select id="voVoice">
              <option value="de_male_calm">🎙️ Adam — Homme calme (recommandé UGC)</option>
              <option value="de_female_warm">🎙️ Bella — Femme chaleureuse</option>
              <option value="de_male_deep">🎙️ Antoni — Homme profond (ZackD style)</option>
              <option value="de_female_pro">🎙️ Elli — Femme professionnelle</option>
            </select>
          </div>
          <div class="alert alert-info" style="margin-bottom:16px;font-size:12px">
            💰 Voiceover DE ≈ 5-15 crédits selon longueur
          </div>
          <button class="btn btn-primary" onclick="generateVoiceover()" id="btnVoice" style="width:100%">
            🔊 Générer voiceover
          </button>
        </div>
        <div class="card">
          <div class="card-title">⚡ Accès rapide scripts</div>
          <div class="script-selector">
            <div class="script-item" onclick="loadVoiceScript('1A')">
              <div class="script-title">1.A — Nacht #187</div>
              <div class="script-hook">SA-02 · ~45s · Insomnaque</div>
            </div>
            <div class="script-item" onclick="loadVoiceScript('4C')">
              <div class="script-title">4.C — PMC 31517876</div>
              <div class="script-hook">SA-08 · ~30s · Biohacker · ZackD parfait</div>
            </div>
            <div class="script-item" onclick="loadVoiceScript('4B')">
              <div class="script-title">4.B — Anti-SSRI</div>
              <div class="script-hook">SA-11 · ~45s · Femme jeune</div>
            </div>
          </div>
        </div>
      </div>
      <div>
        <div class="card">
          <div class="card-title">Statut + Voiceovers générés</div>
          <div id="voStatus" style="color:var(--text2);font-size:13px;margin-bottom:16px">
            Lance une génération pour voir le statut.
          </div>
          <div id="voLibrary" style="display:flex;flex-direction:column;gap:8px"></div>
        </div>
      </div>
    </div>
  </div><!-- /studio-pane-voiceover -->

  <!-- ════ PANE ZACKD CINEMATIC ════ -->
  <div class="studio-pane" id="studio-pane-cinematic">
    <div class="alert alert-info" style="margin-bottom:20px">
      🎬 Pipeline : Claude découpe le script en scènes → Kling 3.0 génère les clips → ElevenLabs voiceover DE → ffmpeg assemble
    </div>
    <div class="grid-2">
      <div>
        <div class="card">
          <div class="card-title">1. Générer les scènes</div>
          <div class="form-group">
            <label>Script DE (ou hook + concept)</label>
            <textarea id="cinScript" placeholder="PMC 31517876. Das ist die Studie. -27,9% Cortisol in 60 Tagen..." style="min-height:150px"></textarea>
          </div>
          <div class="form-group">
            <label>Angle cinématique</label>
            <select id="cinAngle">
              <option value="science">🔬 Science dramatique (cortisol molecules, brain, KSM-66)</option>
              <option value="transformation">✨ Transformation (avant/après, corps, énergie)</option>
              <option value="nature">🌿 Nature + produit (plantes adaptogènes, pureté)</option>
              <option value="urgency">⚡ Urgence (corps en stress, horloge, conséquences)</option>
              <option value="trust">🏆 Social proof cinématique (chiffres, études, résultats)</option>
            </select>
          </div>
          <div class="form-group">
            <label>Clé API Anthropic</label>
            <div style="padding:8px 12px;background:rgba(78,205,196,0.1);border:1px solid rgba(78,205,196,0.3);border-radius:6px;font-size:12px;color:#4ECDC4">✅ Claude OAuth actif — aucune clé requise</div>
          </div>
          <button class="btn btn-primary" onclick="generateCinematicScenes()" id="btnCinScenes" style="width:100%">
            🎬 Générer les scènes Claude
          </button>
        </div>
        <div class="card">
          <div class="card-title">2. Produire les clips</div>
          <div id="cinScenes" style="font-size:13px;color:var(--text2)">Les scènes apparaîtront ici après l'étape 1.</div>
          <div id="cinProduceBtn" style="margin-top:12px;display:none">
            <div class="alert alert-info" style="margin-bottom:12px;font-size:12px">
              💰 4 clips Kling 3.0 (4s) + 1 voiceover ≈ 640 crédits ($3.20)
            </div>
            <button class="btn btn-primary" onclick="produceCinematic()" id="btnCinProduce" style="width:100%">
              🎬 Lancer la production (Kling 3.0 + ElevenLabs)
            </button>
          </div>
        </div>
      </div>
      <div>
        <div class="card">
          <div class="card-title">3. Assembler (ffmpeg)</div>
          <div id="cinStatus" style="font-size:13px;color:var(--text2);margin-bottom:12px">Attendre que tous les clips soient prêts.</div>
          <div id="cinAssembleBtn" style="display:none">
            <button class="btn btn-success" onclick="assembleCinematic()" style="width:100%">⚙️ Assembler avec ffmpeg</button>
          </div>
          <div id="cinResult" style="margin-top:12px"></div>
        </div>
        <div class="card">
          <div class="card-title">Projets Cinématiques</div>
          <div id="cinProjects" style="font-size:13px;color:var(--text2)">Aucun projet...</div>
          <button class="btn btn-secondary btn-sm" style="margin-top:12px" onclick="refreshCinematics()">🔄 Rafraîchir</button>
        </div>
        <div class="card">
          <div class="card-title">🎬 Référence Style ZackD Films</div>
          <div style="font-size:12px;color:var(--text2);line-height:2">
            <div>🎥 <strong>Kling 3.0</strong> — visuals cinématiques dramatiques</div>
            <div>🔊 <strong>ElevenLabs V2</strong> — voix DE naturelle Antoni (deep)</div>
            <div>⚡ <strong>Cuts rapides</strong> — 3-4s par scène</div>
            <div>🌑 <strong>Dark aesthetic</strong> — fond sombre, lumières vives</div>
            <div>📝 <strong>Sous-titres</strong> — ffmpeg burn-in</div>
            <div>🧬 <strong>Idéal pour</strong> — SA-08 Biohacker · Science · Pattern Interrupt</div>
          </div>
        </div>
      </div>
    </div>
  </div><!-- /studio-pane-cinematic -->

  <!-- ════ PANE LONG FORM ════ -->
  <div class="studio-pane" id="studio-pane-longform">
    <div class="alert alert-info" style="margin-bottom:20px;font-size:13px">
      🎬 <strong>Long Form</strong> — Générez 4–6 scènes séquentielles avec le même avatar + angle.
      Chaque scène = 1 clip UGC IA. Assemblez ensuite dans CapCut ou Premiere.
    </div>
    <div class="grid-2">
      <div>
        <!-- Config globale Long Form -->
        <div class="card">
          <div class="card-title">🎭 Config — partagée toutes les scènes</div>
          <div class="form-group">
            <label>Avatar <span style="font-size:10px;color:var(--accent)">— EVOLVE Phase 2</span></label>
            <select id="lfAvatarSelect">
              <optgroup label="👩‍💼 A1 — Professionnelle Surchargée">
                <option value="A1">A1 — Die Erschöpfte Berufstätige</option>
                <option value="A1-a">A1-a — Manager Irritable</option>
                <option value="A1-b">A1-b — Freelancerin Sans Off</option>
                <option value="A1-c">A1-c — Ärztin / Pflegerin</option>
                <option value="A1-d">A1-d — Karrierefrau nach 40</option>
              </optgroup>
              <optgroup label="👩‍👧 A2 — Mère en Surcharge">
                <option value="A2">A2 — Die Überlastete Mutter</option>
                <option value="A2-a">A2-a — Alleinerziehende</option>
                <option value="A2-b">A2-b — Post-Partum (12m+)</option>
                <option value="A2-c">A2-c — Sandwich Generation</option>
              </optgroup>
              <optgroup label="🔥 A3 — En Risque Burnout">
                <option value="A3">A3 — Der/Die Burnout-Gefährdete</option>
                <option value="A3-a">A3-a — CEO unter Druck</option>
                <option value="A3-b">A3-b — Lehrer Silent Burnout</option>
                <option value="A3-c">A3-c — Alles-Versucher</option>
                <option value="A3-d">A3-d — Lexapro-Vermeiderin</option>
                <option value="A3-e" selected>A3-e ⭐ — 3-Uhr-Wachlieger</option>
              </optgroup>
              <optgroup label="🧬 A4 — Biohacker / Wellness">
                <option value="A4">A4 — Biohacker / Wellness-Enthusiast</option>
                <option value="A4-a">A4-a — Ashwagandha-Enttäuschter</option>
                <option value="A4-b">A4-b — Multi-Stack-Optimierer</option>
              </optgroup>
            </select>
          </div>
          <div class="form-group">
            <label>Angle marketing</label>
            <select id="lfAngle">
              <option value="cortisol">🧪 Cortisol · "Dein Cortisol macht Überstunden"</option>
              <option value="schlaf">😴 Sommeil · "3 Uhr morgens. Schon wieder wach."</option>
              <option value="identite">🪞 Identité perdue · "Ich bin nicht mehr ich selbst"</option>
              <option value="performance">⚡ Performance · "3 Kaffee. Immer noch erschöpft."</option>
              <option value="burnout">🔥 Burnout prévention · "Dein Körper sendet Signale."</option>
              <option value="objection">🚫 J'ai tout essayé · "Baldrian: nichts. Melatonin: müder."</option>
              <option value="pharma_alternative">💊 Alternative · "Il y a une étape avant Lexapro"</option>
              <option value="science">🔬 Science KSM-66 · "Der Unterschied ist die Form."</option>
              <option value="stack">🧬 Stack 4-en-1 · "8 Kapseln. Oder eine Portion Nellio."</option>
            </select>
          </div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
            <div class="form-group" style="margin-bottom:0">
              <label>Provider</label>
              <select id="lfProvider" onchange="updateLFModels()">
                <option value="kie">🔮 kie.ai</option>
                <option value="higgsfield">⚡ Higgsfield</option>
                <option value="heygen">🎭 HeyGen</option>
              </select>
            </div>
            <div class="form-group" style="margin-bottom:0">
              <label>Format</label>
              <select id="lfFormat">
                <option value="9:16">📱 9:16</option>
                <option value="16:9">🖥️ 16:9</option>
                <option value="1:1">⬜ 1:1</option>
              </select>
            </div>
          </div>
          <div class="form-group" style="margin-top:12px">
            <label>Modèle</label>
            <select id="lfModel"></select>
          </div>
        </div>

        <!-- Séquence de scènes -->
        <div class="card">
          <div class="card-title">📋 Séquence de scènes</div>
          <div id="lfSceneList">
            <div class="lf-scene-item" data-index="0">
              <div class="lf-scene-header">
                <span class="lf-scene-num">#1</span>
                <select class="lf-scene-type" style="flex:1;font-size:13px">
                  <option value="Hook" selected>🎣 Hook</option>
                  <option value="Problem">😰 Problème</option>
                  <option value="Solution">✨ Solution</option>
                  <option value="CTA">📣 CTA</option>
                  <option value="Testimonial">💬 Témoignage</option>
                </select>
                <span class="lf-scene-status" style="font-size:11px;color:var(--text2);min-width:72px;text-align:right">⏸ En attente</span>
              </div>
              <div class="lf-scene-body">
                <div class="lf-scene-prompt"></div>
                <div class="lf-scene-clips" style="margin-top:8px"></div>
              </div>
            </div>
            <div class="lf-scene-item" data-index="1">
              <div class="lf-scene-header">
                <span class="lf-scene-num">#2</span>
                <select class="lf-scene-type" style="flex:1;font-size:13px">
                  <option value="Hook">🎣 Hook</option>
                  <option value="Problem" selected>😰 Problème</option>
                  <option value="Solution">✨ Solution</option>
                  <option value="CTA">📣 CTA</option>
                  <option value="Testimonial">💬 Témoignage</option>
                </select>
                <span class="lf-scene-status" style="font-size:11px;color:var(--text2);min-width:72px;text-align:right">⏸ En attente</span>
              </div>
              <div class="lf-scene-body"><div class="lf-scene-prompt"></div><div class="lf-scene-clips" style="margin-top:8px"></div></div>
            </div>
            <div class="lf-scene-item" data-index="2">
              <div class="lf-scene-header">
                <span class="lf-scene-num">#3</span>
                <select class="lf-scene-type" style="flex:1;font-size:13px">
                  <option value="Hook">🎣 Hook</option>
                  <option value="Problem">😰 Problème</option>
                  <option value="Solution" selected>✨ Solution</option>
                  <option value="CTA">📣 CTA</option>
                  <option value="Testimonial">💬 Témoignage</option>
                </select>
                <span class="lf-scene-status" style="font-size:11px;color:var(--text2);min-width:72px;text-align:right">⏸ En attente</span>
              </div>
              <div class="lf-scene-body"><div class="lf-scene-prompt"></div><div class="lf-scene-clips" style="margin-top:8px"></div></div>
            </div>
            <div class="lf-scene-item" data-index="3">
              <div class="lf-scene-header">
                <span class="lf-scene-num">#4</span>
                <select class="lf-scene-type" style="flex:1;font-size:13px">
                  <option value="Hook">🎣 Hook</option>
                  <option value="Problem">😰 Problème</option>
                  <option value="Solution">✨ Solution</option>
                  <option value="CTA" selected>📣 CTA</option>
                  <option value="Testimonial">💬 Témoignage</option>
                </select>
                <span class="lf-scene-status" style="font-size:11px;color:var(--text2);min-width:72px;text-align:right">⏸ En attente</span>
              </div>
              <div class="lf-scene-body"><div class="lf-scene-prompt"></div><div class="lf-scene-clips" style="margin-top:8px"></div></div>
            </div>
          </div>
          <div style="display:flex;gap:8px;margin-top:12px">
            <button class="btn btn-secondary btn-sm" onclick="addLFScene()">+ Scène</button>
            <button class="btn btn-secondary btn-sm" onclick="removeLFScene()" id="btnRemoveLFScene">− Scène</button>
            <div style="font-size:11px;color:var(--text2);align-self:center;margin-left:auto" id="lfSceneCount">4 scènes</div>
          </div>
        </div>
      </div>

      <div>
        <!-- Lancer -->
        <div class="card">
          <div class="card-title">🚀 Lancer la production</div>
          <div id="lfCostEstimate" style="font-size:13px;color:var(--text2);margin-bottom:16px">
            kie.ai Sora 2 · 4 scènes × 40 cr = <strong>160 crédits (~$0.80)</strong>
          </div>
          <button class="btn btn-primary" onclick="generateLongForm()" id="btnGenerateLF" style="width:100%;margin-bottom:12px">
            ⚡ Générer toutes les scènes
          </button>
          <div id="lfProgress" style="display:none">
            <div class="progress-bar"><div class="progress-fill" id="lfProgressFill" style="width:0%"></div></div>
            <div style="font-size:12px;color:var(--text2);margin-top:6px;text-align:center" id="lfProgressText">0/4 scènes prêtes</div>
          </div>
          <button class="btn btn-success" onclick="exportLongFormZip()" id="btnLFExport" style="width:100%;margin-top:12px;display:none">
            📦 Exporter ZIP (toutes les scènes)
          </button>
        </div>

        <!-- Timeline résultats -->
        <div class="card">
          <div class="card-title">🎬 Timeline — clips générés</div>
          <div id="lfTimeline" style="font-size:13px;color:var(--text2);min-height:60px">
            Les clips apparaîtront ici au fur et à mesure.
          </div>
        </div>

        <!-- Tips -->
        <div class="card" style="background:rgba(108,99,255,0.05)">
          <div class="card-title">💡 Conseils Long Form</div>
          <div style="font-size:12px;color:var(--text2);line-height:1.8">
            <div>📱 <strong>Format recommandé</strong> : 9:16 (Reels / Shorts)</div>
            <div>⏱️ <strong>Durée idéale</strong> : 4 scènes × 10s = ~40s total</div>
            <div>🎭 <strong>1 avatar = cohérence</strong> visuelle et narrative</div>
            <div>🔄 <strong>Ordre conseillé</strong> : Hook → Problème → Solution → CTA</div>
            <div>✂️ <strong>Assemblage</strong> : importer le ZIP dans CapCut / Premiere</div>
          </div>
        </div>
      </div>
    </div>
  </div><!-- /studio-pane-longform -->

  <!-- IMAGE AD moved to creation-panel-host -->
  <div class="studio-pane" id="studio-pane-imagead" style="display:none!important">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px">

      <div>
        <div class="card">
          <div class="card-title">🖼️ Générateur Image Ad — Meta DE</div>
