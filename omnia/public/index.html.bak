        <div class="card" style="margin-top:0">
          <div class="card-title" style="font-size:12px">Workflow</div>
          <ol style="font-size:12px;color:var(--text2);padding-left:16px;line-height:1.8">
            <li>Choisir avatar + angle du Batch #1 Marksman</li>
            <li>Format Story 9:16 pour cold audience Meta</li>
            <li>Style UGC = meilleur thumb-stop DE</li>
            <li>Copier → Midjourney v6.1</li>
            <li>Combiner avec scripts UGC S1/S2/S3</li>
          </ol>
        </div>
      </div>

      <div>
        <div class="card" style="min-height:400px;display:flex;flex-direction:column">
          <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px">
            <div class="card-title" style="margin-bottom:0">Prompt généré</div>
            <button id="imgad-copy-btn" onclick="copyImageAdPrompt()" class="btn btn-secondary btn-sm" style="display:none">📋 Copier</button>
          </div>
          <div id="imgad-output" style="flex:1;background:var(--surface2);border-radius:8px;padding:16px;font-size:12px;font-family:monospace;line-height:1.7;color:var(--text2);white-space:pre-wrap;min-height:320px;display:flex;align-items:center;justify-content:center">
            <span style="color:var(--text2);font-size:13px;font-family:inherit">Configure les options et clique sur Générer ↑</span>
          </div>
        </div>
      </div>

    </div>
  </div><!-- /studio-pane-imagead -->

  <!-- ════ PANE PIPELINE (ex-Creative Factory UGC) ════ -->
  <div class="studio-pane" id="studio-pane-pipeline" style="display:none">
    <div class="card" style="margin-bottom:20px">
      <h3 style="margin:0 0 8px;font-size:16px">🏭 UGC Auto-Pipeline — 3 Vidéos DE</h3>
      <p style="color:var(--text2);font-size:13px;margin:0 0 16px">Génère automatiquement les 3 scripts UGC (Teufelskreis / Gedankenkarussell / Cortisol) via HeyGen.</p>
      <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap;margin-bottom:16px">
        <button class="btn-primary" onclick="startUGCPipeline()" id="btn-ugc-start" style="background:var(--accent);color:#fff;border:none;padding:10px 20px;border-radius:8px;cursor:pointer;font-weight:600">🚀 Lancer les 3 vidéos</button>
        <button onclick="startUGCWebUI()" id="btn-ugc-webui" style="background:rgba(74,222,128,0.1);color:#4ade80;border:1px solid rgba(74,222,128,0.3);padding:10px 16px;border-radius:8px;cursor:pointer;font-size:13px;font-weight:600">🌐 Via Web UI</button>
        <button onclick="refreshUGCStatus()" style="background:var(--surface2);color:var(--text);border:1px solid var(--border);padding:10px 16px;border-radius:8px;cursor:pointer;font-size:13px">🔄 Rafraîchir</button>
        <span id="ugc-status-badge" style="font-size:12px;color:var(--text2)">Prêt</span>
      </div>
      <div id="ugc-jobs-grid" style="display:grid;grid-template-columns:repeat(3,1fr);gap:14px">
        <div class="ugc-job-card" id="ugc-job-s1" style="background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:14px">
          <div style="font-size:12px;color:var(--text2);margin-bottom:6px">Script 1</div>
          <div style="font-weight:600;font-size:14px;margin-bottom:8px">Der Teufelskreis</div>
          <div style="font-size:11px;color:#a0a0a0;margin-bottom:10px;line-height:1.4">"Du schläfst schlecht WEIL du gestresst bist..."</div>
          <div class="job-status" style="display:inline-block;padding:3px 10px;border-radius:20px;font-size:11px;background:rgba(255,255,255,0.06);color:var(--text2)">⏳ En attente</div>
        </div>
        <div class="ugc-job-card" id="ugc-job-s2" style="background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:14px">
          <div style="font-size:12px;color:var(--text2);margin-bottom:6px">Script 2</div>
          <div style="font-weight:600;font-size:14px;margin-bottom:8px">Das Gedankenkarussell</div>
          <div style="font-size:11px;color:#a0a0a0;margin-bottom:10px;line-height:1.4">"Das Gedankenkarussell nachts — kein Willensproblem..."</div>
          <div class="job-status" style="display:inline-block;padding:3px 10px;border-radius:20px;font-size:11px;background:rgba(255,255,255,0.06);color:var(--text2)">⏳ En attente</div>
        </div>
        <div class="ugc-job-card" id="ugc-job-s3" style="background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:14px">
          <div style="font-size:12px;color:var(--text2);margin-bottom:6px">Script 3</div>
          <div style="font-weight:600;font-size:14px;margin-bottom:8px">Cortisol nachts</div>
          <div style="font-size:11px;color:#a0a0a0;margin-bottom:10px;line-height:1.4">"Dein Cortisol ist nachts noch aktiv..."</div>
          <div class="job-status" style="display:inline-block;padding:3px 10px;border-radius:20px;font-size:11px;background:rgba(255,255,255,0.06);color:var(--text2)">⏳ En attente</div>
        </div>
      </div>
    </div>
    <div class="card">
      <h3 style="margin:0 0 14px;font-size:15px">✅ Vidéos Générées</h3>
      <div id="ugc-results-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:14px">
        <div style="color:var(--text2);font-size:13px;grid-column:1/-1">Aucune vidéo générée pour l'instant.</div>
      </div>
    </div>
  </div><!-- /studio-pane-pipeline -->

  <!-- ════ PANE CLONER (ex-Creative Factory Cloner) ════ -->
  <div class="studio-pane" id="studio-pane-cloner" style="display:none">
    <div class="card" style="margin-bottom:20px">
      <h3 style="margin:0 0 8px;font-size:16px">🔄 Video Cloner — Reproduire une vidéo concurrente</h3>
      <p style="color:var(--text2);font-size:13px;margin:0 0 18px">Analyse la structure d'une vidéo concurrente et génère une version Nellio avec la même architecture.</p>
      <div style="margin-bottom:14px">
        <label style="display:block;font-size:12px;color:var(--text2);margin-bottom:6px">URL de la vidéo (YouTube, etc.)</label>
        <input type="text" id="cloner-url" placeholder="https://youtube.com/watch?v=..." style="width:100%;background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:10px 12px;color:var(--text);font-size:13px;box-sizing:border-box">
      </div>
      <div style="margin-bottom:14px">
        <label style="display:block;font-size:12px;color:var(--text2);margin-bottom:6px">— ou — Colle le transcript directement</label>
        <textarea id="cloner-transcript" rows="5" placeholder="Colle ici le texte/transcript de la vidéo concurrente..." style="width:100%;background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:10px 12px;color:var(--text);font-size:13px;resize:vertical;box-sizing:border-box"></textarea>
      </div>
      <div style="display:flex;gap:10px;align-items:center;margin-bottom:16px">
        <button onclick="analyzeVideo()" style="background:var(--accent);color:#fff;border:none;padding:10px 20px;border-radius:8px;cursor:pointer;font-weight:600">🔍 Analyser</button>
        <span id="cloner-status" style="font-size:13px;color:var(--text2)"></span>
      </div>
      <div id="cloner-analysis-result" style="display:none;background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:16px;margin-bottom:16px">
        <h4 style="margin:0 0 12px;font-size:14px;color:var(--accent)">Structure détectée</h4>
        <pre id="cloner-analysis-pre" style="font-size:12px;color:var(--text2);white-space:pre-wrap;margin:0;max-height:300px;overflow-y:auto"></pre>
      </div>
      <div id="cloner-generate-section" style="display:none">
        <div style="display:flex;gap:10px;align-items:center;margin-bottom:14px">
          <label style="font-size:13px">Avatar:</label>
          <select id="cloner-gender" style="background:var(--surface);border:1px solid var(--border);border-radius:6px;padding:8px 12px;color:var(--text)">
            <option value="female">Femme (Sonja)</option>
            <option value="male">Homme (Markus)</option>
          </select>
          <button onclick="generateClone()" style="background:#4ECDC4;color:#0d0d1a;border:none;padding:10px 20px;border-radius:8px;cursor:pointer;font-weight:700">🎬 Cloner pour Nellio</button>
        </div>
        <div id="cloner-script-result" style="display:none;background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:16px">
          <h4 style="margin:0 0 10px;font-size:14px">Script DE Généré</h4>
          <pre id="cloner-script-pre" style="font-size:13px;white-space:pre-wrap;margin:0 0 12px;line-height:1.6"></pre>
          <div id="cloner-video-result" style="display:none">
            <div style="font-size:12px;color:var(--text2);margin-bottom:6px">Génération vidéo en cours... (2-5 min)</div>
            <div id="cloner-job-id" style="font-size:11px;color:#6c63ff"></div>
          </div>
        </div>
      </div>
    </div>
  </div><!-- /studio-pane-cloner -->

  <!-- ════ PANE AUTOMATION (ex-Creative Factory Automation) ════ -->
  <div class="studio-pane" id="studio-pane-automation" style="display:none">
    <div style="display:grid;grid-template-columns:2fr 1fr;gap:16px;margin-bottom:20px">
      <div class="card">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px">
          <h3 style="margin:0;font-size:16px">⚡ Automation Engine</h3>
          <div id="automation-running-badge" style="padding:4px 12px;border-radius:20px;font-size:12px;font-weight:600;background:rgba(78,205,196,0.15);color:#4ECDC4">● Actif</div>
        </div>
        <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:16px">
          <div style="text-align:center;background:var(--surface);border-radius:8px;padding:12px">
            <div id="auto-stat-pending" style="font-size:22px;font-weight:700;color:var(--accent)">0</div>
            <div style="font-size:11px;color:var(--text2)">En attente</div>
          </div>
          <div style="text-align:center;background:var(--surface);border-radius:8px;padding:12px">
            <div id="auto-stat-processing" style="font-size:22px;font-weight:700;color:#f0a500">0</div>
            <div style="font-size:11px;color:var(--text2)">En cours</div>
          </div>
          <div style="text-align:center;background:var(--surface);border-radius:8px;padding:12px">
            <div id="auto-stat-completed" style="font-size:22px;font-weight:700;color:#4ECDC4">0</div>
            <div style="font-size:11px;color:var(--text2)">Complétés</div>
          </div>
          <div style="text-align:center;background:var(--surface);border-radius:8px;padding:12px">
            <div id="auto-stat-failed" style="font-size:22px;font-weight:700;color:#FF6B6B">0</div>
            <div style="font-size:11px;color:var(--text2)">Échoués</div>
          </div>
        </div>
        <div style="display:flex;gap:10px;flex-wrap:wrap">
          <button onclick="runAllPipeline()" style="background:linear-gradient(135deg,#6c63ff,#FF6B6B);color:#fff;border:none;padding:12px 24px;border-radius:8px;cursor:pointer;font-weight:700;font-size:14px">🚀 Run All Pipeline</button>
          <button onclick="refreshAutomationStatus()" style="background:var(--surface2);color:var(--text);border:1px solid var(--border);padding:10px 16px;border-radius:8px;cursor:pointer;font-size:13px">🔄 Rafraîchir</button>
          <button onclick="clearQueue()" style="background:rgba(255,107,107,0.1);color:#FF6B6B;border:1px solid rgba(255,107,107,0.3);padding:10px 16px;border-radius:8px;cursor:pointer;font-size:13px">🗑️ Vider queue</button>
        </div>
      </div>
      <div class="card" style="display:flex;flex-direction:column;justify-content:center;align-items:center;text-align:center">
        <div style="font-size:40px;margin-bottom:8px">🏭</div>
        <div style="font-size:13px;color:var(--text2);margin-bottom:4px">Uptime</div>
        <div id="auto-uptime" style="font-size:18px;font-weight:600;color:var(--accent)">—</div>
        <div style="font-size:11px;color:var(--text2);margin-top:8px">Poll HeyGen toutes les 30s</div>
      </div>
    </div>
    <div class="card">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:14px">
        <h3 style="margin:0;font-size:15px">📋 Log Automation</h3>
        <span style="font-size:12px;color:var(--text2)">20 dernières actions</span>
      </div>
      <div id="auto-log-feed" style="font-family:monospace;font-size:12px;max-height:400px;overflow-y:auto;background:var(--surface);border-radius:8px;padding:12px">
        <div style="color:var(--text2)">Chargement du log...</div>
      </div>
    </div>
  </div><!-- /studio-pane-automation -->

</div>
<div class="creation-panel" id="cpanel-imagead" style="display:none">
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px">
    <div>
      <div class="card">
        <div class="card-title">🖼️ Générateur Image Ad — Meta DE</div>
        <p style="font-size:12px;color:var(--text2);margin-bottom:16px">Prompts Midjourney optimisés · Avatars V2 · Angles EVOLVE Batch #1</p>
        <div class="form-group">
          <label>Avatar cible</label>
          <select id="imgad-avatar">
            <option value="sonja">Sonja — Berufsstress (32, Munich)</option>
            <option value="markus">Markus — Père épuisé (38, Cologne)</option>
            <option value="julia">Julia — Wellness (27, Berlin)</option>
            <option value="generic">Audience large (25-55 DE)</option>
          </select>
        </div>
        <div class="form-group">
          <label>Angle créatif</label>
          <select id="imgad-angle">
            <option value="cortisol">CORTISOL_MÉCANISME — Das 3-Uhr-Signal (-27.9% cortisol)</option>
            <option value="schlaf">SCHLAF_CHRONIQUE — Durchschlafen / Gedankenkarussell</option>
            <option value="identite">IDENTITE_PRO — High Performer / Stille Energie</option>
            <option value="natural">NATURAL_PROOF — Kein Melatonin / 45 études</option>
          </select>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
          <div class="form-group">
            <label>Format</label>
            <select id="imgad-format">
              <option value="story">Story/Reels — 9:16</option>
              <option value="feed">Feed carré — 1:1</option>
              <option value="portrait">Feed portrait — 4:5</option>
              <option value="banner">Bannière — 16:9</option>
            </select>
          </div>
          <div class="form-group">
            <label>Style visuel</label>
            <select id="imgad-style">
              <option value="ugc">UGC Authentique</option>
              <option value="lifestyle">Lifestyle Premium</option>
              <option value="product">Product Hero</option>
              <option value="scientific">Scientifique</option>
            </select>
          </div>
        </div>
        <div class="form-group">
          <label>Hook overlay DE <span style="font-weight:400;color:var(--text2)">(optionnel)</span></label>
          <input type="text" id="imgad-hook" placeholder="Wachst du nachts um 3 auf? Dein Cortisol..." style="width:100%">
        </div>
        <button onclick="generateImageAdPrompt()" class="btn btn-primary" style="width:100%;margin-top:4px">🪄 Générer le prompt Midjourney</button>
      </div>
      <div class="card" style="margin-top:0">
        <div class="card-title" style="font-size:12px">Workflow</div>
        <ol style="font-size:12px;color:var(--text2);padding-left:16px;line-height:1.8">
          <li>Avatar + angle du Batch #1 Marksman</li>
          <li>Format Story 9:16 pour cold audience Meta</li>
          <li>Style UGC = meilleur thumb-stop DE</li>
          <li>Copier → Midjourney v6.1</li>
          <li>Combiner avec scripts UGC S1/S2/S3</li>
        </ol>
      </div>
    </div>
    <div>
      <div class="card" style="min-height:400px;display:flex;flex-direction:column">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px">
          <div class="card-title" style="margin-bottom:0">Prompt généré</div>
          <button id="imgad-copy-btn" onclick="copyImageAdPrompt()" class="btn btn-secondary btn-sm" style="display:none">📋 Copier</button>
        </div>
        <div id="imgad-output" style="flex:1;background:var(--surface2);border-radius:8px;padding:16px;font-size:12px;font-family:monospace;line-height:1.7;color:var(--text2);white-space:pre-wrap;min-height:320px;display:flex;align-items:center;justify-content:center">
          <span style="color:var(--text2);font-size:13px;font-family:inherit">Configure les options et clique sur Générer ↑</span>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="creation-panel" id="cpanel-library" style="display:none">
  <div class="page-header" style="display:flex;align-items:flex-start;justify-content:space-between;gap:16px;flex-wrap:wrap">
    <div>
      <div class="page-title">📁 Historique</div>
      <div class="page-sub">Historique des vidéos UGC générées</div>
    </div>
    <div style="display:flex;gap:8px;align-items:center">
      <button class="btn btn-secondary" onclick="refreshAllStatuses()" id="btnPollStatus">
        <span class="spinner" id="pollSpinner" style="display:none"></span>
        📡 Sync statuts
      </button>
      <button class="btn btn-secondary" onclick="refreshLibrary()">🔄</button>
    </div>
  </div>

  <!-- Stats bar -->
  <div class="lib-stats">
    <div class="lib-stat">
      <div class="lib-stat-val" id="libStatTotal">0</div>
      <div class="lib-stat-label">Vidéos générées</div>
    </div>
    <div class="lib-stat">
      <div class="lib-stat-val" id="libStatDone">0</div>
      <div class="lib-stat-label">Prêtes</div>
    </div>
    <div class="lib-stat">
      <div class="lib-stat-val" id="libStatProcessing">0</div>
      <div class="lib-stat-label">En cours</div>
    </div>
    <div class="lib-stat">
      <div class="lib-stat-val" id="libStatCredits">—</div>
      <div class="lib-stat-label">Crédits restants</div>
    </div>
  </div>

  <!-- Filters -->
  <div class="lib-filters">
    <select id="libFilterBatch" onchange="refreshLibrary()">
      <option value="">Tous les batches</option>
      <option value="batch1">Batch #1 — Cortisol-Wecker</option>
      <option value="batch2">Batch #2 — Nicht mehr ich selbst</option>
      <option value="batch3">Batch #3 — Cortisol-Körper</option>
      <option value="batch4">Batch #4 — Alles versucht</option>
    </select>
    <select id="libFilterStatus" onchange="refreshLibrary()">
      <option value="">Tous les statuts</option>
      <option value="done">✅ Prêtes</option>
      <option value="processing">⏳ En cours</option>
    </select>
    <span style="color:var(--text2);font-size:13px;margin-left:auto">
      <span id="libCount">0</span> vidéo(s)
    </span>
  </div>

  <div id="libGrid" class="video-grid"></div>
  <div id="libEmpty" style="display:none;text-align:center;padding:80px 40px;color:var(--text2)">
    <div style="font-size:48px;margin-bottom:16px">🎬</div>
    <div style="font-size:16px;font-weight:600;color:var(--text);margin-bottom:8px">Aucune vidéo générée</div>
    <div style="font-size:13px">Lance Batch Generator → Batch #1 pour créer tes premières vidéos UGC</div>
  </div>
</div>
<div class="creation-panel" id="cpanel-hookbank" style="display:none">
  <div class="page-header">
    <div class="page-title">🔑 Hook Bank</div>
    <div class="page-sub">75 hooks testables — filtrés par angle, avatar, format</div>
  </div>
  <div style="display:flex;gap:12px;margin-bottom:20px;flex-wrap:wrap;align-items:center">
    <select id="hbAngle" onchange="filterHooks()" style="width:auto">
      <option value="">Tous les angles</option>
      <option value="sommeil">😴 Sommeil / Réveil</option>
      <option value="identite">🧠 Identité perdue</option>
      <option value="corps">💪 Corps / Stressbauch</option>
      <option value="science">🔬 Science / KSM-66</option>
      <option value="frustration">😤 Frustration / Alles versucht</option>
    </select>
    <select id="hbAvatar" onchange="filterHooks()" style="width:auto">
      <option value="">Tous les avatars</option>
      <option value="SA-02">SA-02 Insomnaque</option>
      <option value="SA-01">SA-01 Mère</option>
      <option value="SA-04">SA-04 Manager</option>
      <option value="SA-09">SA-09 Papa</option>
      <option value="SA-03">SA-03 Sportive</option>
      <option value="SA-14">SA-14 Wieder ich</option>
      <option value="SA-08">SA-08 Biohacker</option>
      <option value="SA-11">SA-11 Anti-SSRI</option>
      <option value="SA-07">SA-07 Sceptique</option>
    </select>
    <select id="hbType" onchange="filterHooks()" style="width:auto">
      <option value="">Tous les types</option>
      <option value="stat">📊 Stat</option>
      <option value="story">📖 Story</option>
      <option value="question">❓ Question</option>
      <option value="proclamation">📢 Proclamation</option>
      <option value="reframe">🔄 Reframe</option>
    </select>
    <span id="hbCount" style="color:var(--text2);font-size:13px">— hooks</span>
  </div>
  <div id="hookGrid" style="display:flex;flex-direction:column;gap:8px"></div>

  <div class="card" style="margin-top:24px">
    <div class="card-title">✨ Générer des variations d'un hook</div>
    <div class="form-group">
      <label>Hook à varier</label>
      <input type="text" id="hbVarHook" placeholder="Coller un hook ou cliquer sur un hook ci-dessus">
    </div>
    <div style="padding:8px 12px;background:rgba(78,205,196,0.1);border:1px solid rgba(78,205,196,0.3);border-radius:6px;font-size:12px;color:#4ECDC4;margin-bottom:8px">✅ Claude OAuth actif — aucune clé requise</div>
    <button class="btn btn-primary" onclick="generateHookVariations()">✨ Générer 8 variations</button>
    <div id="hbVariations" style="margin-top:16px"></div>
  </div>
</div>
<div class="creation-panel" id="cpanel-batchgen" style="display:none">
  <div class="page-header">
    <div class="page-title">⚡ Batch Generator</div>
    <div class="page-sub">Générer tous les créatives d'un batch Marksman en 1 clic</div>
  </div>

  <div class="alert alert-info" style="margin-bottom:20px">
    💰 Batch complet (3 UGC) = 3 × 40 crédits = <strong>120 crédits ($0.60)</strong> | Solde : <span id="batchCredits">—</span> crédits
  </div>

  <div class="grid-2">
    <div>
      <div class="card">
        <div class="card-title">Sélectionner le batch</div>
        <div style="display:flex;flex-direction:column;gap:10px">
          <div class="script-item" id="bsel-batch1" onclick="selectBatch('batch1')" style="border:1px solid var(--accent);background:rgba(108,99,255,0.1)">
            <div class="script-title">⚡ Batch #1 — Der Cortisol-Wecker</div>
            <div class="script-hook">SA-02 · SA-01 · SA-04 | €50/j test</div>
          </div>
          <div class="script-item" id="bsel-batch2" onclick="selectBatch('batch2')">
            <div class="script-title">Batch #2 — Ich bin nicht mehr ich selbst</div>
            <div class="script-hook">SA-14 · SA-01 · SA-09</div>
          </div>
          <div class="script-item" id="bsel-batch3" onclick="selectBatch('batch3')">
            <div class="script-title">Batch #3 — Cortisol-Körper Sichtbar</div>
            <div class="script-hook">SA-05 · SA-03 · SA-15</div>
          </div>
          <div class="script-item" id="bsel-batch4" onclick="selectBatch('batch4')">
            <div class="script-title">Batch #4 — Alles versucht</div>
            <div class="script-hook">SA-07 · SA-11 · SA-08</div>
          </div>
        </div>
      </div>

      <div class="card">
        <div class="card-title">Options</div>
        <div class="form-group">
          <label>Personnage Sora (character_id)</label>
          <select id="batchCharacter">
            <option value="">Aucun — prompt générique</option>
          </select>
        </div>
        <div class="form-group">
          <div style="padding:8px 12px;background:rgba(78,205,196,0.1);border:1px solid rgba(78,205,196,0.3);border-radius:6px;font-size:12px;color:var(--mint)">
            ✅ Claude OAuth actif — aucune clé requise
          </div>
        </div>
        <button class="btn btn-primary" onclick="launchBatch()" id="btnBatch" style="width:100%">
          ⚡ Lancer le batch sélectionné
        </button>
      </div>
    </div>

    <div>
      <div class="card">
        <div class="card-title">Batch Jobs en cours</div>
        <div id="batchJobs" style="font-size:13px;color:var(--text2)">Aucun batch lancé...</div>
        <button class="btn btn-secondary" style="margin-top:12px;font-size:12px" onclick="refreshBatchJobs()">🔄 Rafraîchir</button>
      </div>
      <div class="card">
        <div class="card-title">📋 Récap batch sélectionné</div>
        <div id="batchPreview" style="font-size:13px;color:var(--text2)">
          Sélectionne un batch pour voir le détail
        </div>
      </div>
    </div>
  </div>

  <div style="margin-top:16px; padding-top:16px; border-top:1px solid var(--border)">
    <label style="display:flex;align-items:center;gap:8px;cursor:pointer;color:var(--text)">
      <input type="checkbox" id="batchMultiSceneMode" onchange="toggleBatchMultiSceneMode()">
      <span>Mode Multi-Scènes (4 scènes × 15s par concept)</span>
    </label>
    <div id="batchMultiSceneOptions" style="display:none;margin-top:12px">
      <label style="color:var(--text2)">Template de scènes :</label>
      <select id="batchTemplateSelect" style="margin-left:8px;width:auto">
        <option value="ugc-classic">UGC Classic</option>
        <option value="testimonial">Témoignage</option>
        <option value="demo">Demo Produit</option>
        <option value="vsl-court">VSL Court</option>
      </select>
    </div>
  </div>
</div>
</div>
    <div id="agents-creation-list"></div>
  </div>

  <!-- ── Execution Layer ── -->
  <div class="agents-layer-pane" id="aglayer-execution">
    <!-- Cross-nav -->
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;padding:10px 14px;background:rgba(108,99,255,0.06);border:1px solid rgba(108,99,255,0.15);border-radius:10px">
      <button onclick="showAgentsLayer('creation')" class="btn btn-sm btn-secondary">← ✨ Création</button>
      <div style="font-size:12px;color:var(--text2)">⚙️ <strong style="color:var(--text)">Execution</strong> · Meta Ads · CBO · 3-2-2 · règles auto</div>
      <button onclick="showAgentsLayer('optimization')" class="btn btn-sm btn-primary">📊 Optimization →</button>
    </div>
    <div class="alert alert-info" style="margin-bottom:20px">
      ⚙️ <strong>Execution Layer</strong> — Déploie les créatifs sur Meta Ads avec la méthode <strong>3-2-2</strong> (3 créatifs × 2 body copies × 2 headlines = 12 ads / ABO). Gère budget et créateurs UGC.
    </div>
    <div id="agents-execution-list"></div>
  </div>

  <!-- ── Optimization Layer ── -->
  <div class="agents-layer-pane" id="aglayer-optimization">
    <!-- Cross-nav -->
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;padding:10px 14px;background:rgba(108,99,255,0.06);border:1px solid rgba(108,99,255,0.15);border-radius:10px">
      <button onclick="showAgentsLayer('execution')" class="btn btn-sm btn-secondary">← ⚙️ Execution</button>
      <div style="font-size:12px;color:var(--text2)">📊 <strong style="color:var(--text)">Optimization</strong> · winners · scale · itérations · learnings</div>
      <button onclick="showAgentsLayer('research')" class="btn btn-sm btn-primary" style="background:rgba(78,205,196,0.15);border-color:rgba(78,205,196,0.4);color:var(--accent3)">🔄 Relancer Research →</button>
    </div>
    <div class="alert alert-info" style="margin-bottom:20px">
      📊 <strong>Optimization Layer</strong> — Analyse les performances post-lancement à 72h, itère sur les winners et scale les campagnes rentables vers le Sniper mode.
    </div>
    <div id="agents-optimization-list"></div>
  </div>

  <!-- IMAGE AD moved to Studio Clip sub-tab -->
  <div class="agents-layer-pane" id="aglayer-imagead" style="display:none!important">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px">

      <!-- Config -->
      <div>
        <div class="card">
          <div class="card-title">🖼️ Générateur Image Ad — Meta DE</div>
          <p style="font-size:12px;color:var(--text2);margin-bottom:16px">Prompts Midjourney optimisés Meta Ads · Avatars V2 · Angles EVOLVE Batch #1</p>

          <div class="form-group">
            <label>Avatar cible</label>
            <select id="imgad-avatar">
              <option value="sonja">Sonja — Berufsstress (32, Munich)</option>
              <option value="markus">Markus — Père épuisé (38, Cologne)</option>
              <option value="julia">Julia — Wellness (27, Berlin)</option>
              <option value="generic">Audience large (25-55 DE)</option>
            </select>
          </div>

          <div class="form-group">
            <label>Angle créatif</label>
            <select id="imgad-angle">
              <option value="cortisol">CORTISOL_MÉCANISME — Das 3-Uhr-Signal (-27.9% cortisol)</option>
              <option value="schlaf">SCHLAF_CHRONIQUE — Durchschlafen / Gedankenkarussell</option>
              <option value="identite">IDENTITE_PRO — High Performer / Stille Energie</option>
              <option value="natural">NATURAL_PROOF — Kein Melatonin / 45 études</option>
            </select>
          </div>

          <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
            <div class="form-group">
              <label>Format</label>
              <select id="imgad-format">
                <option value="story">Story/Reels — 9:16</option>
                <option value="feed">Feed carré — 1:1</option>
                <option value="portrait">Feed portrait — 4:5</option>
                <option value="banner">Bannière — 16:9</option>
              </select>
            </div>
            <div class="form-group">
              <label>Style visuel</label>
              <select id="imgad-style">
                <option value="ugc">UGC Authentique</option>
                <option value="lifestyle">Lifestyle Premium</option>
                <option value="product">Product Hero</option>
                <option value="scientific">Scientifique</option>
              </select>
            </div>
          </div>

          <div class="form-group">
            <label>Hook overlay DE <span style="font-weight:400;color:var(--text2)">(optionnel)</span></label>
            <input type="text" id="imgad-hook" placeholder="Wachst du nachts um 3 auf? Dein Cortisol spricht..." style="width:100%">
          </div>

          <button onclick="generateImageAdPrompt()" class="btn btn-primary" style="width:100%;margin-top:4px">
            🪄 Générer le prompt Midjourney
          </button>
        </div>

        <!-- Tips -->
        <div class="card" style="margin-top:0">
          <div class="card-title" style="font-size:12px">Workflow recommandé</div>
          <ol style="font-size:12px;color:var(--text2);padding-left:16px;line-height:1.8">
            <li>Avatar + angle du Batch #1 Marksman</li>
            <li>Format Story 9:16 pour cold audience</li>
            <li>Style UGC = meilleur thumb-stop DE</li>
            <li>Copier → Midjourney v6.1</li>
            <li>Combiner avec scripts UGC S1/S2/S3</li>
          </ol>
        </div>
      </div>

      <!-- Output -->
      <div>
        <div class="card" style="min-height:400px;display:flex;flex-direction:column">
          <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px">
            <div class="card-title" style="margin-bottom:0">Prompt généré</div>
            <button id="imgad-copy-btn" onclick="copyImageAdPrompt()" class="btn btn-secondary btn-sm" style="display:none">📋 Copier</button>
          </div>
          <div id="imgad-output" style="flex:1;background:var(--surface2);border-radius:8px;padding:16px;font-size:12px;font-family:monospace;line-height:1.7;color:var(--text2);white-space:pre-wrap;min-height:320px;display:flex;align-items:center;justify-content:center">
            <span style="color:var(--text2);font-size:13px;font-family:inherit">Configure les options et clique sur Générer ↑</span>
          </div>
        </div>
      </div>
    </div>
  </div><!-- /aglayer-imagead -->

</div><!-- /page-agents -->

<!-- ═══════════════════════════════════════════════════════════
     🏭 CREATIVE FACTORY PAGE
════════════════════════════════════════════════════════════ -->
<div id="page-factory" class="page" style="display:none!important"><!-- LEGACY: contenu migré dans Studio Clip onglets Pipeline/Cloner/Automation -->
  <div style="padding:24px">

    <!-- Header -->
    <div style="margin-bottom:28px">
      <h1 style="font-size:24px;font-weight:700;margin:0 0 6px">🏭 Creative Factory</h1>
      <p style="color:var(--text2);font-size:14px;margin:0">Usine automatisée d'ads vidéos & images — Pipeline non-stop Nellio UltraCalm</p>
    </div>

    <!-- Tabs internes -->
    <div class="studio-tabs" style="margin-bottom:24px">
      <button class="studio-tab active" onclick="showFactoryTab('ugc')" id="ftab-ugc">🎬 UGC Pipeline</button>
      <button class="studio-tab" onclick="showFactoryTab('cloner')" id="ftab-cloner">🔄 Video Cloner</button>
      <button class="studio-tab" onclick="showFactoryTab('images')" id="ftab-images">🖼️ Image Factory</button>
      <button class="studio-tab" onclick="showFactoryTab('automation')" id="ftab-automation">⚡ Automation</button>
    </div>

    <!-- ─── Tab UGC Pipeline ──────────────────────────────── -->
    <div id="ftab-ugc-content" class="factory-tab-content">
      <div class="card" style="margin-bottom:20px">
        <h3 style="margin:0 0 8px;font-size:16px">🎬 UGC Auto-Pipeline — 3 Vidéos DE</h3>
        <p style="color:var(--text2);font-size:13px;margin:0 0 16px">Génère automatiquement les 3 scripts UGC (Teufelskreis / Gedankenkarussell / Cortisol) via HeyGen avec sélection d'avatar photo-réaliste.</p>
        <div style="display:flex;gap:10px;align-items:center;margin-bottom:16px">
          <button class="btn-primary" onclick="startUGCPipeline()" id="btn-ugc-start" style="background:var(--accent);color:#fff;border:none;padding:10px 20px;border-radius:8px;cursor:pointer;font-weight:600">
            🚀 Lancer les 3 vidéos
          </button>
          <button onclick="startUGCWebUI()" id="btn-ugc-webui" style="background:rgba(74,222,128,0.1);color:#4ade80;border:1px solid rgba(74,222,128,0.3);padding:10px 16px;border-radius:8px;cursor:pointer;font-size:13px;font-weight:600">
            🌐 Via Web UI
          </button>
          <button onclick="refreshUGCStatus()" style="background:var(--surface2);color:var(--text);border:1px solid var(--border);padding:10px 16px;border-radius:8px;cursor:pointer;font-size:13px">
            🔄 Rafraîchir
          </button>
          <span id="ugc-status-badge" style="font-size:12px;color:var(--text2)">Prêt</span>
        </div>

        <!-- Progress cards par script -->
        <div id="ugc-jobs-grid" style="display:grid;grid-template-columns:repeat(3,1fr);gap:14px">
          <div class="ugc-job-card" id="ugc-job-s1" style="background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:14px">
            <div style="font-size:12px;color:var(--text2);margin-bottom:6px">Script 1</div>
            <div style="font-weight:600;font-size:14px;margin-bottom:8px">Der Teufelskreis</div>
            <div style="font-size:11px;color:#a0a0a0;margin-bottom:10px;line-height:1.4">"Du schläfst schlecht WEIL du gestresst bist..."</div>
            <div class="job-status" style="display:inline-block;padding:3px 10px;border-radius:20px;font-size:11px;background:rgba(255,255,255,0.06);color:var(--text2)">⏳ En attente</div>
          </div>
          <div class="ugc-job-card" id="ugc-job-s2" style="background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:14px">
            <div style="font-size:12px;color:var(--text2);margin-bottom:6px">Script 2</div>
            <div style="font-weight:600;font-size:14px;margin-bottom:8px">Das Gedankenkarussell</div>
            <div style="font-size:11px;color:#a0a0a0;margin-bottom:10px;line-height:1.4">"Das Gedankenkarussell nachts — kein Willensproblem..."</div>
            <div class="job-status" style="display:inline-block;padding:3px 10px;border-radius:20px;font-size:11px;background:rgba(255,255,255,0.06);color:var(--text2)">⏳ En attente</div>
          </div>
          <div class="ugc-job-card" id="ugc-job-s3" style="background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:14px">
            <div style="font-size:12px;color:var(--text2);margin-bottom:6px">Script 3</div>
            <div style="font-weight:600;font-size:14px;margin-bottom:8px">Cortisol nachts</div>
            <div style="font-size:11px;color:#a0a0a0;margin-bottom:10px;line-height:1.4">"Dein Cortisol ist nachts noch aktiv..."</div>
            <div class="job-status" style="display:inline-block;padding:3px 10px;border-radius:20px;font-size:11px;background:rgba(255,255,255,0.06);color:var(--text2)">⏳ En attente</div>
          </div>
        </div>
      </div>

      <!-- Vidéos complétées -->
      <div class="card">
        <h3 style="margin:0 0 14px;font-size:15px">✅ Vidéos Générées</h3>
        <div id="ugc-results-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:14px">
          <div style="color:var(--text2);font-size:13px;grid-column:1/-1">Aucune vidéo générée pour l'instant.</div>
        </div>
      </div>
    </div>

    <!-- ─── Tab Video Cloner ───────────────────────────────── -->
    <div id="ftab-cloner-content" class="factory-tab-content" style="display:none">
      <div class="card" style="margin-bottom:20px">
        <h3 style="margin:0 0 8px;font-size:16px">🔄 Video Cloner — Reproduire une vidéo concurrente</h3>
        <p style="color:var(--text2);font-size:13px;margin:0 0 18px">Analyse la structure d'une vidéo concurrente et génère une version Nellio avec la même architecture.</p>

        <div style="margin-bottom:14px">
          <label style="display:block;font-size:12px;color:var(--text2);margin-bottom:6px">URL de la vidéo (YouTube, etc.)</label>
          <input type="text" id="cloner-url" placeholder="https://youtube.com/watch?v=..." style="width:100%;background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:10px 12px;color:var(--text);font-size:13px;box-sizing:border-box">
        </div>
        <div style="margin-bottom:14px">
          <label style="display:block;font-size:12px;color:var(--text2);margin-bottom:6px">— ou — Colle le transcript directement</label>
          <textarea id="cloner-transcript" rows="5" placeholder="Colle ici le texte/transcript de la vidéo concurrente..." style="width:100%;background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:10px 12px;color:var(--text);font-size:13px;resize:vertical;box-sizing:border-box"></textarea>
        </div>
        <div style="display:flex;gap:10px;align-items:center;margin-bottom:16px">
          <button onclick="analyzeVideo()" style="background:var(--accent);color:#fff;border:none;padding:10px 20px;border-radius:8px;cursor:pointer;font-weight:600">🔍 Analyser</button>
          <span id="cloner-status" style="font-size:13px;color:var(--text2)"></span>
        </div>

        <!-- Résultat analyse -->
        <div id="cloner-analysis-result" style="display:none;background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:16px;margin-bottom:16px">
          <h4 style="margin:0 0 12px;font-size:14px;color:var(--accent)">Structure détectée</h4>
          <pre id="cloner-analysis-pre" style="font-size:12px;color:var(--text2);white-space:pre-wrap;margin:0;max-height:300px;overflow-y:auto"></pre>
        </div>

        <!-- Génération clone -->
        <div id="cloner-generate-section" style="display:none">
          <div style="display:flex;gap:10px;align-items:center;margin-bottom:14px">
            <label style="font-size:13px">Avatar:</label>
            <select id="cloner-gender" style="background:var(--surface);border:1px solid var(--border);border-radius:6px;padding:8px 12px;color:var(--text)">
              <option value="female">Femme (Sonja)</option>
              <option value="male">Homme (Markus)</option>
            </select>
            <button onclick="generateClone()" style="background:#4ECDC4;color:#0d0d1a;border:none;padding:10px 20px;border-radius:8px;cursor:pointer;font-weight:700">🎬 Cloner pour Nellio</button>
          </div>
          <div id="cloner-script-result" style="display:none;background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:16px">
            <h4 style="margin:0 0 10px;font-size:14px">Script DE Généré</h4>
            <pre id="cloner-script-pre" style="font-size:13px;white-space:pre-wrap;margin:0 0 12px;line-height:1.6"></pre>
            <div id="cloner-video-result" style="display:none">
              <div style="font-size:12px;color:var(--text2);margin-bottom:6px">Génération vidéo en cours... (2-5 min)</div>
              <div id="cloner-job-id" style="font-size:11px;color:#6c63ff"></div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ─── Tab Image Factory ──────────────────────────────── -->
    <div id="ftab-images-content" class="factory-tab-content" style="display:none">
      <div class="card" style="margin-bottom:20px">
        <h3 style="margin:0 0 8px;font-size:16px">🖼️ Image Ad Factory — Prompts Midjourney</h3>
        <p style="color:var(--text2);font-size:13px;margin:0 0 18px">Génère les prompts Midjourney optimisés pour tes static ads Meta — 3 angles × 2 formats × 2 variantes = 12 assets.</p>

        <div style="display:flex;gap:12px;align-items:flex-end;flex-wrap:wrap;margin-bottom:16px">
          <div>
            <label style="display:block;font-size:12px;color:var(--text2);margin-bottom:6px">Angle</label>
            <select id="img-angle" style="background:var(--surface);border:1px solid var(--border);border-radius:6px;padding:8px 12px;color:var(--text)">
              <option value="teufelskreis">Der Teufelskreis</option>
              <option value="gedankenkarussell">Das Gedankenkarussell</option>
              <option value="cortisol">Cortisol nachts</option>
            </select>
          </div>
          <div>
            <label style="display:block;font-size:12px;color:var(--text2);margin-bottom:6px">Format</label>
            <select id="img-format" style="background:var(--surface);border:1px solid var(--border);border-radius:6px;padding:8px 12px;color:var(--text)">
              <option value="4:5">4:5 — Portrait Feed (optimal)</option>
              <option value="1:1">1:1 — Carré</option>
              <option value="9:16">9:16 — Story/Reel</option>
            </select>
          </div>
          <div>
            <label style="display:block;font-size:12px;color:var(--text2);margin-bottom:6px">Variante</label>
            <select id="img-variant" style="background:var(--surface);border:1px solid var(--border);border-radius:6px;padding:8px 12px;color:var(--text)">
              <option value="1">Variante 1</option>
              <option value="2">Variante 2</option>
            </select>
          </div>
          <button onclick="generateImagePrompt()" style="background:var(--accent);color:#fff;border:none;padding:10px 20px;border-radius:8px;cursor:pointer;font-weight:600;height:38px">Générer prompt</button>
        </div>

        <div id="img-result" style="display:none;background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:16px;margin-bottom:16px">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px">
            <h4 style="margin:0;font-size:14px;color:var(--accent)">Prompt Midjourney</h4>
            <button onclick="copyToClipboard('img-prompt-text')" style="background:rgba(255,255,255,0.08);border:none;color:var(--text);padding:5px 12px;border-radius:6px;cursor:pointer;font-size:12px">📋 Copier</button>
          </div>
          <div id="img-prompt-text" style="font-size:13px;line-height:1.6;margin-bottom:12px;font-family:monospace;color:#c8f5e0;background:rgba(0,0,0,0.2);padding:12px;border-radius:6px;white-space:pre-wrap"></div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
            <div><div style="font-size:11px;color:var(--text2);margin-bottom:4px">Hook DE</div><div id="img-hook" style="font-size:13px;font-weight:600"></div></div>
            <div><div style="font-size:11px;color:var(--text2);margin-bottom:4px">CTA DE</div><div id="img-cta" style="font-size:13px"></div></div>
          </div>
        </div>

        <button onclick="generateImageBatch()" id="btn-batch" style="background:rgba(255,107,107,0.15);border:1px solid rgba(255,107,107,0.4);color:#FF6B6B;padding:12px 24px;border-radius:8px;cursor:pointer;font-weight:700;font-size:14px;width:100%">
