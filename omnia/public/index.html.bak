<!-- ═══ LIGHTBOX ═══ -->
<div id="lightbox">
  <div class="lb-backdrop" onclick="closeLightbox()"></div>
  <div class="lightbox-inner">
    <button class="lightbox-close" onclick="closeLightbox()">✕</button>
    <div class="lightbox-video-wrap">
      <video id="lightboxVideo" controls preload="auto" playsinline
        onplay="document.getElementById('lbPlayBtn').classList.add('hidden')"
        onpause="document.getElementById('lbPlayBtn').classList.remove('hidden')"
        onended="document.getElementById('lbPlayBtn').classList.remove('hidden')">
      </video>
      <button id="lbPlayBtn" class="lb-play-btn" onclick="lbTogglePlay()">▶</button>
    </div>
    <div class="lightbox-info">
      <div class="lightbox-title" id="lbTitle">—</div>
      <div class="lightbox-meta" id="lbMeta">—</div>
      <div class="lightbox-actions">
        <a id="lbOpenTab" href="#" target="_blank" class="btn btn-success" style="width:100%;justify-content:center;text-decoration:none;font-size:15px;padding:12px">
          ▶ Ouvrir dans un nouvel onglet
        </a>
        <a id="lbDownload" href="#" download target="_blank" class="btn btn-secondary" style="width:100%;justify-content:center;text-decoration:none">
          ⬇️ Télécharger MP4
        </a>
        <button onclick="copyUrl(document.getElementById('lightboxVideo').src)" class="btn btn-secondary" style="width:100%;justify-content:center">
          📋 Copier l'URL
        </button>
      </div>
    </div>
  </div>
</div>

