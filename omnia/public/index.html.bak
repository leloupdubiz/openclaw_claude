<div class="page" id="page-settings">
  <div class="page-header">
    <div class="page-title">⚙️ Settings</div>
    <div class="page-sub">Configuration API et préférences</div>
  </div>

  <div class="card">
    <div class="card-title">Clés API</div>
    <div class="form-group">
      <label>Clé API Anthropic (Claude)</label>
      <input type="password" id="settAnthropicKey" placeholder="sk-ant-..."
        oninput="saveKey('anthropic', this.value)">
      <div style="font-size:11px;color:var(--text2);margin-top:4px">Stockée en localStorage — jamais envoyée à nos serveurs</div>
    </div>
    <div class="form-group">
      <label>Clé API kie.ai (pré-configurée)</label>
      <input type="text" value="788b72e5..." disabled style="opacity:0.5">
      <div style="font-size:11px;color:var(--text2);margin-top:4px">Intégrée côté serveur — 9,810 crédits disponibles</div>
    </div>
  </div>

  <div class="card">
    <div class="card-title">Statut des services</div>
    <div id="settStatus" style="font-size:13px;color:var(--text2)">Vérification...</div>
    <button class="btn btn-secondary" style="margin-top:12px" onclick="checkStatus()">🔍 Vérifier</button>
  </div>
</div>

<!-- ═══════════════════════════════════════════════════════════ -->
<!-- PAGE API DOCS                                               -->
<!-- ═══════════════════════════════════════════════════════════ -->
<div class="page" id="page-apidocs">
  <div class="page-header">
    <div class="page-title">📚 API Docs — Providers</div>
    <div class="page-sub">Référence complète kie.ai · Higgsfield · HeyGen</div>
  </div>

  <!-- Tabs -->
  <div class="tabs" style="margin-bottom:24px">
    <div class="tab active" onclick="switchDocTab('kie')">🔮 kie.ai</div>
    <div class="tab" onclick="switchDocTab('higgsfield')">⚡ Higgsfield</div>
    <div class="tab" onclick="switchDocTab('heygen')">🎭 HeyGen</div>
  </div>

  <!-- ───── KIE.AI ───── -->
  <div class="tab-pane active" id="doctab-kie">

    <div class="card">
      <div class="card-title">🔮 kie.ai — Vue d'ensemble</div>
      <div style="font-size:13px;color:var(--text2);line-height:1.7">
        <p>Plateforme unifiée donnant accès à +100 modèles IA (image, vidéo, audio) via un seul endpoint. Rétention fichiers : <strong>14 jours</strong>. Max 20 req/10s.</p>
        <table style="width:100%;border-collapse:collapse;margin-top:12px">
          <tr style="border-bottom:1px solid var(--border)"><th style="text-align:left;padding:6px 0;color:var(--text1)">Info</th><th style="text-align:left;padding:6px 0;color:var(--text1)">Valeur</th></tr>
          <tr><td style="padding:5px 0;color:var(--text2)">Base URL</td><td><code>https://api.kie.ai</code></td></tr>
          <tr><td style="padding:5px 0;color:var(--text2)">Auth</td><td><code>Authorization: Bearer {API_KEY}</code></td></tr>
          <tr><td style="padding:5px 0;color:var(--text2)">Créer task</td><td><code>POST /api/v1/jobs/createTask</code></td></tr>
          <tr><td style="padding:5px 0;color:var(--text2)">Statut task</td><td><code>GET /api/v1/jobs/recordInfo?taskId={id}</code></td></tr>
          <tr><td style="padding:5px 0;color:var(--text2)">Crédits</td><td><code>GET /api/v1/account/credits</code></td></tr>
          <tr><td style="padding:5px 0;color:var(--text2)">Rate limit</td><td>20 req / 10 secondes</td></tr>
          <tr><td style="padding:5px 0;color:var(--text2)">Rétention</td><td>14 jours puis expiration</td></tr>
        </table>
      </div>
    </div>

    <div class="card">
      <div class="card-title">📹 Modèles vidéo disponibles</div>
      <div style="font-size:12px;overflow-x:auto">
        <table style="width:100%;border-collapse:collapse">
          <tr style="border-bottom:1px solid var(--border);color:var(--text2);font-size:11px;text-transform:uppercase">
            <th style="padding:6px 8px;text-align:left">Modèle</th>
            <th style="padding:6px 8px;text-align:left">Type</th>
            <th style="padding:6px 8px;text-align:left">Paramètres clés</th>
            <th style="padding:6px 8px;text-align:left">Coût</th>
            <th style="padding:6px 8px;text-align:left">Durée</th>
          </tr>
          <tr style="border-bottom:1px solid rgba(255,255,255,0.04)">
            <td style="padding:8px;color:var(--accent)">sora-2-text-to-video</td>
            <td style="padding:8px">T2V</td>
            <td style="padding:8px;color:var(--text2)">prompt, aspect_ratio (portrait/landscape), n_frames (10/15), remove_watermark</td>
            <td style="padding:8px">~40 cr/clip</td>
            <td style="padding:8px">~10s ou ~15s</td>
          </tr>
          <tr style="border-bottom:1px solid rgba(255,255,255,0.04)">
            <td style="padding:8px;color:var(--accent)">sora-2-pro-text-to-video</td>
            <td style="padding:8px">T2V ⭐</td>
            <td style="padding:8px;color:var(--text2)">+ size (standard/high) — audio + lip-sync garanti</td>
            <td style="padding:8px">~100 cr/clip</td>
            <td style="padding:8px">~10s ou ~15s</td>
          </tr>
          <tr style="border-bottom:1px solid rgba(255,255,255,0.04)">
            <td style="padding:8px;color:var(--accent)">sora-2-image-to-video</td>
            <td style="padding:8px">I2V</td>
            <td style="padding:8px;color:var(--text2)">prompt, image_urls (array), aspect_ratio, n_frames — produit fidèle</td>
            <td style="padding:8px">~40 cr/clip</td>
            <td style="padding:8px">~10s ou ~15s</td>
          </tr>
          <tr style="border-bottom:1px solid rgba(255,255,255,0.04)">
            <td style="padding:8px;color:var(--accent)">sora-2-pro-image-to-video</td>
            <td style="padding:8px">I2V ⭐</td>
            <td style="padding:8px;color:var(--text2)">+ size (high) — HD + audio + produit fidèle</td>
            <td style="padding:8px">~100 cr/clip</td>
            <td style="padding:8px">~10s ou ~15s</td>
          </tr>
          <tr style="border-bottom:1px solid rgba(255,255,255,0.04)">
            <td style="padding:8px;color:var(--accent)">kling/v2-1-pro</td>
            <td style="padding:8px">T2V + I2V</td>
            <td style="padding:8px;color:var(--text2)">prompt, image_url (optionnel), aspect_ratio, duration (5/10), mode (std/pro)</td>
            <td style="padding:8px">40 cr/s</td>
            <td style="padding:8px">5s ou 10s</td>
          </tr>
          <tr>
            <td style="padding:8px;color:var(--accent)">kling/v3-0</td>
            <td style="padding:8px">T2V + I2V</td>
            <td style="padding:8px;color:var(--text2)">Mêmes params que v2.1 — qualité supérieure</td>
            <td style="padding:8px">40 cr/s</td>
            <td style="padding:8px">5s ou 10s</td>
          </tr>
        </table>
      </div>
    </div>

    <div class="card">
      <div class="card-title">📝 Payload exact — Sora 2 T2V</div>
      <div style="font-size:12px;color:var(--text2);margin-bottom:10px">⚠️ <strong>Le prompt doit inclure le script DE comme dialogue</strong> — Sora 2 lit le texte cité pour générer la voix nativement.</div>
      <pre style="background:rgba(0,0,0,0.3);padding:14px;border-radius:6px;font-size:12px;overflow-x:auto;color:#a8d8a8">{
  "model": "sora-2-text-to-video",
  "input": {
    "prompt": "iPhone 15 Pro selfie, woman in kitchen, holds Nellio
               stick-pack, she says: \"Ich hatte ständig Kopfkino...\"",
    "aspect_ratio": "portrait | landscape",
    "n_frames": "10 | 15",        // string obligatoire
    "remove_watermark": true,
    "size": "standard | high"     // Pro seulement
  }
}</pre>
    </div>

    <div class="card">
      <div class="card-title">📝 Payload exact — Sora 2 I2V</div>
      <pre style="background:rgba(0,0,0,0.3);padding:14px;border-radius:6px;font-size:12px;overflow-x:auto;color:#a8d8a8">{
  "model": "sora-2-image-to-video",
  "input": {
    "prompt": "string",
    "image_urls": ["https://..."],  // tableau — URL publique JPEG/PNG/WEBP max 10MB
    "aspect_ratio": "portrait | landscape",
    "n_frames": "10 | 15",
    "remove_watermark": true
  }
}</pre>
    </div>

    <div class="card">
      <div class="card-title">📊 Statut de task — Réponse</div>
      <pre style="background:rgba(0,0,0,0.3);padding:14px;border-radius:6px;font-size:12px;overflow-x:auto;color:#a8d8a8">GET /api/v1/jobs/recordInfo?taskId={id}

{
  "data": {
    "state": "generating | success | failed",
    "progress": 0-100,           // % avancement
    "resultJson": "{\"resultUrls\":[\"https://...\"]}",
    "failCode": null,
    "failMsg": null,
    "createTime": 1234567890000
  }
}</pre>
      <div style="margin-top:10px;font-size:12px;color:var(--text2)">
        <strong style="color:var(--text1)">États :</strong>
        <span style="color:#40c878">generating</span> → en cours ·
        <span style="color:#a8d8a8">success</span> → URL dans resultJson ·
        <span style="color:#ff6b6b">failed</span> → voir failMsg
      </div>
    </div>

    <div class="card">
      <div class="card-title">⚠️ Erreurs fréquentes</div>
      <div style="font-size:13px">
        <div style="padding:8px 0;border-bottom:1px solid var(--border)"><code style="color:#ff6b6b">taskId: null</code> → Payload invalide (champ inconnu ou image_urls vide pour I2V)</div>
        <div style="padding:8px 0;border-bottom:1px solid var(--border)"><code style="color:#ff6b6b">401 Unauthorized</code> → API key incorrecte ou manquante</div>
        <div style="padding:8px 0;border-bottom:1px solid var(--border)"><code style="color:#ff6b6b">n_frames en int</code> → Doit être string : <code>"10"</code> pas <code>10</code></div>
        <div style="padding:8px 0"><code style="color:#ff6b6b">resolution / duration</code> → Paramètres invalides ignorés silencieusement par l'API</div>
      </div>
    </div>

  </div><!-- /doctab-kie -->

  <!-- ───── HIGGSFIELD ───── -->
  <div class="tab-pane" id="doctab-higgsfield">

    <div class="card">
      <div class="card-title">⚡ Higgsfield — Vue d'ensemble</div>
      <div style="font-size:13px;color:var(--text2);line-height:1.7">
        <p>Plateforme de génération vidéo IA avec +100 modèles. Endpoints REST asynchrones. Auth propriétaire : <code>Key key_id:key_secret</code>.</p>
        <table style="width:100%;border-collapse:collapse;margin-top:12px">
          <tr style="border-bottom:1px solid var(--border)"><th style="text-align:left;padding:6px 0;color:var(--text1)">Info</th><th style="text-align:left;padding:6px 0;color:var(--text1)">Valeur</th></tr>
          <tr><td style="padding:5px 0;color:var(--text2)">Base URL</td><td><code>https://api.higgsfield.ai</code></td></tr>
          <tr><td style="padding:5px 0;color:var(--text2)">Auth</td><td><code>Authorization: Key {key_id}:{key_secret}</code> ⚠️ pas Bearer</td></tr>
          <tr><td style="padding:5px 0;color:var(--text2)">Créer génération</td><td><code>POST /v1/generations</code></td></tr>
          <tr><td style="padding:5px 0;color:var(--text2)">Statut</td><td><code>GET /v1/generations/{id}/status</code> ou <code>/requests/{id}/status</code></td></tr>
          <tr><td style="padding:5px 0;color:var(--text2)">Dashboard</td><td><a href="https://cloud.higgsfield.ai" target="_blank" style="color:var(--accent)">cloud.higgsfield.ai</a></td></tr>
        </table>
      </div>
    </div>

    <div class="card">
      <div class="card-title">📹 Modèles vidéo disponibles</div>
      <div style="font-size:12px;overflow-x:auto">
        <table style="width:100%;border-collapse:collapse">
          <tr style="border-bottom:1px solid var(--border);color:var(--text2);font-size:11px;text-transform:uppercase">
            <th style="padding:6px 8px;text-align:left">Modèle</th>
            <th style="padding:6px 8px;text-align:left">Type</th>
            <th style="padding:6px 8px;text-align:left">Spécificité</th>
            <th style="padding:6px 8px;text-align:left">Durée</th>
          </tr>
          <tr style="border-bottom:1px solid rgba(255,255,255,0.04)">
            <td style="padding:8px;color:var(--accent)">higgsfield-ai/soul/standard</td>
            <td style="padding:8px">T2V</td>
            <td style="padding:8px;color:var(--text2)">Vidéo silencieuse · qualité standard</td>
            <td style="padding:8px">5s ou 10s</td>
          </tr>
          <tr style="border-bottom:1px solid rgba(255,255,255,0.04)">
            <td style="padding:8px;color:var(--accent)">higgsfield-ai/soul/preview</td>
            <td style="padding:8px">T2V</td>
            <td style="padding:8px;color:var(--text2)">Vidéo silencieuse · génération rapide</td>
            <td style="padding:8px">5s uniquement</td>
          </tr>
          <tr style="border-bottom:1px solid rgba(255,255,255,0.04)">
            <td style="padding:8px;color:var(--accent)">kling-video/v2.1/pro/image-to-video</td>
            <td style="padding:8px">I2V ⭐</td>
            <td style="padding:8px;color:var(--text2)">Image → vidéo · fidélité produit élevée</td>
            <td style="padding:8px">Variable</td>
          </tr>
          <tr>
            <td style="padding:8px;color:var(--accent)">higgsfield-ai/dop/preview</td>
            <td style="padding:8px">I2V 🎬</td>
            <td style="padding:8px;color:var(--text2)">Style cinématique Director of Photography</td>
            <td style="padding:8px">Variable</td>
          </tr>
        </table>
      </div>
    </div>

    <div class="card">
      <div class="card-title">📝 Payload T2V</div>
      <div style="font-size:12px;color:var(--text2);margin-bottom:10px">⚠️ Higgsfield T2V = vidéo silencieuse. Pour dialogue : utiliser kie.ai Sora 2.</div>
      <pre style="background:rgba(0,0,0,0.3);padding:14px;border-radius:6px;font-size:12px;overflow-x:auto;color:#a8d8a8">POST /v1/generations
Authorization: Key {key_id}:{key_secret}

{
  "model": "higgsfield-ai/soul/standard",
  "prompt": "scene + script DE intégré comme dialogue:
             ...she says: \"[script DE]\"",
  "aspect_ratio": "9:16 | 16:9 | 1:1 | 4:5",
  "duration": 5               // secondes (5 ou 10)
}</pre>
    </div>

    <div class="card">
      <div class="card-title">📝 Payload I2V</div>
      <pre style="background:rgba(0,0,0,0.3);padding:14px;border-radius:6px;font-size:12px;overflow-x:auto;color:#a8d8a8">POST /v1/generations
{
  "model": "kling-video/v2.1/pro/image-to-video",
  "prompt": "string",
  "image_url": "https://...",  // URL publique (pas image_urls tableau)
  "aspect_ratio": "9:16"
}</pre>
    </div>

    <div class="card">
      <div class="card-title">📊 Polling status</div>
      <pre style="background:rgba(0,0,0,0.3);padding:14px;border-radius:6px;font-size:12px;overflow-x:auto;color:#a8d8a8">GET /requests/{id}/status

{
  "status": "pending | processing | completed | failed | nsfw | error",
  "video": {
    "url": "https://..."    // disponible quand completed
  }
}</pre>
    </div>

    <div class="card">
      <div class="card-title">⚠️ Points critiques</div>
      <div style="font-size:13px">
        <div style="padding:8px 0;border-bottom:1px solid var(--border)">🔑 Auth : <strong>Key key_id:key_secret</strong> — pas Bearer Token</div>
        <div style="padding:8px 0;border-bottom:1px solid var(--border)">🔇 T2V = vidéo SILENCIEUSE — pas de TTS natif (contrairement à Sora 2)</div>
        <div style="padding:8px 0;border-bottom:1px solid var(--border)">🖼 I2V : champ <code>image_url</code> (string), pas <code>image_urls</code> (tableau)</div>
        <div style="padding:8px 0">💳 Crédits : à recharger sur cloud.higgsfield.ai avant tout test I2V</div>
      </div>
    </div>

  </div><!-- /doctab-higgsfield -->

  <!-- ───── HEYGEN ───── -->
  <div class="tab-pane" id="doctab-heygen">

    <div class="card">
      <div class="card-title">🎭 HeyGen — Vue d'ensemble</div>
      <div style="font-size:13px;color:var(--text2);line-height:1.7">
        <p>Seul provider avec <strong>avatar parlant + lip-sync natif</strong>. Le script est lu par l'avatar via TTS. Support Avatar III et IV.</p>
        <table style="width:100%;border-collapse:collapse;margin-top:12px">
          <tr style="border-bottom:1px solid var(--border)"><th style="text-align:left;padding:6px 0;color:var(--text1)">Info</th><th style="text-align:left;padding:6px 0;color:var(--text1)">Valeur</th></tr>
          <tr><td style="padding:5px 0;color:var(--text2)">Base URL</td><td><code>https://api.heygen.com</code></td></tr>
          <tr><td style="padding:5px 0;color:var(--text2)">Auth</td><td><code>X-Api-Key: {API_KEY}</code> (header)</td></tr>
          <tr><td style="padding:5px 0;color:var(--text2)">Générer vidéo</td><td><code>POST /v2/video/generate</code></td></tr>
          <tr><td style="padding:5px 0;color:var(--text2)">Statut vidéo</td><td><code>GET /v1/video_status.get?video_id={id}</code></td></tr>
          <tr><td style="padding:5px 0;color:var(--text2)">Liste avatars</td><td><code>GET /v2/avatars</code></td></tr>
          <tr><td style="padding:5px 0;color:var(--text2)">Liste voix</td><td><code>GET /v2/voices</code></td></tr>
          <tr><td style="padding:5px 0;color:var(--text2)">Limite script</td><td>5000 caractères max</td></tr>
          <tr><td style="padding:5px 0;color:var(--text2)">Résolution free</td><td>720p max (plan gratuit)</td></tr>
        </table>
      </div>
    </div>

    <div class="card">
      <div class="card-title">📝 Payload génération vidéo</div>
      <pre style="background:rgba(0,0,0,0.3);padding:14px;border-radius:6px;font-size:12px;overflow-x:auto;color:#a8d8a8">POST /v2/video/generate
X-Api-Key: {API_KEY}

{
  "video_inputs": [{
    "character": {
      "type": "avatar",
      "avatar_id": "AVATAR_ID",
      "avatar_style": "normal"
    },
    "voice": {
      "type": "text",
      "input_text": "Script DE (max 5000 chars)",
      "voice_id": "VOICE_ID",
      "speed": 1.0             // optionnel 0.5-2.0
    },
    "background": {
      "type": "color",         // color | image | video
      "value": "#008000"       // vert = chroma key
    }
  }],
  "dimension": {
    "width": 720,
    "height": 1280             // 9:16 vertical
  },
  "caption": false
}</pre>
    </div>

    <div class="card">
      <div class="card-title">📊 Statut vidéo</div>
      <pre style="background:rgba(0,0,0,0.3);padding:14px;border-radius:6px;font-size:12px;overflow-x:auto;color:#a8d8a8">GET /v1/video_status.get?video_id={id}

{
  "data": {
    "status": "pending | waiting | processing | completed | failed",
    "video_url": "https://...",    // dispo quand completed
    "duration": 12.5,
    "error": null
  }
}</pre>
    </div>

    <div class="card">
      <div class="card-title">🎨 Fonds disponibles</div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;font-size:12px;margin-top:8px">
        <div style="background:rgba(0,0,0,0.2);padding:10px;border-radius:6px">
          <div style="color:var(--text1);font-weight:600;margin-bottom:4px">🎨 Couleur unie</div>
          <code style="color:var(--text2)">type: "color", value: "#HEX"</code><br>
          <span style="color:var(--text2);font-size:11px">Chroma key : #008000 (vert)</span>
        </div>
        <div style="background:rgba(0,0,0,0.2);padding:10px;border-radius:6px">
          <div style="color:var(--text1);font-weight:600;margin-bottom:4px">🖼 Image</div>
          <code style="color:var(--text2)">type: "image", url: "..." | image_asset_id</code><br>
          <span style="color:var(--text2);font-size:11px">Upload via /v1/asset</span>
        </div>
        <div style="background:rgba(0,0,0,0.2);padding:10px;border-radius:6px">
          <div style="color:var(--text1);font-weight:600;margin-bottom:4px">🎬 Vidéo</div>
          <code style="color:var(--text2)">type: "video", url: "..." | video_asset_id</code><br>
          <span style="color:var(--text2);font-size:11px">play_style: fit/freeze/loop/full</span>
        </div>
        <div style="background:rgba(0,0,0,0.2);padding:10px;border-radius:6px">
          <div style="color:var(--text1);font-weight:600;margin-bottom:4px">🟢 Green screen</div>
          <code style="color:var(--text2)">type: "color", value: "#008000"</code><br>
          <span style="color:var(--text2);font-size:11px">Idéal pour post-prod CapCut</span>
        </div>
      </div>
    </div>

    <div class="card">
      <div class="card-title">⭐ Voix NELLO (brand voices)</div>
      <div style="font-size:12px">
        <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;margin-top:8px">
          <div style="background:rgba(108,99,255,0.1);padding:8px;border-radius:6px;border:1px solid rgba(108,99,255,0.3)">
            <div style="color:var(--accent);font-weight:600">NELLO 2</div>
            <code style="font-size:10px;color:var(--text2)">7879068349524adcb...</code>
          </div>
          <div style="background:rgba(108,99,255,0.1);padding:8px;border-radius:6px;border:1px solid rgba(108,99,255,0.3)">
            <div style="color:var(--accent);font-weight:600">NELLO 3</div>
            <code style="font-size:10px;color:var(--text2)">2bd36df41d6447e5a...</code>
          </div>
          <div style="background:rgba(108,99,255,0.1);padding:8px;border-radius:6px;border:1px solid rgba(108,99,255,0.3)">
            <div style="color:var(--accent);font-weight:600">NELLO 5</div>
            <code style="font-size:10px;color:var(--text2)">13e72664c716438f8...</code>
          </div>
        </div>
        <p style="margin-top:10px;color:var(--text2)">Apparaissent en premier (⭐) dans le sélecteur de voix OMNIA.</p>
      </div>
    </div>

    <div class="card">
      <div class="card-title">⚠️ Limites & points critiques</div>
      <div style="font-size:13px">
        <div style="padding:8px 0;border-bottom:1px solid var(--border)">📝 Script max : <strong>5000 chars</strong> — tronquer si dépassé</div>
        <div style="padding:8px 0;border-bottom:1px solid var(--border)">📐 Résolution : 720p max sur plan gratuit · 1080p sur plan payant</div>
        <div style="padding:8px 0;border-bottom:1px solid var(--border)">⏱ Durée : déterminée par la longueur du script (pas de paramètre durée)</div>
        <div style="padding:8px 0;border-bottom:1px solid var(--border)">🔑 Header auth : <code>X-Api-Key</code> (pas Authorization Bearer)</div>
        <div style="padding:8px 0">🎭 Avatars : photo avatar ou digital twin — ID récupéré via <code>GET /v2/avatars</code></div>
      </div>
    </div>

  </div><!-- /doctab-heygen -->

