        <div>✅ <strong>kie.ai</strong> — ${Math.round(credits.credits || 0)} crédits disponibles</div>
        <div>${getKey('anthropic') ? '✅' : '⚠️'} <strong>Anthropic Claude</strong> — ${getKey('anthropic') ? 'Clé configurée' : 'Clé manquante'}</div>
      </div>`;
  } catch(e) {
    el.innerHTML = `<div class="alert alert-error">❌ Erreur: ${e.message}</div>`;
  }
}

// ─── HOOK BANK ──────────────────────────────────────────────
let allHooks = [];
async function loadHookBank() {
  allHooks = await api('/api/hooks');
  filterHooks();
}
function filterHooks() {
  const angle = document.getElementById('hbAngle').value;
  const avatar = document.getElementById('hbAvatar').value;
  const type = document.getElementById('hbType').value;
  let filtered = allHooks.filter(h =>
    (!angle || h.angle === angle) &&
    (!avatar || h.avatar === avatar) &&
    (!type || h.type === type)
  );
  document.getElementById('hbCount').textContent = `${filtered.length} hook(s)`;
  const typeEmoji = { stat:'📊', story:'📖', question:'❓', proclamation:'📢', reframe:'🔄' };
  const angleColor = { sommeil:'#6c63ff', identite:'#ff6b6b', corps:'#4ecdc4', science:'#fbbf24', frustration:'#f97316' };
  document.getElementById('hookGrid').innerHTML = filtered.map(h => `
    <div style="display:flex;align-items:center;gap:12px;padding:12px 16px;background:var(--surface);border:1px solid var(--border);border-left:3px solid ${angleColor[h.angle]||'#888'};border-radius:8px">
      <div style="font-size:18px">${typeEmoji[h.type]||'🔹'}</div>
      <div style="flex:1">
        <div style="font-size:14px;font-weight:500">${h.text}</div>
        <div style="font-size:11px;color:var(--text2);margin-top:3px">${h.avatar} · ${h.type} · ${h.angle}</div>
      </div>
      <button class="btn btn-secondary btn-sm" onclick="copyText('${h.text.replace(/'/g,"\\'").replace(/"/g,'&quot;')}')">📋</button>
      <button class="btn btn-secondary btn-sm" onclick="document.getElementById('hbVarHook').value=this.closest('[style]').querySelector('div:nth-child(2) div').textContent;document.getElementById('hbVarHook').scrollIntoView({behavior:'smooth'})">✨ Varier</button>
    </div>
  `).join('');
}
function copyText(text) { navigator.clipboard.writeText(text); }
async function generateHookVariations() {
  const hook = document.getElementById('hbVarHook').value.trim();
  if (!hook) return alert('Hook requis');
  const div = document.getElementById('hbVariations');
  div.innerHTML = '<div class="alert alert-info">⏳ Génération des variations...</div>';
  const res = await api('/api/hooks/variations', { method:'POST', body:{ hook }});
  if (res.error) { div.innerHTML = `<div class="alert alert-error">❌ ${res.error}</div>`; return; }
  div.innerHTML = `<div class="card"><div class="card-title">8 Variations</div><div class="output-box">${res.variations}</div></div>`;
}

// ─── BATCH GENERATOR ────────────────────────────────────────
let selectedBatch = 'batch1';
const BATCH_PREVIEWS = {
  batch1: '⚡ Batch #1 — Der Cortisol-Wecker\n\n1.A SA-02 — Insomnaque "Nacht #187..."\n1.B SA-01 — Mère "Ich wache um 3 Uhr..."\n1.C SA-04 — Manager "Seit 3 Monaten..."\n\nBudget test : €50/j × 4 jours',
  batch2: 'Batch #2 — Ich bin nicht mehr ich selbst\n\n2.A SA-14 — "Wann bist du wieder du?"\n2.B SA-01 — Milch scene\n2.C SA-09 — Papa explosif',
  batch3: 'Batch #3 — Cortisol-Körper Sichtbar\n\n3.A SA-05 — Static Before/After\n3.B SA-03 — Stressbauch sport\n3.C SA-15 — Périménopause static',
  batch4: 'Batch #4 — Alles versucht\n\n4.A SA-07 — Sceptique DM vs KSM-66\n4.B SA-11 — Anti-SSRI\n4.C SA-08 — Biohacker PMC (ZackD style)'
};
function selectBatch(id) {
  selectedBatch = id;
  document.querySelectorAll('[id^="bsel-"]').forEach(el => { el.classList.remove('selected'); el.style.background=''; el.style.borderColor='transparent'; });
  const el = document.getElementById(`bsel-${id}`);
  if (el) { el.classList.add('selected'); el.style.background='rgba(108,99,255,0.1)'; el.style.borderColor='var(--accent)'; }
  document.getElementById('batchPreview').textContent = BATCH_PREVIEWS[id] || '';
}
async function launchBatch() {
  const character_id = document.getElementById('batchCharacter').value;
  const btn = document.getElementById('btnBatch');
  btn.disabled = true; btn.innerHTML = '<span class="spinner"></span> Lancement...';
  const res = await api('/api/batch/generate', { method:'POST', body:{ batch_id: selectedBatch, character_id: character_id || null }});
  btn.disabled = false; btn.innerHTML = '⚡ Lancer le batch sélectionné';
  if (res.success) {
    document.getElementById('batchJobs').innerHTML = `<div class="alert alert-success">✅ Batch lancé ! Job ID: ${res.job_id} · ${res.total} créatives en génération</div>`;
    setTimeout(() => { refreshBatchJobs(); loadCredits(); }, 5000);
  } else {
    document.getElementById('batchJobs').innerHTML = `<div class="alert alert-error">❌ ${res.error}</div>`;
  }
}
async function refreshBatchJobs() {
  const jobs = await api('/api/batch/jobs');
  if (!jobs.length) { document.getElementById('batchJobs').innerHTML = '<div style="color:var(--text2)">Aucun batch lancé...</div>'; return; }
  document.getElementById('batchJobs').innerHTML = jobs.slice(0,5).map(j => `
    <div style="padding:10px;background:var(--surface2);border-radius:8px;margin-bottom:8px">
      <div style="font-weight:600;font-size:13px">${j.batch_name}</div>
      <div style="font-size:12px;color:var(--text2)">${j.completed}/${j.total} générées · <span class="badge badge-${j.status==='done'?'done':'processing'}">${j.status}</span></div>
    </div>`).join('');
}

// ─── VOICEOVER ──────────────────────────────────────────────
async function generateVoiceover() {
  const text = document.getElementById('voText').value.trim();
  const voice = document.getElementById('voVoice').value;
  if (!text) return alert('Texte requis');
  const btn = document.getElementById('btnVoice');
  btn.disabled = true; btn.innerHTML = '<span class="spinner"></span> Génération...';
  document.getElementById('voStatus').innerHTML = '<div class="alert alert-info">⏳ Envoi à ElevenLabs V2...</div>';
  const res = await api('/api/voiceover/generate', { method:'POST', body:{ text, voice }});
  btn.disabled = false; btn.innerHTML = '🔊 Générer voiceover';
  if (res.code === 200 && res.data?.task_id) {
    const tid = res.data.task_id;
    document.getElementById('voStatus').innerHTML = `<div class="alert alert-info">⏳ Tâche ${tid} — polling...</div>`;
    const iv = setInterval(async () => {
      const r = await api(`/api/voiceover/status/${tid}`);
      if (r.data?.state === 'success') {
        clearInterval(iv);
        document.getElementById('voStatus').innerHTML = '<div class="alert alert-success">✅ Voiceover prêt !</div>';
        refreshVoiceovers();
      } else if (r.data?.state === 'failed') {
        clearInterval(iv);
        document.getElementById('voStatus').innerHTML = `<div class="alert alert-error">❌ Échec</div>`;
      }
    }, 10000);
  } else {
    document.getElementById('voStatus').innerHTML = `<div class="alert alert-error">❌ ${res.msg || 'Erreur'}</div>`;
  }
}
async function refreshVoiceovers() {
  const vos = await api('/api/voiceovers');
  document.getElementById('voLibrary').innerHTML = vos.slice(0,10).map(v => `
    <div style="padding:10px;background:var(--surface2);border-radius:8px;display:flex;align-items:center;gap:10px">
      <span>${v.status==='done'?'✅':'⏳'}</span>
      <div style="flex:1;font-size:12px">${v.text}... · <em>${v.voice}</em></div>
      ${v.result_url ? `<audio controls src="${v.result_url}" style="height:28px;width:120px"></audio>` : ''}
    </div>`).join('') || '<div style="color:var(--text2)">Aucun voiceover...</div>';
}
function loadVoiceScript(key) { const s = SCRIPTS[key]; if (s) document.getElementById('voText').value = s.text; }

// ─── B-ROLL STUDIO ──────────────────────────────────────────
async function loadBrollTemplates() {
  const templates = await api('/api/broll/templates');
  document.getElementById('brollTemplates').innerHTML = templates.map(t => `
    <div class="script-item" onclick="document.getElementById('brName').value='${t.id}';document.getElementById('brPrompt').dataset.template='${t.id}';document.getElementById('brPrompt').value='[Template: ${t.id}]'">
      <div class="script-title">🎥 ${t.id.replace(/_/g,' ')}</div>
      <div class="script-hook">${t.prompt}</div>
    </div>`).join('');
}
async function generateBroll() {
  const name = document.getElementById('brName').value.trim() || 'b-roll';
  const promptEl = document.getElementById('brPrompt');
  const template = promptEl.dataset.template;
  const prompt = (!template || promptEl.value.startsWith('[Template')) ? undefined : promptEl.value.trim();
  const duration = parseInt(document.getElementById('brDuration').value);
  document.getElementById('brStatus').innerHTML = '<div class="alert alert-info">⏳ Génération Kling 3.0...</div>';
  const res = await api('/api/broll/generate', { method:'POST', body:{ prompt, template, duration, name }});
  if (res.code === 200 && res.data?.task_id) {
    const tid = res.data.task_id;
    document.getElementById('brStatus').innerHTML = `<div class="alert alert-success">✅ Tâche créée. Polling 10s...</div>`;
    const iv = setInterval(async () => {
      const r = await api(`/api/broll/status/${tid}`);
      if (r.data?.state === 'success') { clearInterval(iv); document.getElementById('brStatus').innerHTML = '<div class="alert alert-success">✅ B-Roll prêt !</div>'; refreshBrolls(); }
      else if (r.data?.state === 'failed') { clearInterval(iv); document.getElementById('brStatus').innerHTML = `<div class="alert alert-error">❌ Échec</div>`; }
    }, 10000);
  } else {
    document.getElementById('brStatus').innerHTML = `<div class="alert alert-error">❌ ${res.msg}</div>`;
  }
}
async function refreshBrolls() {
  const brolls = await api('/api/brolls');
  document.getElementById('brLibrary').innerHTML = brolls.slice(0,10).map(b => `
    <div style="padding:10px;background:var(--surface2);border-radius:8px;display:flex;gap:10px;align-items:center;margin-bottom:4px">
      <span>${b.status==='done'?'✅':'⏳'}</span>
      <div style="flex:1;font-size:12px;font-weight:600">${b.name}</div>
      ${b.result_url ? `<a href="${b.result_url}" target="_blank" class="btn btn-success btn-sm">▶️</a>` : '<span class="badge badge-processing">processing</span>'}
    </div>`).join('') || '<div style="color:var(--text2)">Aucun b-roll...</div>';
}

// ─── ZACKD CINEMATIC ────────────────────────────────────────
let currentCinematicId = null;
async function generateCinematicScenes() {
  const script = document.getElementById('cinScript').value.trim();
  const angle = document.getElementById('cinAngle').value;
  if (!script) return alert('Script requis');
  const btn = document.getElementById('btnCinScenes');
  btn.disabled = true; btn.innerHTML = '<span class="spinner"></span> Génération scènes Claude...';
  const res = await api('/api/cinematic/generate', { method:'POST', body:{ script, angle }});
  btn.disabled = false; btn.innerHTML = '🎬 Générer les scènes Claude';
  if (res.error) { document.getElementById('cinScenes').innerHTML = `<div class="alert alert-error">❌ ${res.error}</div>`; return; }
  currentCinematicId = res.project_id;
  document.getElementById('cinScenes').innerHTML = res.scenes.map((s,i) => `
    <div style="padding:10px;background:var(--surface2);border-radius:6px;margin-bottom:8px;border-left:3px solid var(--accent)">
      <div style="font-size:11px;font-weight:700;color:var(--accent)">SCÈNE ${i+1} · ${s.subtitle}</div>
      <div style="font-size:12px;margin-top:4px"><strong>🎤</strong> ${s.narration}</div>
      <div style="font-size:11px;color:var(--text2);margin-top:2px"><strong>🎥</strong> ${s.visual_prompt?.slice(0,100)}...</div>
    </div>`).join('');
  document.getElementById('cinProduceBtn').style.display = 'block';
}
async function produceCinematic() {
  if (!currentCinematicId) return;
  const btn = document.getElementById('btnCinProduce');
  btn.disabled = true; btn.innerHTML = '<span class="spinner"></span> Production...';
  const res = await api(`/api/cinematic/produce/${currentCinematicId}`, { method:'POST' });
  btn.disabled = false; btn.innerHTML = '🎬 Lancer la production';
  if (res.error) { document.getElementById('cinStatus').innerHTML = `<div class="alert alert-error">❌ ${res.error}</div>`; return; }
  document.getElementById('cinStatus').innerHTML = `<div class="alert alert-success">✅ ${res.tasks_count} tâches lancées. Attendre 3-5 min.</div>`;
  document.getElementById('cinAssembleBtn').style.display = 'block';
  setTimeout(refreshCinematics, 5000);
}
async function assembleCinematic() {
  document.getElementById('cinStatus').innerHTML = '<div class="alert alert-info">⏳ Assemblage ffmpeg...</div>';
  const res = await api(`/api/cinematic/assemble/${currentCinematicId}`, { method:'POST' });
  if (res.error) { document.getElementById('cinStatus').innerHTML = `<div class="alert alert-error">❌ ${res.error}</div>`; return; }
  document.getElementById('cinResult').innerHTML = `<div class="alert alert-success">✅ Vidéo assemblée !<br><a href="${res.url}" target="_blank" class="btn btn-success" style="margin-top:8px;display:inline-flex">⬇️ Télécharger</a></div>`;
}
async function refreshCinematics() {
  const projects = await api('/api/cinematics');
  document.getElementById('cinProjects').innerHTML = projects.slice(0,5).map(p => `
    <div style="padding:10px;background:var(--surface2);border-radius:8px;margin-bottom:8px;cursor:pointer"
      onclick="currentCinematicId='${p.id}';document.getElementById('cinAssembleBtn').style.display='block'">
      <div style="font-weight:600;font-size:12px">${p.angle} · ${p.scenes?.length||0} scènes · <span class="badge badge-${p.status==='done'?'done':'processing'}">${p.status}</span></div>
      ${p.result_url ? `<a href="${p.result_url}" target="_blank" class="btn btn-success btn-sm" style="margin-top:4px">▶️ Voir</a>` : ''}
    </div>`).join('') || '<div style="color:var(--text2)">Aucun projet...</div>';
}

// ─── SPRINT 2 — MULTI-SCENE FUNCTIONS ───────────────────────

async function loadAvatarsList() {
  // Init cascade Core → Sub-Avatar → Angle
  onCoreAvatarChange();
  try {
    const r = await fetch('/api/avatars/list');
    const avatars = await r.json();
    if (avatars.length) {
      const options = avatars.map(a => `<option value="${a.avatarId}">${a.avatarName}</option>`).join('');
      const sel = document.getElementById('msAvatarSelect');
      if (sel) sel.innerHTML = options;
    }
  } catch(e) { /* ignore */ }
}

function updateSceneCards() {
  const checkedEl = document.querySelector('input[name="msStructure"]:checked');
  const n = parseInt(checkedEl ? checkedEl.value : 4);
  const container = document.getElementById('msSceneCards');
  if (!container) return;
  const sceneTypes = ['Hook', 'Problème', 'Solution', 'Témoignage', 'CTA', 'B-Roll', 'Story', 'Result', 'Agitation', 'Mechanism'];
  container.innerHTML = Array.from({length: n}, (_, i) => `
    <div style="border:1px solid var(--border); border-radius:8px; padding:12px; margin:8px 0; background:var(--surface2)">
      <h4 style="font-size:13px;font-weight:700;color:var(--accent);margin-bottom:8px">Scène ${i+1}</h4>
      <select id="msSceneType_${i}" style="margin-bottom:8px">
        ${sceneTypes.map(t => `<option>${t}</option>`).join('')}
      </select>
      <textarea id="msSceneScript_${i}" placeholder="Script en allemand..." style="width:100%;margin-top:4px;min-height:60px;background:var(--surface);border:1px solid var(--border);border-radius:6px;padding:8px;color:var(--text);font-family:inherit;resize:vertical"></textarea>
      <textarea id="msScenePrompt_${i}" placeholder="Prompt visuel Sora 2..." style="width:100%;margin-top:8px;min-height:60px;background:var(--surface);border:1px solid var(--border);border-radius:6px;padding:8px;color:var(--text);font-family:inherit;resize:vertical"></textarea>
      <button onclick="generateSceneScript(${i})" class="btn btn-secondary" style="margin-top:6px;font-size:12px;padding:5px 12px">✨ Générer script DE</button>
    </div>
  `).join('');
}

async function loadMsTemplate() {
  const templateId = document.getElementById('msTemplateSelect')?.value;
  if (!templateId) return;
  try {
    const r = await fetch('/api/scene-templates');
    const templates = await r.json();
    const t = templates[templateId];
    if (!t) return;
    const radios = document.querySelectorAll('input[name="msStructure"]');
    radios.forEach(radio => { if (parseInt(radio.value) === t.scenes.length) radio.checked = true; });
    updateSceneCards();
    setTimeout(() => {
      t.scenes.forEach((scene, i) => {
        const typeEl = document.getElementById(`msSceneType_${i}`);
        if (typeEl) typeEl.value = scene.type;
        const scriptEl = document.getElementById(`msSceneScript_${i}`);
        if (scriptEl) scriptEl.placeholder = scene.scriptHint;
      });
    }, 100);
  } catch(e) { console.warn('loadMsTemplate:', e); }
}

async function generateSceneScript(sceneIndex) {
  const sceneType = document.getElementById(`msSceneType_${sceneIndex}`)?.value || 'Hook';
  const avatarId = document.getElementById('msAvatarSelect')?.value || '';
  const btn = event?.target;
  if (btn) { btn.disabled = true; btn.textContent = '⏳...'; }
  try {
    const r = await fetch('/api/generate-scene-script', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({ sceneType, scriptHint: '', avatarId })
    });
    const data = await r.json();
    if (data.script) {
      const el = document.getElementById(`msSceneScript_${sceneIndex}`);
      if (el) el.value = data.script;
    }
  } catch(e) { console.warn('generateSceneScript:', e); }
  if (btn) { btn.disabled = false; btn.textContent = '✨ Générer script DE'; }
}

async function generateMultiScene() {
  const avatarId = document.getElementById('msAvatarSelect')?.value;
  const template = document.getElementById('msTemplateSelect')?.value || 'custom';
  const checkedEl = document.querySelector('input[name="msStructure"]:checked');
  const n = parseInt(checkedEl ? checkedEl.value : 4);
  const scenes = Array.from({length: n}, (_, i) => ({
    sceneType: document.getElementById(`msSceneType_${i}`)?.value || 'Hook',
    scriptDE: document.getElementById(`msSceneScript_${i}`)?.value || '',
    visualPrompt: document.getElementById(`msScenePrompt_${i}`)?.value || '',
    duration: 15
  }));

  const progressDiv = document.getElementById('msProgress');
  const progressText = document.getElementById('msProgressText');
  if (progressDiv) progressDiv.style.display = 'block';
  if (progressText) progressText.textContent = 'Démarrage...';

  try {
    const r = await fetch('/api/multiscene/generate', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({ avatarId, template, scenes })
    });
    const data = await r.json();
    if (data.jobId) {
      pollMultiSceneStatus(data.jobId, n);
    } else {
      if (progressText) progressText.textContent = 'Erreur : ' + (data.error || 'Inconnu');
    }
  } catch(e) {
    if (progressText) progressText.textContent = 'Erreur : ' + e.message;
  }
}

async function pollMultiSceneStatus(jobId, totalScenes) {
  try {
    const r = await fetch(`/api/multiscene/status/${jobId}`);
    const job = await r.json();
    const fill = document.getElementById('msProgressFill');
    const text = document.getElementById('msProgressText');
    if (job.status === 'done') {
      if (fill) fill.style.width = '100%';
      if (text) text.textContent = '✅ Vidéo terminée ! Visible dans la Video Library.';
      loadAvatarsList();
      return;
    }
    if (job.status === 'failed') {
      if (text) text.textContent = '❌ Échec : ' + (job.error || 'Inconnu');
      return;
    }
    const pct = Math.round(((job.currentScene || 0) / totalScenes) * 100);
    if (fill) fill.style.width = pct + '%';
    if (text) text.textContent = `Génération scène ${job.currentScene || 0}/${totalScenes}...`;
    setTimeout(() => pollMultiSceneStatus(jobId, totalScenes), 5000);
  } catch(e) {
    setTimeout(() => pollMultiSceneStatus(jobId, totalScenes), 5000);
  }
}

function toggleBatchMultiSceneMode() {
  const checked = document.getElementById('batchMultiSceneMode')?.checked;
  const opts = document.getElementById('batchMultiSceneOptions');
  if (opts) opts.style.display = checked ? 'block' : 'none';
}

