// SPRINT 3 — STUDIO CLIP (GÉNÉRATION SCÈNE PAR SCÈNE)
// ══════════════════════════════════════════════════════════════

// State Sprint 3
let currentVariantJobId = null;
let currentProjectId = null;
let variantPollInterval = null;
const activeJobs = {}; // multi-job: jobId -> { interval, numVariants, format }

// Injecter la description packaging Nellio (stick-pack, PAS canister)
// ── Auto-génération du prompt visuel (Marketing Mania) ────────
let _visualPromptTimer = null;

// ─── PROMPT UGC UNIFIÉ — Marketing Mania ─────────────────────────────────────
// 1 seul appel → Script DE 15s + Prompt visuel Sora 2 intégré
async function generateClipPrompt() {
  const btn      = document.getElementById('btnGenPrompt');
  const label    = document.getElementById('genPromptLabel');
  const statusEl = document.getElementById('genPromptStatus');
  const ta       = document.getElementById('clipVisualPrompt');
  if (!ta) return;

  if (btn) btn.disabled = true;
  if (label) label.textContent = '⏳ Génération...';
  if (statusEl) statusEl.style.display = 'inline';
  ta.style.opacity = '0.4';

  try {
    const avatarId  = document.getElementById('clipAvatarSelect')?.value  || 'A3-e';
    const angle     = document.getElementById('clipAngle')?.value         || 'cortisol';
    const sceneType = document.getElementById('clipSceneType')?.value     || 'Testimonial';
    const format    = document.getElementById('clipFormat')?.value        || '9:16';
    const duration  = document.getElementById('clipDuration')?.value      || '15';
    const provider  = document.getElementById('clipProvider')?.value      || 'kie';
    const model     = document.getElementById('clipModel')?.value         || '';
    const hasImage  = !!(_selectedImageUrl || _selectedImageLocal || _selectedImageBase64);

    const d = await api('/api/generate/clip-prompt', {
      method: 'POST',
      body: { avatarId, angle, sceneType, format, duration, provider, model, hasImage }
    });

    if (d.prompt) {
      ta.value = d.prompt;
      // Stocker scriptDE pour HeyGen TTS
      const scriptInput = document.getElementById('clipScript');
      if (scriptInput) scriptInput.value = d.scriptDE || '';
      // Afficher le script DE généré dans la bulle de lecture
      const frBlock = document.getElementById('clipScriptFR');
      const frText  = document.getElementById('clipScriptFRText');
      if (d.scriptDE && frBlock && frText) {
        frText.textContent = d.scriptDE;
        frBlock.style.display = 'block';
      }
      // Traduire le prompt complet EN→FR pour vérification (async, non bloquant)
      translatePromptToFR(d.prompt);
    }
  } catch(e) {
    console.warn('generateClipPrompt error:', e.message);
    alert('Erreur génération: ' + e.message);
  } finally {
    if (btn) btn.disabled = false;
    if (label) label.textContent = 'Générer';
    if (statusEl) statusEl.style.display = 'none';
    ta.style.opacity = '1';
  }
}

// Callback avatar → clear prompt (nouveau avatar = nouveau contexte)
