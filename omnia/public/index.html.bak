<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>OMNIA — Creative OS</title>
<style>
:root {
  --bg: #0a0a0f;
  --surface: #111118;
  --surface2: #1a1a24;
  --border: #2a2a3a;
  --accent: #6c63ff;
  --accent2: #ff6b6b;
  --accent3: #4ecdc4;
  --text: #e8e8f0;
  --text2: #888899;
  --success: #4ade80;
  --warning: #fbbf24;
  --error: #f87171;
}
* { box-sizing: border-box; margin: 0; padding: 0; }
body {
  font-family: 'SF Pro Display', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  background: var(--bg); color: var(--text); min-height: 100vh;
}

/* ─── SIDEBAR ─── */
.layout { display: flex; min-height: 100vh; }
.sidebar {
  width: 240px; background: var(--surface); border-right: 1px solid var(--border);
  padding: 24px 16px; display: flex; flex-direction: column; gap: 8px;
  position: fixed; height: 100vh; overflow-y: auto;
}
.logo {
  font-size: 20px; font-weight: 700; color: var(--accent);
  letter-spacing: -0.5px; margin-bottom: 24px; padding: 0 8px;
  display: flex; align-items: center; gap: 8px;
}
.logo span { font-size: 13px; color: var(--text2); font-weight: 400; }
.nav-item {
  display: flex; align-items: center; gap: 10px; padding: 10px 12px;
  border-radius: 8px; cursor: pointer; transition: all 0.15s;
  font-size: 14px; color: var(--text2); border: none; background: none;
  width: 100%; text-align: left;
}
.nav-item:hover { background: var(--surface2); color: var(--text); }
.nav-item.active { background: rgba(108,99,255,0.15); color: var(--accent); }
.nav-icon { font-size: 18px; width: 22px; text-align: center; }
.credits-badge {
  margin-top: auto; padding: 12px; background: var(--surface2);
  border-radius: 10px; border: 1px solid var(--border);
  font-size: 12px; color: var(--text2);
}
.credits-num { font-size: 20px; font-weight: 700; color: var(--accent3); }

/* ─── MAIN ─── */
.main { margin-left: 240px; flex: 1; padding: 32px; min-height: 100vh; }
.page.iframe-page { padding: 0; margin: -32px; overflow: hidden; height: 100vh; }
.page { display: none; }
.page.active { display: block; }
.page-header { margin-bottom: 28px; }
.page-title { font-size: 26px; font-weight: 700; margin-bottom: 4px; }
.page-sub { color: var(--text2); font-size: 14px; }

/* ─── CARDS ─── */
.card {
  background: var(--surface); border: 1px solid var(--border);
  border-radius: 12px; padding: 20px; margin-bottom: 16px;
}
.card-title { font-size: 13px; font-weight: 600; color: var(--text2);
  text-transform: uppercase; letter-spacing: 0.8px; margin-bottom: 16px; }

/* ─── FORMS ─── */
label { font-size: 13px; color: var(--text2); display: block; margin-bottom: 6px; }
input, select, textarea {
  width: 100%; background: var(--surface2); border: 1px solid var(--border);
  border-radius: 8px; padding: 10px 12px; color: var(--text); font-size: 14px;
  outline: none; transition: border-color 0.15s; font-family: inherit;
}
input:focus, select:focus, textarea:focus { border-color: var(--accent); }
textarea { resize: vertical; min-height: 120px; }
select option { background: var(--surface2); }
.form-group { margin-bottom: 16px; }

/* ─── BUTTONS ─── */
.btn {
  padding: 10px 20px; border-radius: 8px; border: none; cursor: pointer;
  font-size: 14px; font-weight: 600; transition: all 0.15s; display: inline-flex;
  align-items: center; gap: 8px;
}
.btn-primary { background: var(--accent); color: #fff; }
.btn-primary:hover { background: #5a52d5; transform: translateY(-1px); }
.btn-secondary { background: var(--surface2); color: var(--text); border: 1px solid var(--border); }
.btn-secondary:hover { border-color: var(--accent); }
.btn-danger { background: rgba(248,113,113,0.1); color: var(--error); border: 1px solid rgba(248,113,113,0.3); }
.btn-success { background: rgba(74,222,128,0.1); color: var(--success); border: 1px solid rgba(74,222,128,0.3); }
.btn:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }
.btn-sm { padding: 6px 12px; font-size: 12px; }

/* ─── GRID ─── */
.grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
.grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px; }

/* ─── STATUS BADGES ─── */
.badge {
  display: inline-flex; align-items: center; gap: 4px; padding: 3px 10px;
  border-radius: 20px; font-size: 12px; font-weight: 600;
}
.badge-processing { background: rgba(251,191,36,0.1); color: var(--warning); }
.badge-done { background: rgba(74,222,128,0.1); color: var(--success); }
.badge-error { background: rgba(248,113,113,0.1); color: var(--error); }

/* ─── ALERT / OUTPUT ─── */
.alert {
  padding: 12px 16px; border-radius: 8px; font-size: 13px; margin-bottom: 12px;
}
.alert-info { background: rgba(108,99,255,0.1); border: 1px solid rgba(108,99,255,0.3); color: var(--accent); }
.alert-success { background: rgba(74,222,128,0.1); border: 1px solid rgba(74,222,128,0.3); color: var(--success); }
.alert-error { background: rgba(248,113,113,0.1); border: 1px solid rgba(248,113,113,0.3); color: var(--error); }

.output-box {
  background: var(--surface2); border: 1px solid var(--border); border-radius: 8px;
  padding: 14px; font-size: 13px; line-height: 1.6; white-space: pre-wrap;
  word-break: break-word; max-height: 400px; overflow-y: auto;
  font-family: 'SF Mono', Consolas, monospace;
}

/* ─── CHARACTER CARDS ─── */
.char-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 12px; }
.char-card {
  background: var(--surface2); border: 1px solid var(--border); border-radius: 10px;
  padding: 16px; cursor: pointer; transition: all 0.15s; position: relative;
}
.char-card:hover { border-color: var(--accent); }
.char-card.selected { border-color: var(--accent); background: rgba(108,99,255,0.1); }
.char-avatar { font-size: 36px; margin-bottom: 8px; }
.char-name { font-weight: 600; font-size: 14px; }
.char-id { font-size: 11px; color: var(--text2); margin-top: 4px; font-family: monospace; }
.char-del { position: absolute; top: 8px; right: 8px; font-size: 16px;
  cursor: pointer; color: var(--text2); opacity: 0; transition: opacity 0.15s; }
.char-card:hover .char-del { opacity: 1; }

/* ─── VIDEO LIBRARY ─── */
.lib-stats { display: flex; gap: 16px; margin-bottom: 24px; flex-wrap: wrap; }
.lib-stat {
  background: var(--surface); border: 1px solid var(--border); border-radius: 10px;
  padding: 14px 20px; flex: 1; min-width: 120px;
}
.lib-stat-val { font-size: 24px; font-weight: 700; color: var(--accent3); }
.lib-stat-label { font-size: 11px; color: var(--text2); margin-top: 2px; text-transform: uppercase; letter-spacing: 0.6px; }
.lib-filters { display: flex; gap: 10px; margin-bottom: 20px; flex-wrap: wrap; align-items: center; }
.lib-filters select { width: auto; flex: 0 0 auto; }

.video-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 20px; }
.video-card {
  background: var(--surface); border: 1px solid var(--border); border-radius: 14px;
  overflow: hidden; transition: all 0.2s; cursor: pointer; position: relative;
}
.video-card:hover { border-color: var(--accent); transform: translateY(-3px); box-shadow: 0 12px 40px rgba(108,99,255,0.15); }
.video-card.done { border-color: rgba(74,222,128,0.25); }
.video-card.done:hover { border-color: var(--success); box-shadow: 0 12px 40px rgba(74,222,128,0.12); }

/* 9:16 preview container */
.video-preview-wrap {
  position: relative; aspect-ratio: 9/16; background: #080810;
  overflow: hidden; display: flex; align-items: center; justify-content: center;
}
.video-preview-wrap video {
  width: 100%; height: 100%; object-fit: cover; display: block;
  transition: transform 0.3s;
}
.video-card:hover .video-preview-wrap video { transform: scale(1.02); }

/* Play overlay */
.play-overlay {
  position: absolute; inset: 0; display: flex; align-items: center; justify-content: center;
  background: rgba(0,0,0,0.15); opacity: 0.6; transition: opacity 0.2s; cursor: pointer;
  pointer-events: all;
}
.video-card:hover .play-overlay { opacity: 1; background: rgba(0,0,0,0.3); }
.play-btn-circle {
  width: 52px; height: 52px; border-radius: 50%; background: rgba(255,255,255,0.95);
  display: flex; align-items: center; justify-content: center; font-size: 20px;
  box-shadow: 0 4px 20px rgba(0,0,0,0.4);
  transition: transform 0.15s;
}
.play-btn-circle:hover { transform: scale(1.1); }

/* Processing shimmer */
.video-processing-bg {
  position: absolute; inset: 0;
  background: linear-gradient(135deg, #0d0d1a 0%, #1a1a2e 50%, #0d0d1a 100%);
  background-size: 200% 200%; animation: shimmer 2s ease-in-out infinite;
  display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 12px;
}
@keyframes shimmer { 0%,100% { background-position: 0% 50%; } 50% { background-position: 100% 50%; } }
.processing-pulse {
  width: 48px; height: 48px; border-radius: 50%;
  border: 3px solid rgba(108,99,255,0.3);
  border-top-color: var(--accent);
  animation: spin 1.2s linear infinite;
}
.processing-text { font-size: 11px; color: var(--text2); font-weight: 500; letter-spacing: 0.3px; }
.processing-progress {
  position: absolute; bottom: 0; left: 0; height: 3px;
  background: linear-gradient(90deg, var(--accent), var(--accent3));
  transition: width 1s ease; border-radius: 0;
}

/* Gradient info overlay at bottom */
.video-info-overlay {
  position: absolute; bottom: 0; left: 0; right: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.92) 0%, rgba(0,0,0,0.6) 60%, transparent 100%);
  padding: 32px 12px 12px; pointer-events: none;
}
.video-title-overlay { font-size: 12px; font-weight: 700; color: #fff; margin-bottom: 4px; line-height: 1.3; }
.video-badges { display: flex; gap: 6px; flex-wrap: wrap; }
.vbadge {
  font-size: 10px; font-weight: 600; padding: 2px 7px; border-radius: 20px;
  background: rgba(255,255,255,0.15); color: rgba(255,255,255,0.9);
  backdrop-filter: blur(4px);
}
.vbadge-done { background: rgba(74,222,128,0.3); color: #4ade80; }
.vbadge-processing { background: rgba(251,191,36,0.3); color: #fbbf24; }

/* Actions bar below card */
.video-actions-bar {
  display: flex; gap: 6px; padding: 10px 12px;
  background: var(--surface2); border-top: 1px solid var(--border);
}
.video-actions-bar button, .video-actions-bar a {
  flex: 1; padding: 7px 10px; border-radius: 7px; font-size: 11px; font-weight: 600;
  border: none; cursor: pointer; text-decoration: none; text-align: center;
  display: flex; align-items: center; justify-content: center; gap: 4px;
  transition: all 0.15s;
}
.vact-preview { background: rgba(108,99,255,0.15); color: var(--accent); }
.vact-preview:hover { background: rgba(108,99,255,0.3); }
.vact-download { background: rgba(74,222,128,0.12); color: var(--success); }
.vact-download:hover { background: rgba(74,222,128,0.25); }
.vact-del { background: rgba(248,113,113,0.1); color: var(--error); }
.vact-del:hover { background: rgba(248,113,113,0.2); }

/* ─── LIGHTBOX ─── */
#lightbox {
  display: none; position: fixed; inset: 0; z-index: 9999;
  align-items: center; justify-content: center; pointer-events: none;
}
#lightbox.open { display: flex; }
.lb-backdrop {
  position: fixed; inset: 0; background: rgba(0,0,0,0.93);
  backdrop-filter: blur(12px); pointer-events: all; cursor: pointer; z-index: 0;
}
.lightbox-inner {
  position: relative; max-height: 90vh; max-width: 90vw;
  display: flex; gap: 24px; align-items: flex-start;
  pointer-events: all; z-index: 1;
}
.lightbox-video-wrap {
  flex-shrink: 0; width: min(360px, 44vw); aspect-ratio: 9/16;
  border-radius: 16px; overflow: visible; background: #000;
  box-shadow: 0 24px 80px rgba(0,0,0,0.8); position: relative;
}
.lightbox-video-wrap video {
  width: 100%; height: 100%; object-fit: cover; display: block;
  border-radius: 16px; cursor: pointer; position: relative; z-index: 1;
}
/* Bouton play custom centré sur la vidéo */
.lb-play-btn {
  position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%);
  width: 64px; height: 64px; border-radius: 50%;
  background: rgba(255,255,255,0.92); border: none; cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  font-size: 26px; z-index: 2; transition: transform 0.15s, opacity 0.2s;
  box-shadow: 0 4px 24px rgba(0,0,0,0.5);
}
.lb-play-btn:hover { transform: translate(-50%,-50%) scale(1.1); }
.lb-play-btn.hidden { opacity: 0; pointer-events: none; }
.lightbox-info {
  flex: 1; color: #fff; padding-top: 8px; max-width: 300px;
}
.lightbox-title { font-size: 22px; font-weight: 700; margin-bottom: 8px; }
.lightbox-meta { color: rgba(255,255,255,0.5); font-size: 13px; margin-bottom: 20px; line-height: 1.5; }
.lightbox-actions { display: flex; flex-direction: column; gap: 10px; }
.lightbox-close {
  position: absolute; top: -16px; right: -16px;
  width: 36px; height: 36px; border-radius: 50%; border: none;
  background: rgba(255,255,255,0.15); color: #fff; font-size: 18px; cursor: pointer;
  display: flex; align-items: center; justify-content: center; transition: background 0.15s;
  z-index: 3;
}
.lightbox-close:hover { background: rgba(255,255,255,0.3); }

/* ─── TABS (inside page) ─── */
.tabs { display: flex; gap: 4px; margin-bottom: 20px; background: var(--surface);
  border-radius: 10px; padding: 4px; border: 1px solid var(--border); }
.tab { padding: 8px 16px; border-radius: 7px; cursor: pointer; font-size: 13px;
  font-weight: 600; color: var(--text2); border: none; background: none; transition: all 0.15s; }
.tab.active { background: var(--accent); color: #fff; }
.tab-pane { display: none; }
.tab-pane.active { display: block; }

/* ─── STUDIO SUB-TABS ─── */
.studio-tabs { display: flex; gap: 2px; margin-bottom: 20px; border-bottom: 2px solid var(--border); padding-bottom: 0; }
.studio-tab { padding: 8px 18px; font-size: 13px; font-weight: 600; color: var(--text2);
  border: none; background: none; cursor: pointer; border-bottom: 2px solid transparent;
  margin-bottom: -2px; border-radius: 6px 6px 0 0; transition: all 0.15s; }
.studio-tab:hover { color: var(--text); background: rgba(255,255,255,0.05); }
.studio-tab.active { color: var(--accent); border-bottom-color: var(--accent); background: rgba(108,99,255,0.08); }
.studio-pane { display: none; }
.studio-pane.active { display: block; }

/* ─── LONG FORM SCENE LIST ─── */
.lf-scene-item { background: var(--surface); border: 1px solid var(--border); border-radius: 10px;
  padding: 14px 16px; margin-bottom: 10px; }
.lf-scene-item.lf-done { border-color: rgba(78,205,196,0.5); }
.lf-scene-item.lf-generating { border-color: rgba(108,99,255,0.5); }
.lf-scene-header { display: flex; gap: 10px; align-items: center; }
.lf-scene-num { font-size: 11px; font-weight: 700; color: var(--text2); min-width: 24px; }
.lf-scene-body { margin-top: 10px; font-size: 12px; color: var(--text2); display: none; }
.lf-scene-item.lf-done .lf-scene-body, .lf-scene-item.lf-generating .lf-scene-body { display: block; }

/* ─── PROGRESS ─── */
.progress-bar { height: 4px; background: var(--surface2); border-radius: 2px; overflow: hidden; margin-top: 8px; }
.progress-fill { height: 100%; background: var(--accent); border-radius: 2px; transition: width 0.5s; }

/* ─── LOADING SPINNER ─── */
.spinner { display: inline-block; width: 16px; height: 16px; border: 2px solid rgba(255,255,255,0.3);
  border-top-color: #fff; border-radius: 50%; animation: spin 0.8s linear infinite; }
@keyframes spin { to { transform: rotate(360deg); } }

/* ─── DIVIDER ─── */
.divider { border: none; border-top: 1px solid var(--border); margin: 20px 0; }

/* ─── AGENTS EVOLVE PAGE ─── */
.agents-layer-tabs { display: flex; gap: 4px; margin-bottom: 24px; padding: 5px;
  background: var(--surface); border-radius: 12px; border: 1px solid var(--border); }
.agents-layer-tab { flex: 1; padding: 10px 6px; font-size: 11px; font-weight: 600;
  color: var(--text2); border: none; background: none; cursor: pointer;
  border-radius: 8px; transition: all 0.15s; text-align: center; line-height: 1.3; }
.agents-layer-tab:hover { color: var(--text); background: rgba(255,255,255,0.05); }
.agents-layer-tab.active { background: var(--accent); color: #fff; }
.agents-layer-tab .layer-emoji { font-size: 16px; display: block; margin-bottom: 2px; }
.agents-layer-pane { display: none; }
.agents-layer-pane.active { display: block; }
.agent-card { background: var(--surface); border: 1px solid var(--border);
  border-radius: 12px; margin-bottom: 10px; overflow: hidden; transition: border-color 0.2s; }
.agent-card:hover { border-color: rgba(108,99,255,0.35); }
.agent-card-header { display: flex; align-items: center; gap: 12px; padding: 14px 18px; }
.agent-emoji-big { font-size: 22px; width: 34px; text-align: center; flex-shrink: 0; }
.agent-info { flex: 1; min-width: 0; }
.agent-name { font-size: 14px; font-weight: 700; margin-bottom: 2px; }
.agent-desc { font-size: 12px; color: var(--text2); line-height: 1.4; }
.agent-actions { display: flex; gap: 6px; align-items: center; flex-shrink: 0; }
.agent-status { padding: 2px 9px; border-radius: 20px; font-size: 11px; font-weight: 600; }
.agent-status-standby { background: rgba(136,136,153,0.12); color: var(--text2); }
.agent-status-active { background: rgba(108,99,255,0.15); color: var(--accent); }
.agent-status-done { background: rgba(74,222,128,0.12); color: var(--success); }
.agent-panel { display: none; border-top: 1px solid var(--border); }
.agent-panel.open { display: flex; }
.agent-chat-side { flex: 1; padding: 18px; border-right: 1px solid var(--border); min-width: 0; }
.agent-mission-side { width: 360px; padding: 18px; background: rgba(108,99,255,0.03); flex-shrink: 0; }
.agent-panel-title { font-size: 11px; font-weight: 700; text-transform: uppercase;
  letter-spacing: 0.8px; color: var(--text2); margin-bottom: 10px; }
.agent-chat-msgs { height: 260px; overflow-y: auto; display: flex; flex-direction: column;
  gap: 10px; margin-bottom: 12px; padding: 12px;
  background: var(--bg); border-radius: 8px; border: 1px solid var(--border); scroll-behavior: smooth; }
.agent-msg { max-width: 88%; padding: 9px 13px; border-radius: 12px; font-size: 13px; line-height: 1.5; word-break: break-word; }
.agent-msg-user { align-self: flex-end; background: var(--accent); color: #fff; border-radius: 12px 12px 4px 12px; }
.agent-msg-bot { align-self: flex-start; background: var(--surface); border: 1px solid var(--border);
  color: var(--text); border-radius: 12px 12px 12px 4px; white-space: pre-wrap; }
.agent-msg-sys { align-self: center; font-size: 11px; color: var(--text2); font-style: italic; padding: 4px 0; }
.agent-chat-input-row { display: flex; gap: 8px; }
.agent-chat-input-row input { flex: 1; font-size: 13px; padding: 9px 12px; }
.mission-card { background: var(--surface); border: 1px solid var(--border);
  border-radius: 10px; padding: 14px; margin-bottom: 12px; }
.mission-card h4 { font-size: 11px; font-weight: 700; color: var(--text2);
  text-transform: uppercase; letter-spacing: 0.8px; margin-bottom: 8px; }
.mission-desc-text { font-size: 12px; color: var(--text2); line-height: 1.5; margin-bottom: 12px; }
.mission-output-box { margin-top: 14px; padding: 14px;
  background: rgba(108,99,255,0.06); border: 1px solid rgba(108,99,255,0.2);
  border-radius: 8px; font-size: 12px; line-height: 1.6; white-space: pre-wrap;
  max-height: 320px; overflow-y: auto; display: none; }
.mission-output-box.visible { display: block; }
/* Research Data Display */
.research-phase-banner { display: flex; align-items: center; gap: 14px; padding: 14px 18px;
  background: rgba(74,222,128,0.07); border: 1px solid rgba(74,222,128,0.3);
  border-radius: 10px; margin-bottom: 20px; }
.research-phase-banner .phase-icon { font-size: 28px; }
.research-phase-banner h3 { font-size: 15px; font-weight: 700; color: var(--success); }
.research-phase-banner p { font-size: 12px; color: var(--text2); margin-top: 2px; }
.research-data-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 14px; margin-bottom: 24px; }
.rdc { background: var(--surface2); border: 1px solid var(--border); border-radius: 10px; padding: 16px; }
.rdc h4 { font-size: 11px; font-weight: 700; text-transform: uppercase;
  letter-spacing: 0.8px; color: var(--text2); margin-bottom: 12px; }
.desire-row { display: flex; align-items: flex-start; gap: 8px; padding: 6px 0;
  border-bottom: 1px solid rgba(255,255,255,0.05); font-size: 12px; }
.desire-row:last-child { border-bottom: none; }
.desire-rank { font-size: 10px; color: var(--text2); min-width: 18px; }
.desire-text { flex: 1; line-height: 1.3; }
.desire-score { font-size: 11px; font-weight: 700; color: var(--accent3); }
.primary-tag { padding: 1px 7px; font-size: 10px; background: rgba(78,205,196,0.15);
  color: var(--accent3); border-radius: 10px; display: inline-block; margin-left: 4px; }
.avatar-chip { padding: 8px 12px; background: var(--surface); border: 1px solid var(--border);
  border-radius: 8px; margin-bottom: 6px; }
.avatar-chip-id { font-size: 11px; font-weight: 700; color: var(--accent); }
.avatar-chip-name { font-size: 12px; font-weight: 600; margin-top: 2px; }
.avatar-chip-hook { font-size: 11px; color: var(--text2); margin-top: 2px; font-style: italic; }
.competitor-row { padding: 8px 0; border-bottom: 1px solid rgba(255,255,255,0.05); }
.competitor-row:last-child { border-bottom: none; }
.competitor-name { font-size: 12px; font-weight: 600; }
.competitor-gap { color: var(--success); font-size: 11px; margin-top: 2px; }
.competitor-price { color: var(--text2); font-size: 11px; }
/* Ecosystem Overview */
.eco-overview { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 28px; }
.eco-layer { background: var(--surface); border: 1px solid var(--border); border-radius: 10px; padding: 14px 16px; }
.eco-layer.eco-center { grid-column: 1 / -1; background: rgba(108,99,255,0.07);
  border-color: rgba(108,99,255,0.3); display: flex; align-items: center; gap: 16px; }
.eco-layer-title { font-size: 11px; font-weight: 700; text-transform: uppercase;
  letter-spacing: 0.8px; color: var(--text2); margin-bottom: 8px; }
.eco-chips { display: flex; flex-wrap: wrap; gap: 4px; }
.eco-chip { padding: 3px 10px; background: var(--surface2); border-radius: 20px;
  font-size: 11px; cursor: pointer; transition: background 0.15s; border: none; color: var(--text); }
.eco-chip:hover { background: rgba(108,99,255,0.2); color: var(--accent); }

/* ─── MISSION REPORT MODAL ─── */
.report-modal { position: fixed; inset: 0; z-index: 2000; background: rgba(0,0,0,0.9);
  display: none; flex-direction: column; }
.report-modal.open { display: flex; }
.report-header { display: flex; align-items: center; gap: 12px; padding: 14px 24px;
  background: var(--surface); border-bottom: 1px solid var(--border); flex-shrink: 0; }
.report-agent-emoji { font-size: 24px; }
.report-title { flex: 1; font-size: 16px; font-weight: 700; }
.report-layer-badge { padding: 3px 10px; border-radius: 20px; font-size: 11px; font-weight: 700;
  background: rgba(108,99,255,0.15); color: var(--accent); text-transform: uppercase; letter-spacing: 0.5px; }
.report-body { display: flex; flex: 1; overflow: hidden; }
/* Left: rendered markdown */
.report-content { flex: 1; overflow-y: auto; padding: 36px 40px; line-height: 1.65; }
.report-content h1 { font-size: 22px; font-weight: 700; margin: 0 0 16px; color: var(--accent); border-bottom: 2px solid rgba(108,99,255,0.3); padding-bottom: 10px; }
.report-content h2 { font-size: 18px; font-weight: 700; margin: 28px 0 12px; color: var(--text);
  display: flex; align-items: center; gap: 8px; }
.report-content h2::before { content: ''; display: inline-block; width: 4px; height: 18px;
  background: var(--accent); border-radius: 2px; flex-shrink: 0; }
.report-content h3 { font-size: 14px; font-weight: 700; margin: 20px 0 8px; color: var(--accent3); }
.report-content h4 { font-size: 12px; font-weight: 700; margin: 14px 0 6px; text-transform: uppercase;
  letter-spacing: 0.8px; color: var(--text2); }
.report-content p { margin: 0 0 12px; font-size: 14px; color: var(--text); }
.report-content ul { margin: 0 0 14px 0; padding: 0; list-style: none; }
.report-content ul li { padding: 5px 0 5px 20px; position: relative; font-size: 14px;
  border-bottom: 1px solid rgba(255,255,255,0.04); }
.report-content ul li::before { content: '→'; position: absolute; left: 0; color: var(--accent); font-weight: 700; }
.report-content ol { margin: 0 0 14px 20px; }
.report-content ol li { padding: 5px 0; font-size: 14px; }
.report-content blockquote { border-left: 3px solid var(--accent); padding: 10px 16px;
  margin: 14px 0; background: rgba(108,99,255,0.06); border-radius: 0 8px 8px 0;
  font-style: italic; color: var(--text2); font-size: 14px; }
.report-content code { background: rgba(108,99,255,0.12); padding: 2px 7px; border-radius: 4px;
  font-family: monospace; font-size: 12px; color: var(--accent3); }
.report-content pre { background: var(--surface2); padding: 18px; border-radius: 10px;
  overflow-x: auto; margin: 14px 0; font-size: 12px; line-height: 1.6;
  border: 1px solid var(--border); }
.report-content hr { border: none; border-top: 1px solid var(--border); margin: 24px 0; }
.report-content strong { color: var(--text); font-weight: 700; }
.report-content em { color: var(--text2); }
.report-content table { width: 100%; border-collapse: collapse; margin: 14px 0; font-size: 13px; }
.report-content th { padding: 9px 14px; background: var(--surface2); border: 1px solid var(--border);
  text-align: left; font-weight: 700; color: var(--text2); font-size: 11px; text-transform: uppercase; }
.report-content td { padding: 9px 14px; border: 1px solid var(--border); }
.report-content tr:nth-child(even) td { background: rgba(255,255,255,0.02); }
/* Right: visuals */
.report-visuals { width: 380px; background: var(--surface); border-left: 1px solid var(--border);
  overflow-y: auto; padding: 24px; flex-shrink: 0; }
.vis-section { margin-bottom: 28px; }
.vis-title { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.8px;
  color: var(--text2); margin-bottom: 14px; padding-bottom: 8px; border-bottom: 1px solid var(--border); }
/* Summary card */
.summary-card { background: rgba(108,99,255,0.06); border: 1px solid rgba(108,99,255,0.2);
  border-radius: 10px; padding: 14px; }
.summary-item { display: flex; gap: 8px; padding: 6px 0; font-size: 13px;
  border-bottom: 1px solid rgba(255,255,255,0.05); line-height: 1.4; }
.summary-item:last-child { border-bottom: none; }
.summary-item-icon { color: var(--accent); font-weight: 700; flex-shrink: 0; }
/* Bar chart */
.bar-row { margin-bottom: 10px; }
.bar-label { font-size: 11px; color: var(--text2); margin-bottom: 4px; display: flex; justify-content: space-between; }
.bar-track { height: 8px; background: rgba(255,255,255,0.07); border-radius: 4px; overflow: hidden; }
.bar-fill { height: 100%; border-radius: 4px; transition: width 1s ease-out; background: linear-gradient(90deg, var(--accent), #8b7cf8); }
.bar-fill.primary { background: linear-gradient(90deg, var(--accent3), #6eddd6); }
/* KPI grid */
.kpi-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
.kpi-item { background: var(--surface2); border: 1px solid var(--border); border-radius: 8px;
  padding: 10px 12px; text-align: center; }
.kpi-value { font-size: 16px; font-weight: 700; color: var(--accent3); }
.kpi-label { font-size: 11px; color: var(--text2); margin-top: 2px; font-weight: 600; }
/* Timeline */
.timeline { position: relative; padding-left: 22px; }
.timeline::before { content: ''; position: absolute; left: 7px; top: 8px; bottom: 8px; width: 2px; background: var(--border); }
.timeline-item { position: relative; margin-bottom: 16px; }
.timeline-dot { position: absolute; left: -18px; top: 5px; width: 12px; height: 12px;
  border-radius: 50%; background: var(--border); border: 2px solid var(--bg); }
.timeline-dot.tdone { background: var(--success); }
.timeline-dot.tactive { background: var(--accent); }
.timeline-item-title { font-size: 13px; font-weight: 700; margin-bottom: 3px; }
.timeline-item-desc { font-size: 11px; color: var(--text2); line-height: 1.4; }
/* 3-2-2 Matrix */
.matrix-322 { display: grid; grid-template-columns: 52px 1fr 1fr; gap: 4px; font-size: 11px; }
.mcell { padding: 8px 6px; border-radius: 6px; text-align: center; }
.mcell-h { background: var(--surface2); font-weight: 700; color: var(--text2); }
.mcell-l { background: rgba(108,99,255,0.12); font-weight: 700; color: var(--accent);
  display: flex; align-items: center; justify-content: center; font-size: 10px; writing-mode: vertical-lr; }
.mcell-ad { background: rgba(74,222,128,0.07); border: 1px solid rgba(74,222,128,0.2); color: var(--success); }
/* Rule cards */
.rule-card { background: var(--surface2); border-radius: 8px; padding: 10px 12px;
  margin-bottom: 8px; border-left: 3px solid var(--border); }
/* Hook pattern pill */
.hook-pattern { display: flex; align-items: center; gap: 8px; padding: 7px 0;
  border-bottom: 1px solid rgba(255,255,255,0.05); }
.hook-pattern:last-child { border-bottom: none; }
.hook-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }

/* ─── INLINE REPORT DASHBOARD ─── */
.agent-report-dashboard { display: none; border-top: 2px solid rgba(108,99,255,0.4); }
.agent-report-dashboard.visible { display: block; }
.ard-header { display: flex; align-items: center; gap: 10px; padding: 13px 18px;
  background: linear-gradient(90deg, rgba(108,99,255,0.14) 0%, rgba(108,99,255,0.04) 100%);
  border-bottom: 1px solid rgba(108,99,255,0.25); flex-wrap: wrap; gap: 8px; }
.ard-title { flex: 1; font-size: 14px; font-weight: 700; color: var(--accent); min-width: 160px; }
.ard-ts { font-size: 11px; color: var(--text2); padding: 3px 8px; background: rgba(255,255,255,0.05);
  border-radius: 10px; }
.ard-body { display: flex; }
.ard-content { flex: 1; overflow-x: hidden; padding: 30px 36px; min-width: 0; }
.ard-visuals { width: 340px; flex-shrink: 0; padding: 20px; background: var(--surface);
  border-left: 1px solid var(--border); overflow-x: hidden; }

/* ─── COPY BUTTON ─── */
.copy-btn { float: right; padding: 4px 10px; font-size: 11px; }

/* API KEY INPUT */
.api-key-section { padding: 10px 16px; background: rgba(108,99,255,0.05);
  border-radius: 8px; border: 1px solid rgba(108,99,255,0.2); margin-bottom: 20px; }

/* ─── SCRIPTS SELECTOR ─── */
.script-selector { max-height: 200px; overflow-y: auto; }
.script-item { padding: 10px 12px; border-radius: 6px; cursor: pointer;
  font-size: 13px; border: 1px solid transparent; margin-bottom: 4px; transition: all 0.1s; }
.script-item:hover { background: var(--surface2); }
.script-item.selected { border-color: var(--accent); background: rgba(108,99,255,0.1); }
.script-item .script-title { font-weight: 600; }
.script-item .script-hook { font-size: 11px; color: var(--text2); margin-top: 2px; }

/* ─── COMMAND CENTER ─── */
.cc-tabs { display:flex; gap:8px; margin-bottom:24px; flex-wrap:wrap; }
.cc-tab {
  padding:8px 18px; border-radius:8px; cursor:pointer; font-size:13px; font-weight:600;
  border:1px solid var(--border); background:var(--surface2); color:var(--text2);
  transition:all 0.15s;
}
.cc-tab.active { background:rgba(108,99,255,0.18); border-color:var(--accent); color:var(--accent); }
.cc-section { display:none; }
.cc-section.active { display:block; }

/* Tables */
.cc-table { width:100%; border-collapse:collapse; font-size:13px; }
.cc-table th {
  text-align:left; padding:10px 12px; background:var(--surface2);
  color:var(--text2); font-weight:600; font-size:11px; text-transform:uppercase;
  letter-spacing:0.6px; border-bottom:1px solid var(--border);
}
.cc-table td { padding:11px 12px; border-bottom:1px solid rgba(255,255,255,0.04); vertical-align:top; }
.cc-table tr:last-child td { border-bottom:none; }
.cc-table tr:hover td { background:rgba(255,255,255,0.02); }

/* Badges */
.badge {
  display:inline-block; padding:3px 9px; border-radius:20px;
  font-size:11px; font-weight:600; white-space:nowrap;
}
.badge-done   { background:rgba(74,222,128,0.15); color:#4ade80; border:1px solid rgba(74,222,128,0.3); }
.badge-wip    { background:rgba(251,191,36,0.15);  color:#fbbf24; border:1px solid rgba(251,191,36,0.3); }
.badge-todo   { background:rgba(248,113,113,0.15); color:#f87171; border:1px solid rgba(248,113,113,0.3); }
.badge-paused { background:rgba(136,136,153,0.15); color:#888899; border:1px solid rgba(136,136,153,0.3); }
.badge-p0     { background:rgba(248,113,113,0.15); color:#f87171; border:1px solid rgba(248,113,113,0.3); }
.badge-p1     { background:rgba(251,191,36,0.15);  color:#fbbf24; border:1px solid rgba(251,191,36,0.3); }
.badge-p2     { background:rgba(108,99,255,0.15);  color:#6c63ff; border:1px solid rgba(108,99,255,0.3); }

/* OKR tree */
.okr-obj { background:var(--surface2); border:1px solid var(--border); border-radius:10px; margin-bottom:14px; overflow:hidden; }
.okr-obj-header {
  padding:12px 16px; display:flex; align-items:center; gap:10px;
  cursor:pointer; user-select:none;
}
.okr-obj-header:hover { background:rgba(108,99,255,0.06); }
.okr-obj-title { font-size:14px; font-weight:700; flex:1; }
.okr-toggle { font-size:11px; color:var(--text2); transition:transform 0.2s; }
.okr-toggle.open { transform:rotate(90deg); }
.okr-body { padding:0 16px 14px; }
.okr-kr { border-left:2px solid var(--accent); padding:8px 12px; margin:8px 0; border-radius:0 8px 8px 0; background:rgba(108,99,255,0.05); }
.okr-kr-title { font-size:13px; font-weight:600; margin-bottom:6px; }
.okr-tasks { padding-left:12px; }
.okr-task { display:flex; align-items:center; gap:8px; padding:5px 0; font-size:13px; color:var(--text2); cursor:pointer; }
.okr-task input[type=checkbox] { width:15px; height:15px; accent-color:var(--accent); cursor:pointer; }
.okr-task.done-task > span { text-decoration:line-through; color:var(--text2); opacity:0.5; }

/* To-do */
.todo-add-bar { display:flex; gap:8px; margin-bottom:16px; }
.todo-add-bar input { flex:1; }
.todo-item {
  display:flex; align-items:center; gap:10px; padding:10px 14px;
  background:var(--surface2); border:1px solid var(--border); border-radius:8px; margin-bottom:8px;
  transition:all 0.15s;
}
.todo-item:hover { border-color:rgba(108,99,255,0.3); }
.todo-item.done { opacity:0.45; }
.todo-item.done .todo-label { text-decoration:line-through; }
.todo-label { flex:1; font-size:13px; }
.todo-meta { font-size:11px; color:var(--text2); white-space:nowrap; }
.todo-del { background:none; border:none; color:var(--text2); cursor:pointer; font-size:15px; padding:2px 6px; border-radius:4px; opacity:0.5; }
.todo-del:hover { opacity:1; color:var(--error); }

/* Add form modal-like */
.cc-add-btn {
  padding:8px 16px; background:var(--accent); color:#fff; border:none;
  border-radius:8px; cursor:pointer; font-size:13px; font-weight:600;
  transition:opacity 0.15s;
}
.cc-add-btn:hover { opacity:0.85; }
.cc-add-btn.secondary { background:var(--surface2); color:var(--text2); border:1px solid var(--border); }

.cc-form { background:var(--surface2); border:1px solid var(--border); border-radius:10px; padding:18px; margin-bottom:20px; display:none; }
.cc-form.open { display:block; }
.cc-form-grid { display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:12px; }
.cc-form-row { margin-bottom:12px; }
.cc-form-actions { display:flex; gap:8px; }
.progress-bar-wrap { background:rgba(255,255,255,0.07); border-radius:20px; height:6px; flex:1; overflow:hidden; }
.progress-bar-fill { height:100%; border-radius:20px; background:linear-gradient(90deg,var(--accent),var(--accent3)); transition:width 0.4s; }
.section-toolbar { display:flex; align-items:center; gap:8px; margin-bottom:16px; }
.section-toolbar h3 { flex:1; font-size:15px; font-weight:700; }
.cc-stats { display:grid; grid-template-columns:repeat(4,1fr); gap:12px; margin-bottom:24px; }
.cc-stat { background:var(--surface2); border:1px solid var(--border); border-radius:10px; padding:14px 16px; }
.cc-stat-val { font-size:26px; font-weight:800; }
.cc-stat-lab { font-size:11px; color:var(--text2); margin-top:2px; }
</style>
</head>
<body>
<div class="layout">

<!-- ─── SIDEBAR ─── -->
<nav class="sidebar">
  <div class="logo">⚡ OMNIA <span>Creative OS</span></div>

  <button class="nav-item active" onclick="showPage('commandcenter')">
    <span class="nav-icon">🎯</span> Command Center
  </button>
  <div style="font-size:10px;font-weight:700;color:var(--text2);letter-spacing:1px;text-transform:uppercase;padding:8px 12px 4px;margin-top:4px">EVOLVE</div>
  <button class="nav-item" onclick="showEvolveSection('research')">
    <span class="nav-icon">🔍</span> Recherche
  </button>
  <button class="nav-item" onclick="showEvolveSection('strategy')">
    <span class="nav-icon">🧠</span> Stratégie
  </button>
  <button class="nav-item" onclick="showEvolveSection('creation')">
    <span class="nav-icon">🎨</span> Création
  </button>
  <button class="nav-item" onclick="showEvolveSection('execution')">
    <span class="nav-icon">🚀</span> Exécution
  </button>
  <button class="nav-item" onclick="showEvolveSection('optimization')">
    <span class="nav-icon">📈</span> Optimisation
  </button>

  <hr style="border-color:var(--border);margin:8px 0">
  <button class="nav-item" onclick="showPage('adspy')">
    <span class="nav-icon">🔭</span> ADSPY PRO
  </button>
  <button class="nav-item" onclick="showPage('knowledge-base')">
    <span class="nav-icon">📖</span> Bibliothèque
  </button>
  <hr style="border-color:var(--border);margin:8px 0">
  <button class="nav-item" onclick="showPage('multiscene'); setTimeout(()=>showStudioTab('pipeline'),50)">
    <span class="nav-icon">🏭</span> Pipeline UGC
  </button>
  <button class="nav-item" onclick="showPage('settings')">
    <span class="nav-icon">⚙️</span> Settings
  </button>
  <button class="nav-item" onclick="showPage('apidocs')">
    <span class="nav-icon">📚</span> API Docs
  </button>

  <div class="credits-badge">
    <div style="margin-bottom:4px">Crédits kie.ai</div>
    <div class="credits-num" id="creditsDisplay">—</div>
    <div style="font-size:11px;margin-top:4px">≈ <span id="creditsVideos">—</span> vidéos Sora 2</div>
  </div>
</nav>

<!-- ─── MAIN CONTENT ─── -->
<main class="main">

<!-- ═══ DASHBOARD ═══ -->
<div class="page" id="page-dashboard">
  <div class="page-header">
    <div class="page-title">⚡ OMNIA Creative OS</div>
    <div class="page-sub">drinknellio.com — Pipeline UGC IA automatisé</div>
  </div>

  <div class="grid-3">
    <div class="card" style="cursor:pointer;border-color:rgba(108,99,255,0.4)" onclick="showPage('multiscene');showStudioTab('ugc')">
      <div style="font-size:32px;margin-bottom:8px">🎬</div>
      <div style="font-weight:700;margin-bottom:4px">UGC Clip</div>
      <div style="font-size:13px;color:var(--text2)">19 avatars · 9 angles · kie.ai / HeyGen</div>
      <div id="dash-videos" style="margin-top:12px;font-size:22px;font-weight:700;color:var(--accent)">0</div>
      <div style="font-size:11px;color:var(--text2)">clips générés</div>
    </div>
    <div class="card" style="cursor:pointer;border-color:rgba(255,107,107,0.4)" onclick="showPage('multiscene');showStudioTab('longform')">
      <div style="font-size:32px;margin-bottom:8px">🎬</div>
      <div style="font-weight:700;margin-bottom:4px">Long Form</div>
      <div style="font-size:13px;color:var(--text2)">4–6 scènes · même avatar · export ZIP</div>
      <div style="margin-top:12px;font-size:22px;font-weight:700;color:var(--accent2)">40s+</div>
      <div style="font-size:11px;color:var(--text2)">vidéos longues</div>
    </div>
    <div class="card" style="cursor:pointer;border-color:rgba(78,205,196,0.4)" onclick="showPage('multiscene');showStudioTab('broll')">
      <div style="font-size:32px;margin-bottom:8px">🎥</div>
      <div style="font-weight:700;margin-bottom:4px">B-Roll + Voiceover</div>
      <div style="font-size:13px;color:var(--text2)">Kling 3.0 · ElevenLabs · ZackD</div>
      <div style="margin-top:12px;font-size:22px;font-weight:700;color:var(--accent3)">3</div>
      <div style="font-size:11px;color:var(--text2)">modes de production</div>
    </div>
  </div>
  <!-- Agents EVOLVE shortcut -->
  <div class="card" style="cursor:pointer;border-color:rgba(108,99,255,0.5);background:rgba(108,99,255,0.04)" onclick="showPage('agents')">
    <div style="display:flex;align-items:center;gap:16px">
      <div style="font-size:40px">🤖</div>
      <div style="flex:1">
        <div style="font-weight:700;font-size:16px;margin-bottom:4px">⚡ EVOLVE Agent Ecosystem</div>
        <div style="font-size:13px;color:var(--text2)">26 agents spécialisés · 5 layers · Research → Strategy → Creation → Execution → Optimization</div>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;font-size:12px">
        <div style="text-align:center"><div style="font-size:18px;font-weight:700;color:var(--success)">✅</div><div style="color:var(--text2)">Research</div></div>
        <div style="text-align:center"><div style="font-size:18px;font-weight:700;color:var(--accent)">⚡</div><div style="color:var(--text2)">Strategy</div></div>
        <div style="text-align:center"><div style="font-size:18px;font-weight:700;color:var(--text2)">⏸</div><div style="color:var(--text2)">Création</div></div>
      </div>
    </div>
  </div>

  <div class="card">
    <div class="card-title">Pipeline EVOLVE — Statut</div>
    <div style="display:flex;flex-direction:column;gap:10px">
      <div style="display:flex;align-items:center;gap:12px">
        <span style="color:var(--success);font-size:18px">✅</span>
        <div><strong>Phase 1 — Research</strong> <span style="color:var(--text2);font-size:12px">9 fichiers · Dashboard 8 onglets</span></div>
      </div>
      <div style="display:flex;align-items:center;gap:12px">
        <span style="color:var(--success);font-size:18px">✅</span>
        <div><strong>Phase 2 — Strategy</strong> <span style="color:var(--text2);font-size:12px">42 angles · 75 hooks · 10 batches</span></div>
      </div>
      <div style="display:flex;align-items:center;gap:12px">
        <span style="color:var(--success);font-size:18px">✅</span>
        <div><strong>Phase 3 — Scripts</strong> <span style="color:var(--text2);font-size:12px">12 créatives · 9 scripts UGC verbatim</span></div>
      </div>
      <div style="display:flex;align-items:center;gap:12px">
        <span style="color:var(--accent);font-size:18px">🚀</span>
        <div><strong>Phase 4 — Exécution</strong> <span style="color:var(--accent);font-size:12px">EN COURS — OMNIA actif</span></div>
      </div>
    </div>
  </div>

  <div class="card">
    <div class="card-title">Marksman Batches — Prêts à produire</div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px">
      <div style="padding:12px;background:var(--surface2);border-radius:8px;border-left:3px solid var(--accent)">
        <div style="font-weight:600;font-size:13px">Batch #1</div>
        <div style="font-size:12px;color:var(--text2)">Der Cortisol-Wecker</div>
        <div style="font-size:11px;margin-top:4px">SA-02 · SA-01 · SA-04</div>
      </div>
      <div style="padding:12px;background:var(--surface2);border-radius:8px;border-left:3px solid var(--accent2)">
        <div style="font-weight:600;font-size:13px">Batch #2</div>
        <div style="font-size:12px;color:var(--text2)">Ich bin nicht mehr ich selbst</div>
        <div style="font-size:11px;margin-top:4px">SA-14 · SA-01 · SA-09</div>
      </div>
      <div style="padding:12px;background:var(--surface2);border-radius:8px;border-left:3px solid var(--accent3)">
        <div style="font-weight:600;font-size:13px">Batch #3</div>
        <div style="font-size:12px;color:var(--text2)">Cortisol-Körper Sichtbar</div>
        <div style="font-size:11px;margin-top:4px">SA-05 · SA-03 · SA-15</div>
      </div>
      <div style="padding:12px;background:var(--surface2);border-radius:8px;border-left:3px solid var(--warning)">
        <div style="font-weight:600;font-size:13px">Batch #4</div>
        <div style="font-size:12px;color:var(--text2)">Alles versucht — jetzt das Richtige</div>
