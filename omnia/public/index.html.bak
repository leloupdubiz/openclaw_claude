            { id:'t3b2', text:'Améliorer l\'indice de cohérence (B-roll / montage / preuve)', done:false },
            { id:'t3b3', text:'Dupliquer sur 2-3 ad accounts en parallèle', done:false },
          ]},
          { id:'kr3c', text:'Mettre en place le LTV via email/SMS retention', tasks:[
            { id:'t3c1', text:'Formulaire post-achat + formulaire 45 jours', done:false },
            { id:'t3c2', text:'Flow email réachat J+30 DE', done:false },
            { id:'t3c3', text:'Calculer LTV réelle (commande 1 + upsell + réachat)', done:false },
          ]}
        ]
      }
    ],
    todos: [
      { id:'td1', text:'Recharger crédits Anthropic (console.anthropic.com)', priority:'P0', project:'p2', done:false, ts: Date.now()-100 },
      { id:'td2', text:'Produire scripts UGC DE — Angle CORTISOL_MÉCANISME', priority:'P0', project:'p4', done:false, ts: Date.now()-200 },
      { id:'td3', text:'Produire scripts UGC DE — Angle SCHLAF_CHRONIQUE', priority:'P0', project:'p4', done:false, ts: Date.now()-300 },
      { id:'td4', text:'Produire scripts UGC DE — Angle IDENTITE_PRO', priority:'P0', project:'p4', done:false, ts: Date.now()-400 },
      { id:'td5', text:'Configurer Meta BM + chauffer page Facebook Nellio', priority:'P0', project:'p7', done:false, ts: Date.now()-500 },
      { id:'td6', text:'Lancer CBO testing 300-500€ Meta DE', priority:'P0', project:'p7', done:false, ts: Date.now()-600 },
      { id:'td7', text:'Construire Batch Generator UI (frontend Nellio Studio)', priority:'P0', project:'p2', done:false, ts: Date.now()-700 },
      { id:'td8', text:'Créer les 3 agents OMNIA manquants (Research Doc / Roadmap / Learnings)', priority:'P1', project:'p5', done:false, ts: Date.now()-800 },
      { id:'td9', text:'Se reconnecter Whop → débloquer 15 leçons EcomTalent', priority:'P1', project:'p6', done:false, ts: Date.now()-900 },
      { id:'td10', text:'Analyser data Meta 72h → identifier angle winner', priority:'P1', project:'p7', done:false, ts: Date.now()-1000 },
      { id:'td11', text:'Ajouter historique localStorage Nellio Studio', priority:'P1', project:'p2', done:false, ts: Date.now()-1100 },
      { id:'td12', text:'Implémenter export CSV Meta Ads Nellio Studio', priority:'P1', project:'p2', done:false, ts: Date.now()-1200 },
    ]
  };
}

// ─── ÉTAT FORMULAIRE EN COURS D'ÉDITION ──────────────────────
let _editProjId = null;
let _editObjId  = null;

// ─── TABS ────────────────────────────────────────────────────
function ccShowTab(tab) {
  document.querySelectorAll('.cc-tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.cc-section').forEach(s => s.classList.remove('active'));
  document.getElementById('cc-' + tab).classList.add('active');
  event.target.classList.add('active');
  ccUpdateStats();
}

function ccToggleForm(id) {
  const f = document.getElementById(id);
  f.classList.toggle('open');
  if (!f.classList.contains('open')) { _editProjId = null; _editObjId = null; }
}

// ─── STATS ───────────────────────────────────────────────────
function ccUpdateStats() {
  const d = ccLoad();
  const activeProj = d.projects.filter(p => p.status !== 'done' && p.status !== 'paused').length;
  const openTasks  = d.todos.filter(t => !t.done).length;
  const doneTasks  = d.todos.filter(t => t.done).length;
  document.getElementById('cc-stat-proj').textContent  = activeProj;
  document.getElementById('cc-stat-obj').textContent   = d.objectives.length;
  document.getElementById('cc-stat-tasks').textContent = openTasks;
  document.getElementById('cc-stat-done').textContent  = doneTasks;
}

// ─── HELPERS ─────────────────────────────────────────────────
function ccStatusBadge(s) {
  const map = { done:'badge-done', wip:'badge-wip', todo:'badge-todo', paused:'badge-paused' };
  const lbl = { done:'✅ Terminé', wip:'🟡 En cours', todo:'🔴 À faire', paused:'⏸️ En pause' };
  return `<span class="badge ${map[s]||'badge-todo'}">${lbl[s]||s}</span>`;
}
function ccPriBadge(p) {
  const map = { P0:'badge-p0', P1:'badge-p1', P2:'badge-p2' };
  return `<span class="badge ${map[p]||'badge-p2'}">${p}</span>`;
}
function ccHorizonBadge(h) {
  const col = { CT:'#f43f5e', MT:'#fbbf24', LT:'#6c63ff' };
  return `<span style="font-size:11px;font-weight:700;color:${col[h]||'#888'}">${h}</span>`;
}
function uid() { return '_' + Math.random().toString(36).substr(2,9); }

// ─── PROJETS ─────────────────────────────────────────────────
function ccRenderProjects() {
  const d = ccLoad();
  const order = { P0:0, P1:1, P2:2 };
  const statusOrd = { todo:0, wip:1, paused:2, done:3 };
  const sorted = [...d.projects].sort((a,b) => statusOrd[a.status]-statusOrd[b.status] || order[a.priority]-order[b.priority]);

  const tbody = document.getElementById('proj-tbody');
  if (!tbody) return;
  tbody.innerHTML = sorted.map(p => `
    <tr>
      <td>${ccHorizonBadge(p.horizon)}</td>
      <td>${ccPriBadge(p.priority)}</td>
      <td style="font-weight:600;max-width:220px">${p.name}</td>
      <td>${ccStatusBadge(p.status)}</td>
      <td style="min-width:110px">
        <div style="display:flex;align-items:center;gap:8px">
          <div class="progress-bar-wrap"><div class="progress-bar-fill" style="width:${p.pct}%"></div></div>
          <span style="font-size:12px;color:var(--text2);white-space:nowrap">${p.pct}%</span>
        </div>
      </td>
      <td style="color:var(--text2);font-size:12px;max-width:200px">${p.desc||'—'}</td>
      <td style="white-space:nowrap">
        <button class="todo-del" onclick="ccEditProject('${p.id}')" title="Éditer">✏️</button>
        <button class="todo-del" onclick="ccDeleteProject('${p.id}')" title="Supprimer">🗑️</button>
      </td>
    </tr>`).join('');

  // Refresh todo project select
  const sel = document.getElementById('todo-project');
  if (sel) {
    const cur = sel.value;
    sel.innerHTML = '<option value="">— Projet —</option>' + d.projects.map(p =>
      `<option value="${p.id}" ${cur===p.id?'selected':''}>${p.name.slice(0,35)}</option>`).join('');
  }
  ccUpdateStats();
}

function ccSaveProject() {
  const d = ccLoad();
  const name = document.getElementById('pf-name').value.trim();
  if (!name) return;
  const obj = {
    id: _editProjId || uid(),
    name,
    horizon:  document.getElementById('pf-horizon').value,
    status:   document.getElementById('pf-status').value,
    priority: document.getElementById('pf-priority').value,
    pct:      parseInt(document.getElementById('pf-pct').value)||0,
    desc:     document.getElementById('pf-desc').value.trim(),
    ts: Date.now()
  };
  if (_editProjId) {
    const idx = d.projects.findIndex(p => p.id === _editProjId);
    if (idx > -1) d.projects[idx] = obj;
  } else {
    d.projects.unshift(obj);
  }
  ccSave(d);
  _editProjId = null;
  document.getElementById('proj-form').classList.remove('open');
  ['pf-name','pf-desc'].forEach(id => document.getElementById(id).value='');
  document.getElementById('pf-pct').value = 0;
  ccRenderProjects();
}

function ccEditProject(id) {
  const d = ccLoad();
  const p = d.projects.find(x => x.id === id);
  if (!p) return;
  _editProjId = id;
  document.getElementById('pf-name').value     = p.name;
  document.getElementById('pf-horizon').value  = p.horizon;
  document.getElementById('pf-status').value   = p.status;
  document.getElementById('pf-priority').value = p.priority;
  document.getElementById('pf-pct').value      = p.pct;
  document.getElementById('pf-desc').value     = p.desc||'';
  document.getElementById('proj-form').classList.add('open');
  document.getElementById('pf-name').scrollIntoView({ behavior:'smooth', block:'nearest' });
}

function ccDeleteProject(id) {
  if (!confirm('Supprimer ce projet ?')) return;
  const d = ccLoad();
  d.projects = d.projects.filter(p => p.id !== id);
  ccSave(d); ccRenderProjects();
}

// ─── OKR ─────────────────────────────────────────────────────
function ccRenderOKR() {
  const d = ccLoad();
  const el = document.getElementById('okr-list');
  if (!el) return;
  el.innerHTML = d.objectives.map(obj => {
    const totalTasks = obj.krs.reduce((s,kr) => s + kr.tasks.length, 0);
    const doneTasks  = obj.krs.reduce((s,kr) => s + kr.tasks.filter(t=>t.done).length, 0);
    const pct = totalTasks ? Math.round(doneTasks/totalTasks*100) : 0;
    return `
    <div class="okr-obj">
      <div class="okr-obj-header" onclick="ccToggleOKR('${obj.id}')">
        <div style="flex:1">
          <div style="display:flex;align-items:center;gap:10px;margin-bottom:6px">
            ${ccHorizonBadge(obj.horizon)}
            <span class="okr-obj-title">${obj.title}</span>
          </div>
          <div style="display:flex;align-items:center;gap:10px">
            <div class="progress-bar-wrap" style="max-width:180px"><div class="progress-bar-fill" style="width:${pct}%"></div></div>
            <span style="font-size:11px;color:var(--text2)">${doneTasks}/${totalTasks} tâches · ${pct}%</span>
          </div>
        </div>
        <button class="todo-del" onclick="event.stopPropagation();ccDeleteObjective('${obj.id}')" title="Supprimer">🗑️</button>
        <span class="okr-toggle ${obj.collapsed?'':'open'}">▶</span>
      </div>
      ${obj.collapsed ? '' : `<div class="okr-body">
        ${obj.krs.map(kr => `
          <div class="okr-kr">
            <div class="okr-kr-title">🔑 ${kr.text}</div>
            <div class="okr-tasks">
              ${kr.tasks.map(t => `
                <div class="okr-task ${t.done?'done-task':''}" onclick="ccToggleTask('${obj.id}','${kr.id}','${t.id}')">
                  <input type="checkbox" ${t.done?'checked':''} onclick="event.stopPropagation();ccToggleTask('${obj.id}','${kr.id}','${t.id}')">
                  <span>${t.text}</span>
                </div>`).join('')}
              <div style="margin-top:8px;display:flex;gap:6px">
                <input id="newtask-${kr.id}" placeholder="Nouvelle tâche..." style="font-size:12px;padding:6px 10px;flex:1" onkeydown="if(event.key==='Enter')ccAddTask('${obj.id}','${kr.id}')">
                <button class="cc-add-btn" style="padding:6px 12px;font-size:12px" onclick="ccAddTask('${obj.id}','${kr.id}')">+</button>
              </div>
            </div>
          </div>`).join('')}
        <div style="margin-top:12px;display:flex;gap:6px;align-items:center">
          <input id="newkr-${obj.id}" placeholder="Nouveau Key Result..." style="font-size:12px;padding:6px 10px;flex:1" onkeydown="if(event.key==='Enter')ccAddKR('${obj.id}')">
          <button class="cc-add-btn secondary" style="padding:6px 12px;font-size:12px" onclick="ccAddKR('${obj.id}')">+ KR</button>
        </div>
      </div>`}
    </div>`;
  }).join('');
  ccUpdateStats();
}

function ccToggleOKR(objId) {
  const d = ccLoad();
  const obj = d.objectives.find(o => o.id === objId);
  if (obj) obj.collapsed = !obj.collapsed;
  ccSave(d); ccRenderOKR();
}

function ccSaveObjective() {
  const title = document.getElementById('of-title').value.trim();
  if (!title) return;
  const krsRaw = document.getElementById('of-krs').value.trim().split('\n').filter(Boolean);
  const d = ccLoad();
  d.objectives.push({
    id: uid(), title,
    horizon: document.getElementById('of-horizon').value,
    collapsed: false,
    ts: Date.now(),
    krs: krsRaw.map(txt => ({ id: uid(), text: txt.replace(/^KR\d+:\s*/,''), tasks:[] }))
  });
  ccSave(d);
  document.getElementById('okr-form').classList.remove('open');
  document.getElementById('of-title').value = '';
  document.getElementById('of-krs').value   = '';
  ccRenderOKR();
}

function ccDeleteObjective(id) {
  if (!confirm('Supprimer cet objectif ?')) return;
  const d = ccLoad();
  d.objectives = d.objectives.filter(o => o.id !== id);
  ccSave(d); ccRenderOKR();
}

function ccToggleTask(objId, krId, taskId) {
  const d = ccLoad();
  const obj = d.objectives.find(o => o.id === objId);
  if (!obj) return;
  const kr = obj.krs.find(k => k.id === krId);
  if (!kr) return;
  const task = kr.tasks.find(t => t.id === taskId);
  if (task) task.done = !task.done;
  ccSave(d); ccRenderOKR();
}

function ccAddTask(objId, krId) {
  const inp = document.getElementById('newtask-'+krId);
  if (!inp || !inp.value.trim()) return;
  const d = ccLoad();
  const obj = d.objectives.find(o => o.id === objId);
  const kr  = obj && obj.krs.find(k => k.id === krId);
  if (!kr) return;
  kr.tasks.push({ id: uid(), text: inp.value.trim(), done: false });
  ccSave(d); ccRenderOKR();
}

function ccAddKR(objId) {
  const inp = document.getElementById('newkr-'+objId);
  if (!inp || !inp.value.trim()) return;
  const d = ccLoad();
  const obj = d.objectives.find(o => o.id === objId);
  if (!obj) return;
  obj.krs.push({ id: uid(), text: inp.value.trim(), tasks:[] });
  ccSave(d); ccRenderOKR();
}

// ─── TO-DO ───────────────────────────────────────────────────
function ccRenderTodo() {
  const d = ccLoad();
  const filter = document.getElementById('todo-filter')?.value || 'all';
  let items = [...d.todos];
  if (filter === 'open')  items = items.filter(t => !t.done);
  if (filter === 'done')  items = items.filter(t => t.done);
  if (filter === 'P0')    items = items.filter(t => t.priority === 'P0');
  if (filter === 'P1')    items = items.filter(t => t.priority === 'P1');

  // Trier : non-done d'abord, puis par priorité, puis par date
  const pri = { P0:0, P1:1, P2:2 };
  items.sort((a,b) => a.done-b.done || (pri[a.priority]||2)-(pri[b.priority]||2) || b.ts-a.ts);

  const el = document.getElementById('todo-list');
  if (!el) return;
  if (!items.length) { el.innerHTML = '<div style="text-align:center;padding:32px;color:var(--text2)">Aucune tâche correspondante.</div>'; return; }

  el.innerHTML = items.map(t => {
    const proj = d.projects.find(p => p.id === t.project);
    return `<div class="todo-item ${t.done?'done':''}">
      <input type="checkbox" ${t.done?'checked':''} onchange="ccToggleTodo('${t.id}')" style="width:16px;height:16px;accent-color:var(--accent);cursor:pointer">
      <span class="todo-label">${t.text}</span>
      ${ccPriBadge(t.priority)}
      ${proj ? `<span class="todo-meta">📋 ${proj.name.slice(0,25)}…</span>` : ''}
      <button class="todo-del" onclick="ccDeleteTodo('${t.id}')">🗑️</button>
    </div>`;
  }).join('');
  ccUpdateStats();
}

function ccAddTodo() {
  const inp = document.getElementById('todo-input');
  const text = inp.value.trim();
  if (!text) return;
  const d = ccLoad();
  d.todos.unshift({
    id: uid(),
    text,
    priority: document.getElementById('todo-priority').value,
    project:  document.getElementById('todo-project').value,
    done: false,
    ts: Date.now()
  });
  ccSave(d);
  inp.value = '';
  ccRenderTodo();
  ccRenderProjects(); // refresh projet select
}

function ccToggleTodo(id) {
  const d = ccLoad();
  const t = d.todos.find(x => x.id === id);
  if (t) t.done = !t.done;
  ccSave(d); ccRenderTodo();
}

function ccDeleteTodo(id) {
  if (!confirm('Supprimer cette tâche ?')) return;
  const d = ccLoad();
  d.todos = d.todos.filter(t => t.id !== id);
  ccSave(d); ccRenderTodo();
}

// ─── INIT ────────────────────────────────────────────────────
(function ccInit() {
  // Si aucune donnée en localStorage, initialiser avec les données par défaut
  if (!localStorage.getItem(CC_KEY)) ccSave(ccDefaultData());

  // Render au chargement de la page commandcenter
  const origShowPage = window.showPage;
  window.showPage = function(name) {
    origShowPage && origShowPage(name);
    if (name === 'commandcenter') {
      setTimeout(() => { ccRenderProjects(); ccRenderOKR(); ccRenderTodo(); ccUpdateStats(); }, 50);
    }
  };

  // Render immédiat si la page est déjà active
  if (document.getElementById('page-commandcenter')?.classList.contains('active')) {
    ccRenderProjects(); ccRenderOKR(); ccRenderTodo(); ccUpdateStats();
  }
})();
</script>

<!-- ═══ PIPELINE 1 CLIC — JS ═══ -->
<script>
let _pipelineCsvData = null;

async function runPipelineFull() {
  const angle = document.getElementById('pip-angle').value;
  const avatar = document.getElementById('pip-avatar').value;
  const hooks_count = parseInt(document.getElementById('pip-hooks').value);
  const verbatims = document.getElementById('pip-verbatims').value.trim();
  const statusEl = document.getElementById('pip-status');
  const resultEl = document.getElementById('pip-result');
  const csvBtn = document.getElementById('pip-csv-btn');

  statusEl.textContent = '⏳ Pipeline en cours (3 agents × Claude)…';
  resultEl.style.display = 'none';
  csvBtn.style.display = 'none';
  _pipelineCsvData = null;

  try {
    const res = await fetch('/api/pipeline/full', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ angle, avatar, hooks_count, verbatims })
    });
    const data = await res.json();
    if (!data.success) throw new Error(data.error || 'Erreur inconnue');

    document.getElementById('pip-research').textContent = data.research_doc || '—';
    document.getElementById('pip-hooks-out').textContent = data.hooks || '—';
    document.getElementById('pip-script-out').textContent = data.script || '—';
    _pipelineCsvData = data.csv_export;

    resultEl.style.display = 'block';
    csvBtn.style.display = 'inline-block';
    statusEl.textContent = `✅ Pipeline complet — fichier : ${data.markdown_file?.split('/').pop() || 'sauvegardé'}`;
  } catch (e) {
    statusEl.textContent = `❌ Erreur : ${e.message}`;
  }
}

function downloadPipelineCSV() {
  if (!_pipelineCsvData) return;
  const blob = new Blob([_pipelineCsvData], { type: 'text/csv;charset=utf-8;' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = `nellio_pipeline_${Date.now()}.csv`;
  a.click();
  URL.revokeObjectURL(url);
}
</script>

<!-- ═══ CREATIVE FACTORY JS ═══ -->
<script>
// ─── Factory Tab Switcher ────────────────────────────────────────────────────
function showFactoryTab(tab) {
  // Legacy → redirige vers Studio Clip
  const map = { ugc: 'pipeline', cloner: 'cloner', images: 'pipeline', automation: 'automation' };
  showPage('multiscene');
  setTimeout(() => showStudioTab(map[tab] || 'pipeline'), 50);
}

// ─── UGC Pipeline ────────────────────────────────────────────────────────────
let ugcPollingInterval = null;

async function startUGCPipeline() {
  const btn = document.getElementById('btn-ugc-start');
  const badge = document.getElementById('ugc-status-badge');
  btn.disabled = true;
  btn.textContent = '⏳ Lancement...';
  badge.textContent = 'Envoi à HeyGen...';

  try {
    const res = await fetch('/api/ugc/pipeline/start', { method: 'POST', headers: {'Content-Type':'application/json'} });
    const data = await res.json();

    if (data.error) {
      badge.textContent = '❌ ' + data.error;
      btn.disabled = false;
      btn.textContent = '🚀 Lancer les 3 vidéos';
      return;
    }

    badge.textContent = `✅ ${data.started}/${data.total} jobs démarrés`;
    btn.textContent = '⏳ En génération...';

    // Mettre à jour les cards avec les job IDs
    if (data.jobs) {
      data.jobs.forEach(job => {
        const card = document.getElementById(`ugc-job-s${job.scriptIndex}`);
        if (card) {
          const statusEl = card.querySelector('.job-status');
          if (statusEl) {
            statusEl.style.background = 'rgba(240,165,0,0.15)';
            statusEl.style.color = '#f0a500';
            statusEl.textContent = '🔄 Processing...';
            statusEl.setAttribute('data-job-id', job.id);
          }
          card.setAttribute('data-job-id', job.id);
        }
      });
    }

    // Démarrer le polling
    startUGCPolling();

  } catch(e) {
    badge.textContent = '❌ Erreur: ' + e.message;
    btn.disabled = false;
    btn.textContent = '🚀 Lancer les 3 vidéos';
  }
}

function startUGCPolling() {
  if (ugcPollingInterval) clearInterval(ugcPollingInterval);
  ugcPollingInterval = setInterval(refreshUGCStatus, 15000);
}

async function startUGCWebUI() {
  const btn = document.getElementById('btn-ugc-webui');
  const badge = document.getElementById('ugc-status-badge');
  btn.disabled = true;
  btn.textContent = '⏳ Lancement Web UI...';
  badge.textContent = 'Génération via HeyGen Web...';
  try {
    const res = await fetch('/api/ugc/pipeline/start-web', { method: 'POST', headers: {'Content-Type':'application/json'} });
    const data = await res.json();
    if (data.ok) {
      badge.textContent = '🌐 Web UI lancé — résultats dans ~2-3 min';
      btn.textContent = '⏳ En génération...';
      startUGCPolling();
    } else {
      badge.textContent = '❌ ' + (data.error || 'Erreur');
      btn.disabled = false;
      btn.textContent = '🌐 Via Web UI';
    }
  } catch(e) {
    badge.textContent = '❌ ' + e.message;
    btn.disabled = false;
    btn.textContent = '🌐 Via Web UI';
  }
}

async function refreshUGCStatus() {
  try {
    const res = await fetch('/api/ugc/pipeline/status');
    const data = await res.json();

    const badge = document.getElementById('ugc-status-badge');
    badge.textContent = `Processing: ${data.processing} | ✅ ${data.completed} | ❌ ${data.failed}`;

    if (data.jobs) {
      data.jobs.forEach(job => {
        const card = document.getElementById(`ugc-job-s${job.scriptIndex}`);
        if (!card) return;
        const statusEl = card.querySelector('.job-status');
        if (!statusEl) return;

        if (job.status === 'completed') {
          statusEl.style.background = 'rgba(78,205,196,0.15)';
          statusEl.style.color = '#4ECDC4';
          statusEl.textContent = '✅ Complété';

          // Ajouter player/download
          if (job.localPath || job.videoUrl) {
            if (!card.querySelector('.video-player')) {
              const url = job.localPath || job.videoUrl;
              const playerHtml = `<div class="video-player" style="margin-top:10px">
                <video src="${url}" controls style="width:100%;border-radius:6px;max-height:200px"></video>
                <a href="${url}" download style="display:block;text-align:center;margin-top:6px;font-size:11px;color:#4ECDC4">⬇️ Télécharger</a>
              </div>`;
              card.insertAdjacentHTML('beforeend', playerHtml);
            }
          }
        } else if (job.status === 'failed') {
          statusEl.style.background = 'rgba(255,107,107,0.15)';
          statusEl.style.color = '#FF6B6B';
          statusEl.textContent = '❌ Échoué';
        } else if (job.status === 'processing') {
          statusEl.style.background = 'rgba(240,165,0,0.15)';
          statusEl.style.color = '#f0a500';
          statusEl.textContent = '🔄 Processing...';
        }
      });
    }

    // Stop polling si plus rien en cours
    if (data.processing === 0 && ugcPollingInterval) {
      clearInterval(ugcPollingInterval);
      ugcPollingInterval = null;
      const btn = document.getElementById('btn-ugc-start');
      btn.disabled = false;
      btn.textContent = '🚀 Lancer les 3 vidéos';
    }

    // Mettre à jour la grid résultats
    if (data.completed > 0) {
      const resultsRes = await fetch('/api/ugc/pipeline/results');
      const resultsData = await resultsRes.json();
      updateUGCResultsGrid(resultsData.results || []);
    }
  } catch(e) {
    console.warn('[factory] Refresh UGC status error:', e.message);
  }
}

function updateUGCResultsGrid(results) {
  const grid = document.getElementById('ugc-results-grid');
  if (!grid || results.length === 0) return;
  grid.innerHTML = results.map(r => `
    <div style="background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:14px">
      <div style="font-size:11px;color:var(--text2);margin-bottom:4px">Script ${r.scriptIndex}</div>
      <div style="font-weight:600;font-size:13px;margin-bottom:8px">${r.scriptTitle || 'Script UGC'}</div>
      ${r.localPath ? `<video src="${r.localPath}" controls style="width:100%;border-radius:6px;margin-bottom:8px;max-height:180px"></video>
      <a href="${r.localPath}" download style="display:block;text-align:center;font-size:12px;color:#4ECDC4">⬇️ Télécharger</a>` : ''}
    </div>`).join('');
}

// ─── Video Cloner ─────────────────────────────────────────────────────────────
let clonerAnalysis = null;

async function analyzeVideo() {
  const url = document.getElementById('cloner-url').value.trim();
  const transcript = document.getElementById('cloner-transcript').value.trim();
  const status = document.getElementById('cloner-status');

  if (!url && !transcript) {
    status.textContent = '⚠️ Fournir une URL ou un transcript';
    return;
  }

  status.textContent = '🔍 Analyse en cours...';

  try {
    const res = await fetch('/api/cloner/analyze', {
      method: 'POST',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify({ url: url || undefined, transcript: transcript || undefined })
    });
    const data = await res.json();

    if (data.needsTranscript) {
      status.textContent = '⚠️ ' + data.message;
      return;
    }

    if (data.error) {
      status.textContent = '❌ ' + data.error;
      return;
    }

    clonerAnalysis = data.analysis;
    status.textContent = '✅ Analyse complète';

    const pre = document.getElementById('cloner-analysis-pre');
    pre.textContent = JSON.stringify(data.analysis, null, 2);
    document.getElementById('cloner-analysis-result').style.display = 'block';
    document.getElementById('cloner-generate-section').style.display = 'block';

  } catch(e) {
    status.textContent = '❌ Erreur: ' + e.message;
  }
}

async function generateClone() {
  if (!clonerAnalysis) { alert('Lance l\'analyse d\'abord'); return; }
  const gender = document.getElementById('cloner-gender').value;
  const status = document.getElementById('cloner-status');
  status.textContent = '🎬 Génération script + vidéo...';

  try {
    const res = await fetch('/api/cloner/generate', {
      method: 'POST',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify({ analysis: clonerAnalysis, avatarGender: gender })
    });
    const data = await res.json();

    if (data.error && !data.scriptDE) {
      status.textContent = '❌ ' + data.error;
      return;
    }

    document.getElementById('cloner-script-pre').textContent = data.scriptDE || 'Script non disponible';
    document.getElementById('cloner-script-result').style.display = 'block';

    if (data.jobId) {
      document.getElementById('cloner-job-id').textContent = 'Job HeyGen: ' + data.jobId;
      document.getElementById('cloner-video-result').style.display = 'block';
      status.textContent = '✅ Script généré — vidéo en cours (2-5 min)';
    } else {
      status.textContent = '✅ Script généré' + (data.error ? ' (vidéo: ' + data.error + ')' : '');
    }

  } catch(e) {
    status.textContent = '❌ Erreur: ' + e.message;
  }
}

// ─── Image Factory ────────────────────────────────────────────────────────────
async function generateImagePrompt() {
  const angle = document.getElementById('img-angle').value;
  const format = document.getElementById('img-format').value;
  const variant = document.getElementById('img-variant').value;

  const resultDiv = document.getElementById('img-result');
  resultDiv.style.display = 'none';

  try {
    const res = await fetch('/api/image-factory/generate', {
      method: 'POST',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify({ angle, format, variant: parseInt(variant) })
    });
    const data = await res.json();

    if (data.error) { alert('Erreur: ' + data.error); return; }

    document.getElementById('img-prompt-text').textContent =
      (data.midjourneyPrompt || '') + '\n' + (data.negativePrompt || '') + '\n' + (data.parameters || '');
    document.getElementById('img-hook').textContent = data.hookDE || '';
    document.getElementById('img-cta').textContent = data.ctaDE || '';
    resultDiv.style.display = 'block';

  } catch(e) {
    alert('Erreur: ' + e.message);
  }
}

async function generateImageBatch() {
  const btn = document.getElementById('btn-batch');
  btn.disabled = true;
  btn.textContent = '⏳ Génération des 12 prompts...';

  try {
    const res = await fetch('/api/image-factory/batch', { method: 'POST', headers: {'Content-Type':'application/json'} });
    const data = await res.json();

    if (data.error) { alert('Erreur: ' + data.error); return; }

    const grid = document.getElementById('img-batch-grid');
    const cards = document.getElementById('img-batch-cards');
    cards.innerHTML = (data.prompts || []).map((p, i) => `
      <div style="background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:14px">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px">
          <span style="font-size:11px;color:var(--accent);font-weight:600">${p.angleLabel || p.angle} | ${p.format} | V${p.variant}</span>
          <button onclick="copyPrompt(${i})" style="background:rgba(255,255,255,0.06);border:none;color:var(--text2);padding:3px 10px;border-radius:5px;cursor:pointer;font-size:11px">📋</button>
        </div>
        <div id="batch-prompt-${i}" style="font-size:11px;color:#c8f5e0;font-family:monospace;margin-bottom:8px;max-height:80px;overflow:hidden;text-overflow:ellipsis">${p.midjourneyPrompt || p.error || 'N/A'}</div>
        <div style="font-size:11px;color:var(--text2)">${p.hookDE || ''}</div>
      </div>`).join('');

    grid.style.display = 'block';
    // Store for copy
    window.__batchPrompts = data.prompts;

  } catch(e) {
    alert('Erreur: ' + e.message);
  } finally {
    btn.disabled = false;
    btn.textContent = '🎯 Générer Batch 3-2-2 Complet (12 prompts)';
  }
}

function copyPrompt(index) {
  const p = window.__batchPrompts?.[index];
  if (!p) return;
  const text = [p.midjourneyPrompt, p.negativePrompt, p.parameters].filter(Boolean).join('\n');
  navigator.clipboard.writeText(text).then(() => alert('Copié !'));
}

function copyToClipboard(elementId) {
  const el = document.getElementById(elementId);
  if (!el) return;
  navigator.clipboard.writeText(el.textContent).then(() => alert('Copié dans le presse-papiers !'));
}

// ─── Automation ───────────────────────────────────────────────────────────────
async function refreshAutomationStatus() {
  try {
    const res = await fetch('/api/automation/status');
    const data = await res.json();

    document.getElementById('auto-stat-pending').textContent = data.queue?.pending ?? 0;
    document.getElementById('auto-stat-processing').textContent = data.queue?.processing ?? 0;
    document.getElementById('auto-stat-completed').textContent = data.queue?.completed ?? 0;
    document.getElementById('auto-stat-failed').textContent = data.queue?.failed ?? 0;
    document.getElementById('auto-uptime').textContent = data.uptime || '—';

    const badge = document.getElementById('automation-running-badge');
    if (data.isRunning) {
      badge.style.background = 'rgba(78,205,196,0.15)';
      badge.style.color = '#4ECDC4';
      badge.textContent = '● Actif';
    } else {
      badge.style.background = 'rgba(255,107,107,0.15)';
      badge.style.color = '#FF6B6B';
      badge.textContent = '○ Arrêté';
    }

    const logFeed = document.getElementById('auto-log-feed');
    if (data.recentLogs && data.recentLogs.length > 0) {
      const levelColors = { info: '#a0a0ff', warn: '#f0a500', error: '#FF6B6B', success: '#4ECDC4' };
      logFeed.innerHTML = [...data.recentLogs].reverse().map(log => {
        const color = levelColors[log.level] || '#a0a0a0';
        const ts = log.ts ? new Date(log.ts).toLocaleTimeString('fr-FR') : '';
        return `<div style="margin-bottom:4px"><span style="color:#555">${ts}</span> <span style="color:${color}">[${log.level}]</span> ${log.message}</div>`;
      }).join('');
    } else {
      logFeed.innerHTML = '<div style="color:var(--text2)">Aucun log pour l\'instant.</div>';
    }
  } catch(e) {
    console.warn('[factory] Refresh automation error:', e.message);
  }
}

async function runAllPipeline() {
  try {
    const res = await fetch('/api/automation/run-all', { method: 'POST', headers: {'Content-Type':'application/json'} });
    const data = await res.json();
    alert('✅ ' + (data.message || 'Pipeline lancé'));
    refreshAutomationStatus();
  } catch(e) {
    alert('Erreur: ' + e.message);
  }
}

async function clearQueue() {
  if (!confirm('Vider la queue ? Les jobs complétés seront conservés.')) return;
  try {
    await fetch('/api/automation/clear', { method: 'DELETE' });
    refreshAutomationStatus();
  } catch(e) {
    alert('Erreur: ' + e.message);
  }
}

// ─── Intégration dans showPage ────────────────────────────────────────────────
// Patch showPage pour gérer la page factory
(function() {
  const _orig = window.showPage;
  window.showPage = function(name) {
    if (name === 'factory') {
      // Cacher toutes les pages
      document.querySelectorAll('.page').forEach(p => p.style.display = 'none');
      const factoryPage = document.getElementById('page-factory');
      if (factoryPage) factoryPage.style.display = 'block';
      // Mettre à jour nav
      document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
      const navItems = document.querySelectorAll('.nav-item');
      navItems.forEach(n => { if (n.textContent.includes('Factory')) n.classList.add('active'); });
      // Init tab actif
      showFactoryTab('ugc');
      return;
    }
    if (_orig) _orig(name);
  };
})();

// Auto-refresh automation status toutes les 60s quand page factory active
setInterval(() => {
  const factoryPage = document.getElementById('page-factory');
  if (factoryPage && factoryPage.style.display !== 'none') {
    const autoTab = document.getElementById('ftab-automation-content');
    if (autoTab && autoTab.style.display !== 'none') {
      refreshAutomationStatus();
    }
  }
}, 60000);
</script>

<!-- ═══ MISSION REPORT MODAL ═══ -->
<div class="report-modal" id="reportModal">
  <div class="report-header">
    <div class="report-agent-emoji" id="reportEmoji">🤖</div>
    <div class="report-title" id="reportTitle">Mission Report</div>
    <span class="report-layer-badge" id="reportLayerBadge">Layer</span>
    <div style="margin-left:auto;display:flex;gap:8px">
      <button class="btn btn-sm btn-secondary" onclick="copyReportText()">📋 Copier</button>
      <button class="btn btn-sm btn-secondary" onclick="saveReportMd()">💾 .md</button>
      <button class="btn btn-sm btn-danger" onclick="closeReport()">✕ Fermer</button>
    </div>
  </div>
  <div class="report-body">
    <div class="report-content" id="reportContent"></div>
    <div class="report-visuals" id="reportVisuals"></div>
  </div>
</div>

</body>
</html>
