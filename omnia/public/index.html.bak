  }
};

// ─── STATE ──────────────────────────────────────────────────
let currentPrompt = '';
let pollIntervals = {};

// ─── UTILS ──────────────────────────────────────────────────
const api = async (url, opts = {}) => {
  const res = await fetch(url, {
    headers: { 'Content-Type': 'application/json' },
    ...opts,
    body: opts.body ? JSON.stringify(opts.body) : undefined
  });
  return res.json();
};

const saveKey = (type, val) => {
  localStorage.setItem(`omnia_key_${type}`, val);
};
const getKey = (type) => localStorage.getItem(`omnia_key_${type}`) || '';

// ─── NAVIGATION ─────────────────────────────────────────────
function showPage(name) {
  // Rediriger les 4 outils créatifs vers la Creation Layer dans Agents
  const creationPanels = ['multiscene', 'hookbank', 'batchgen', 'library'];
  if (creationPanels.includes(name)) {
    showPage('agents');
    showAgentsLayer('creation');
    showCreationPanel(name);
    return;
  }
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  document.getElementById(`page-${name}`)?.classList.add('active');
  const navItems = document.querySelectorAll('.nav-item');
  navItems.forEach(n => {
    if (n.getAttribute('onclick')?.includes(name)) n.classList.add('active');
  });
  if (name === 'characters') loadCharacterLibrary();
  if (name === 'library') refreshLibrary();
  if (name === 'video') { loadCharacterSelects(); updateVidCredits(); }
  if (name === 'prompt') loadCharacterSelects();
  if (name === 'dashboard') loadDashboard();
  if (name === 'settings') loadSettingsKeys();
  if (name === 'hookbank') loadHookBank();
  if (name === 'batchgen') { loadCharacterSelects(); refreshBatchJobs(); const ce = document.getElementById('batchCredits'); const cd = document.getElementById('creditsDisplay'); if(ce && cd) ce.textContent = cd.textContent; }
  if (name === 'voiceover') refreshVoiceovers();
  if (name === 'broll') { loadBrollTemplates(); refreshBrolls(); }
  if (name === 'cinematic') refreshCinematics();
  if (name === 'multiscene') { loadAvatarsList(); loadStudioProjects(); updateSceneCards(); updateClipCost(); syncDurationOptions(); loadCharacterSelects(); checkPendingJob(); }
}

function switchDocTab(provider) {
  // Tabs nav
  document.querySelectorAll('#page-apidocs .tab').forEach(t => t.classList.remove('active'));
  const tabs = document.querySelectorAll('#page-apidocs .tab');
  const idx = ['kie','higgsfield','heygen'].indexOf(provider);
  if (tabs[idx]) tabs[idx].classList.add('active');
  // Panes
  document.querySelectorAll('#page-apidocs .tab-pane').forEach(p => p.classList.remove('active'));
  const pane = document.getElementById(`doctab-${provider}`);
  if (pane) pane.classList.add('active');
}

function switchTab(group, tab) {
  const prefix = `${group}-`;
  document.querySelectorAll(`[id^="${prefix}"]`).forEach(el => el.classList.remove('active'));
  document.getElementById(`${prefix}${tab}`)?.classList.add('active');
  const tabs = document.querySelectorAll('.tab');
  tabs.forEach(t => {
    if (t.getAttribute('onclick')?.includes(`'${group}', '${tab}'`)) t.classList.add('active');
    else if (t.getAttribute('onclick')?.includes(`"${group}"`)) t.classList.remove('active');
  });
  // Re-select tabs in the right group
  const allTabs = document.querySelectorAll('.tabs');
}

// ─── CREDITS ────────────────────────────────────────────────
async function loadCredits() {
  try {
    const data = await api('/api/credits');
    const c = data.credits || 0;
    document.getElementById('creditsDisplay').textContent = Math.round(c).toLocaleString();
    document.getElementById('creditsVideos').textContent = Math.floor(c / 40);
    const vidEl = document.getElementById('vidCredits');
    if (vidEl) vidEl.textContent = Math.round(c).toLocaleString();
  } catch(e) {}
}

function updateVidCredits() { loadCredits(); }

// ─── DASHBOARD ──────────────────────────────────────────────
async function loadDashboard() {
  try {
    const chars = await api('/api/characters');
    document.getElementById('dash-chars').textContent = chars.length;
    const vids = await api('/api/videos');
    document.getElementById('dash-videos').textContent = vids.length;
  } catch(e) {}
}

// ─── CHARACTERS ─────────────────────────────────────────────
async function loadCharacterLibrary() {
  const chars = await api('/api/characters');
  const grid = document.getElementById('charLibrary');
  const empty = document.getElementById('charEmpty');
  if (!chars.length) { grid.innerHTML = ''; empty.style.display = 'block'; return; }
  empty.style.display = 'none';
  const avatarEmojis = { 'SA-02':'😫','SA-01':'👩','SA-04':'💼','SA-09':'👨','SA-03':'🏃','SA-14':'🧘','SA-08':'🔬','SA-11':'📚' };
  grid.innerHTML = chars.map(c => `
    <div class="char-card" id="char-${c.id}">
      <span class="char-del" onclick="deleteChar('${c.id}')">🗑️</span>
      <div class="char-avatar">${avatarEmojis[c.avatar] || '👤'}</div>
      <div class="char-name">${c.name}</div>
      <div class="char-id">ID: ${c.character_id}</div>
      <div style="margin-top:8px"><span class="badge badge-done">${c.avatar}</span></div>
      <div style="font-size:11px;color:var(--text2);margin-top:4px">${c.created_at?.slice(0,10) || ''}</div>
    </div>
  `).join('');
}

async function createCharacter() {
  const name = document.getElementById('charName').value.trim();
  const avatar = document.getElementById('charAvatar').value;
  const desc = document.getElementById('charDesc').value.trim();
  const fileUrl = document.getElementById('charVideoUrl').value.trim();
  const fileInput = document.getElementById('charVideoFile');
  const safety = document.getElementById('charSafety').value.trim();

  if (!name) return alert('Nom requis');
  if (!fileUrl && !fileInput.files.length) return alert('Vidéo de référence requise (URL ou fichier)');

  const btn = document.getElementById('btnCreateChar');
  btn.disabled = true; btn.innerHTML = '<span class="spinner"></span> Upload en cours...';

  const statusDiv = document.getElementById('charStatus');
  const statusContent = document.getElementById('charStatusContent');
  statusDiv.style.display = 'block';
  statusContent.innerHTML = '<div class="alert alert-info">📤 Upload de la vidéo vers kie.ai...</div>';

  try {
    let uploadResult;
    if (fileUrl) {
      uploadResult = await api('/api/characters/upload', { method: 'POST', body: { file_url: fileUrl } });
    } else {
      const file = fileInput.files[0];
      const reader = new FileReader();
      const base64 = await new Promise(r => { reader.onload = e => r(e.target.result.split(',')[1]); reader.readAsDataURL(file); });
      uploadResult = await api('/api/characters/upload', { method: 'POST', body: {
        file_base64: base64, filename: file.name, mime_type: file.type
      }});
    }

    if (uploadResult.code !== 200) throw new Error(uploadResult.msg || 'Upload échoué');

    const charFileUrl = uploadResult.data?.url || uploadResult.data?.file_url;
    statusContent.innerHTML = `<div class="alert alert-success">✅ Upload OK. Création du personnage Sora 2...</div>`;

    btn.innerHTML = '<span class="spinner"></span> Création en cours...';

    const createResult = await api('/api/characters/create', { method: 'POST', body: {
      character_file_url: charFileUrl,
      character_prompt: desc,
      safety_instruction: safety || undefined
    }});

    if (createResult.code !== 200) throw new Error(createResult.msg || 'Création échouée');

    const taskId = createResult.data?.task_id;
    statusContent.innerHTML = `<div class="alert alert-info">⏳ Tâche créée (ID: ${taskId}). Polling...</div>`;

    // Poll jusqu'au succès
    await pollCharacter(taskId, name, avatar, desc, statusContent);

  } catch(e) {
    statusContent.innerHTML = `<div class="alert alert-error">❌ Erreur: ${e.message}</div>`;
    btn.disabled = false; btn.innerHTML = '🎭 Créer le personnage Sora 2';
  }
}

async function pollCharacter(taskId, name, avatar, desc, statusEl) {
  return new Promise((resolve) => {
    const interval = setInterval(async () => {
      try {
        const res = await api(`/api/task/${taskId}`);
        const state = res.data?.state;

        if (state === 'success') {
          clearInterval(interval);
          const resultJson = res.data.resultJson ? JSON.parse(res.data.resultJson) : {};
          const characterId = resultJson.character_id || taskId;

          // Sauvegarder
          await api('/api/characters/save', { method: 'POST', body: {
            name, avatar, character_id: characterId, description: desc, task_id: taskId
          }});

          statusEl.innerHTML = `
            <div class="alert alert-success">
              ✅ Personnage créé avec succès !<br>
              <strong>character_id:</strong> <code>${characterId}</code><br>
              Utilisable dans le Prompt Builder et Video Generator.
            </div>`;

          document.getElementById('btnCreateChar').disabled = false;
          document.getElementById('btnCreateChar').innerHTML = '🎭 Créer le personnage Sora 2';
          loadCharacterSelects();
          resolve(characterId);
        } else if (state === 'failed') {
          clearInterval(interval);
          statusEl.innerHTML = `<div class="alert alert-error">❌ Création échouée: ${res.data?.failReason || 'Erreur inconnue'}</div>`;
          document.getElementById('btnCreateChar').disabled = false;
          document.getElementById('btnCreateChar').innerHTML = '🎭 Créer le personnage Sora 2';
          resolve(null);
        } else {
          statusEl.innerHTML = `<div class="alert alert-info">⏳ Statut: ${state || 'processing'}... (polling toutes les 10s)</div>`;
        }
      } catch(e) {}
    }, 10000);
  });
}

async function deleteChar(id) {
  if (!confirm('Supprimer ce personnage ?')) return;
  await api(`/api/characters/${id}`, { method: 'DELETE' });
  loadCharacterLibrary();
  loadCharacterSelects();
}

async function saveManualChar() {
  const name = document.getElementById('manCharName').value.trim();
  const avatar = document.getElementById('manCharAvatar').value;
  const character_id = document.getElementById('manCharId').value.trim();
  const description = document.getElementById('manCharDesc').value.trim();
  const msg = document.getElementById('manCharMsg');

  if (!name || !character_id) { msg.innerHTML = '<div class="alert alert-error">Nom et character_id requis</div>'; return; }

  const res = await api('/api/characters/save', { method: 'POST', body: { name, avatar, character_id, description }});
  if (res.success) {
    msg.innerHTML = `<div class="alert alert-success">✅ Personnage "${name}" sauvegardé !</div>`;
    loadCharacterSelects();
  } else {
    msg.innerHTML = `<div class="alert alert-error">❌ ${res.error}</div>`;
  }
}

async function loadCharacterSelects() {
  const chars = await api('/api/characters');
  const opts = ['<option value="">Aucun</option>', ...chars.map(c =>
    `<option value="${c.character_id}">${c.name} (${c.avatar})</option>`)].join('');
  ['promptCharacter', 'vidCharacter', 'clipCharacter'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.innerHTML = opts;
  });
}

// ─── PROMPT BUILDER ─────────────────────────────────────────
function loadScript(key) {
  const s = SCRIPTS[key];
  if (!s) return;
  document.getElementById('promptScript').value = s.text;
  document.getElementById('promptAvatar').value = s.avatar;
  document.querySelectorAll('.script-item').forEach(el => el.classList.remove('selected'));
  event.currentTarget.classList.add('selected');
}

async function generatePrompt() {
  const script = document.getElementById('promptScript').value.trim();
  const avatar = document.getElementById('promptAvatar').value;
  const character_id = document.getElementById('promptCharacter').value;
  if (!script) return alert('Script requis');

  const btn = document.getElementById('btnGenPrompt');
  const out = document.getElementById('promptOutput');
  btn.disabled = true; btn.innerHTML = '<span class="spinner"></span> Génération...';
  out.textContent = 'Génération du prompt Sora en cours...';

  try {
    const res = await api('/api/prompt/generate', { method: 'POST', body: {
      script, avatar, character_id: character_id || null
    }});

    if (res.error) throw new Error(res.error);
    currentPrompt = res.prompt;
    out.textContent = res.prompt;
    out.style.color = 'var(--text)';
  } catch(e) {
    out.textContent = `Erreur: ${e.message}`;
    out.style.color = 'var(--error)';
  } finally {
    btn.disabled = false; btn.innerHTML = '✨ Générer le prompt Sora';
  }
}

function copyPrompt() {
  const text = document.getElementById('promptOutput').textContent;
  navigator.clipboard.writeText(text);
  const btn = event.currentTarget;
  btn.textContent = '✅ Copié!';
  setTimeout(() => btn.textContent = '📋 Copier', 2000);
}

function sendToVideoGen() {
  // Legacy: redirect to Studio Clip UGC tab
  showPage('multiscene');
  showStudioTab('ugc');
}

// ─── VIDEO GENERATOR ────────────────────────────────────────
async function generateVideo() {
  const prompt = document.getElementById('vidPrompt').value.trim();
  const character_id = document.getElementById('vidCharacter').value;
  const name = document.getElementById('vidName').value.trim() || `Video_${Date.now()}`;
  const avatar = document.getElementById('vidAvatar').value;
  const duration = parseInt(document.getElementById('vidDuration').value);
  const resolution = document.getElementById('vidResolution').value;

  if (!prompt) return alert('Prompt requis');

  const btn = document.getElementById('btnGenVideo');
  const status = document.getElementById('vidStatus');
  btn.disabled = true; btn.innerHTML = '<span class="spinner"></span> Envoi à kie.ai...';
  status.innerHTML = '<div class="alert alert-info">⏳ Envoi de la tâche à kie.ai Sora 2...</div>';

  try {
    const res = await api('/api/video/generate', { method: 'POST', body: {
      prompt, character_id: character_id || null, name, avatar, duration, resolution,
      script_ref: name
    }});

    if (res.code !== 200) throw new Error(res.msg || 'Erreur génération');

    const taskId = res.data?.task_id;
    status.innerHTML = `
      <div class="alert alert-success">
        ✅ Tâche créée !<br>
        Task ID: <code>${taskId}</code><br>
        Polling automatique toutes les 15 secondes...
      </div>`;

    // Update queue
    addToQueue(taskId, name);

    // Start polling
    startPolling(taskId);

    // Reload credits
    setTimeout(loadCredits, 3000);

  } catch(e) {
    status.innerHTML = `<div class="alert alert-error">❌ ${e.message}</div>`;
  } finally {
    btn.disabled = false; btn.innerHTML = '🚀 Générer la vidéo (Sora 2)';
  }
}

let queueItems = [];
function addToQueue(taskId, name) {
  queueItems.unshift({ taskId, name, status: 'processing', started: new Date().toLocaleTimeString() });
  renderQueue();
}
function renderQueue() {
  const el = document.getElementById('vidQueue');
  if (!queueItems.length) { el.innerHTML = '<div style="color:var(--text2);font-size:13px">Aucune vidéo en cours...</div>'; return; }
  el.innerHTML = queueItems.slice(0, 5).map(q => `
    <div style="display:flex;align-items:center;gap:8px;padding:8px;background:var(--surface2);border-radius:6px;margin-bottom:6px;font-size:12px">
      <span>${q.status === 'done' ? '✅' : q.status === 'error' ? '❌' : '⏳'}</span>
      <div style="flex:1">
        <div style="font-weight:600">${q.name}</div>
        <div style="color:var(--text2)">${q.taskId.slice(0,12)}... · ${q.started}</div>
      </div>
      <span class="badge badge-${q.status === 'done' ? 'done' : q.status === 'error' ? 'error' : 'processing'}">${q.status}</span>
    </div>
  `).join('');
}

function startPolling(taskId) {
  if (pollIntervals[taskId]) return;
  pollIntervals[taskId] = setInterval(async () => {
    try {
      const res = await api(`/api/video/status/${taskId}`);
      const state = res.data?.state;
      const qItem = queueItems.find(q => q.taskId === taskId);

      if (state === 'success') {
        clearInterval(pollIntervals[taskId]);
        delete pollIntervals[taskId];
        if (qItem) qItem.status = 'done';
        renderQueue();
        document.getElementById('vidStatus').innerHTML = `
          <div class="alert alert-success">✅ Vidéo prête ! Va dans la Video Library pour la télécharger.</div>`;
      } else if (state === 'failed') {
        clearInterval(pollIntervals[taskId]);
        delete pollIntervals[taskId];
        if (qItem) qItem.status = 'error';
        renderQueue();
      }
    } catch(e) {}
  }, 15000);
}

// ─── VIDEO LIBRARY ──────────────────────────────────────────
let libAutoRefreshInterval = null;

async function refreshLibrary() {
  const allVideos = await api('/api/videos');
  const filterBatch = document.getElementById('libFilterBatch')?.value || '';
  const filterStatus = document.getElementById('libFilterStatus')?.value || '';

  const videos = allVideos.filter(v =>
    (!filterBatch || v.batch_id === filterBatch) &&
    (!filterStatus || v.status === filterStatus)
  );

  // Stats
  const done = allVideos.filter(v => v.status === 'done').length;
  const processing = allVideos.filter(v => v.status === 'processing').length;
  document.getElementById('libStatTotal').textContent = allVideos.length;
  document.getElementById('libStatDone').textContent = done;
  document.getElementById('libStatProcessing').textContent = processing;
  document.getElementById('libCount').textContent = videos.length;

  // Crédits
  api('/api/credits').then(c => {
    const el = document.getElementById('libStatCredits');
    if (el && c.credits != null) el.textContent = c.credits.toLocaleString();
  }).catch(() => {});

  const grid = document.getElementById('libGrid');
  const empty = document.getElementById('libEmpty');

  if (!videos.length) {
    grid.innerHTML = '';
    empty.style.display = 'block';
    // Stop auto-refresh if nothing processing
    if (!processing) stopLibAutoRefresh();
    return;
  }
  empty.style.display = 'none';

  // Helper : URL vidéo (proxy si externe, direct si local)
  function videoSrc(url) {
    if (!url) return '';
    if (url.startsWith('/downloads/') || url.startsWith('blob:') || url.startsWith('http://localhost')) return url;
    return `/api/videos/stream?url=${encodeURIComponent(url)}`;
  }

  // Stocker les données vidéos dans un map global pour éviter les problèmes d'escape dans onclick
  window._videoData = {};
  videos.forEach(v => { window._videoData[v.id] = v; });

  grid.innerHTML = videos.map(v => {
    const isDone = v.status === 'done';
    const batchLabel = v.batch_id ? v.batch_id.replace('batch', 'B') : '';
    const dateLabel = v.created_at ? new Date(v.created_at).toLocaleString('fr-FR', { day:'2-digit', month:'2-digit', hour:'2-digit', minute:'2-digit' }) : '';
    const creativeName = v.name?.replace(v.batch_id ? v.batch_id + '_' : '', '') || v.name || '—';
    const src = videoSrc(v.result_url);
    const thumb = v.thumbnail || '';

    return `
    <div class="video-card ${isDone ? 'done' : ''}" id="vcard-${v.id}" data-vid-id="${v.id}">
      <div class="video-preview-wrap ${isDone ? 'clickable-preview' : ''}">
        ${isDone ? `
          <video
            id="vid-${v.id}"
            src="${src}"
            ${thumb ? `poster="${thumb}"` : ''}
            muted loop preload="metadata"
            playsinline
            style="width:100%;height:100%;object-fit:cover;display:block;cursor:pointer"
            onclick="window._openVideoById('${v.id}')"
          ></video>
          <div class="play-overlay" onclick="window._openVideoById('${v.id}')">
            <div class="play-btn-circle">▶</div>
          </div>
          <div class="video-info-overlay">
            <div class="video-title-overlay">${creativeName}</div>
            <div class="video-badges">
              ${batchLabel ? `<span class="vbadge">${batchLabel}</span>` : ''}
              ${v.avatar ? `<span class="vbadge">${v.avatar}</span>` : ''}
              <span class="vbadge vbadge-done">✓ Prête</span>
            </div>
          </div>
        ` : `
          <div class="video-processing-bg">
            <div class="processing-pulse"></div>
            <div class="processing-text">Génération Sora 2…</div>
          </div>
          <div class="video-info-overlay">
            <div class="video-title-overlay">${creativeName}</div>
            <div class="video-badges">
              ${batchLabel ? `<span class="vbadge">${batchLabel}</span>` : ''}
              ${v.avatar ? `<span class="vbadge">${v.avatar}</span>` : ''}
              <span class="vbadge vbadge-processing">⏳ En cours</span>
            </div>
          </div>
        `}
      </div>
      <div class="video-actions-bar">
        ${isDone ? `
          <button class="vact-preview" onclick="window._openVideoById('${v.id}')">▶ Play</button>
          <a href="${v.mp4_url || src}" download="${v.name || 'video'}.mp4" class="vact-download">⬇ DL</a>
        ` : `
          <button class="vact-preview" style="flex:2;opacity:0.5;cursor:default">⏳ En cours…</button>
        `}
        <button class="vact-del" onclick="event.stopPropagation();deleteVideo('${v.id}')">✕</button>
      </div>
    </div>`;
  }).join('');

  // Hover play/pause sur les vidéos inline
  videos.filter(v => v.status === 'done').forEach(v => {
    const vidEl = document.getElementById('vid-' + v.id);
    if (!vidEl) return;
    vidEl.addEventListener('mouseenter', () => { vidEl.play().catch(() => {}); });
    vidEl.addEventListener('mouseleave', () => { vidEl.pause(); vidEl.currentTime = 0; });
  });

  // Auto-refresh si des vidéos sont en cours
  if (processing > 0) startLibAutoRefresh();
  else stopLibAutoRefresh();
}

function startLibAutoRefresh() {
  if (libAutoRefreshInterval) return;
  libAutoRefreshInterval = setInterval(async () => {
    await refreshAllStatuses(true);
  }, 15000);
}

function stopLibAutoRefresh() {
  if (libAutoRefreshInterval) { clearInterval(libAutoRefreshInterval); libAutoRefreshInterval = null; }
}

async function refreshAllStatuses(silent = false) {
  const btn = document.getElementById('btnPollStatus');
  const spinner = document.getElementById('pollSpinner');
  if (!silent && btn) btn.disabled = true;
  if (!silent && spinner) spinner.style.display = 'inline-block';

  try {
    const videos = await api('/api/videos');
    const processing = videos.filter(v => v.status === 'processing' && v.task_id);
    await Promise.all(processing.map(v => api(`/api/video/status/${v.task_id}`)));
    await refreshLibrary();
  } finally {
    if (!silent && btn) btn.disabled = false;
    if (!silent && spinner) spinner.style.display = 'none';
  }
}

// Lightbox
// Ouvre la lightbox à partir du data map (évite tous les problèmes d'escape)
window._openVideoById = function(id) {
  const v = window._videoData && window._videoData[id];
  if (!v || !v.result_url) { console.warn('Video not found:', id); return; }
  // Lecture : WebM si dispo, sinon MP4
  const src = v.result_url.startsWith('/downloads/') || v.result_url.startsWith('http') ? v.result_url : '/api/videos/stream?url=' + encodeURIComponent(v.result_url);
  // Téléchargement : MP4 natif si dispo
  const dlUrl = v.mp4_url || v.result_url;
  const name = v.name || 'Vidéo UGC';
  const avatar = v.avatar || '';
  const date = v.created_at ? new Date(v.created_at).toLocaleString('fr-FR', { day:'2-digit', month:'2-digit', hour:'2-digit', minute:'2-digit' }) : '';
  openLightbox(src, name, avatar, date, dlUrl, v.thumbnail || '');
};

function openLightbox(proxySrc, name, avatar, date, downloadUrl, thumbnail) {
  if (!proxySrc) return;
  const lb  = document.getElementById('lightbox');
  const vid = document.getElementById('lightboxVideo');
  const btn = document.getElementById('lbPlayBtn');

  // Reset état play button
  if (btn) btn.classList.remove('hidden');

  // Poster + source
  vid.pause();
  if (thumbnail) vid.setAttribute('poster', thumbnail);
  else vid.removeAttribute('poster');
  vid.src = proxySrc;
  vid.load();

  // Tenter autoplay (user gesture disponible car on vient d'un clic)
  vid.play().then(() => {
    if (btn) btn.classList.add('hidden');
  }).catch(() => {
    // Autoplay bloqué → play btn visible, user clique dessus
    if (btn) btn.classList.remove('hidden');
  });

  // Métadonnées
  document.getElementById('lbTitle').textContent = name || 'Vidéo UGC';
  document.getElementById('lbMeta').textContent =
    [avatar, date].filter(Boolean).join(' · ') + ' · Sora 2 · 1080p · Meta Ads';
  document.getElementById('lbDownload').href = downloadUrl || proxySrc;
  const tabBtn = document.getElementById('lbOpenTab');
  if (tabBtn) tabBtn.href = proxySrc;

  lb.classList.add('open');
  document.body.style.overflow = 'hidden';
}

function lbTogglePlay() {
  const vid = document.getElementById('lightboxVideo');
  const btn = document.getElementById('lbPlayBtn');
  if (!vid) return;
  if (vid.paused) {
    vid.play().then(() => { if (btn) btn.classList.add('hidden'); }).catch(() => {});
  } else {
    vid.pause();
    if (btn) btn.classList.remove('hidden');
  }
}

function closeLightbox() {
  const lb  = document.getElementById('lightbox');
  const vid = document.getElementById('lightboxVideo');
  lb.classList.remove('open');
  vid.pause();
  vid.src = '';
  vid.removeAttribute('poster');
  document.body.style.overflow = '';
}

function copyUrl(url) {
  navigator.clipboard.writeText(url).then(() => {
    const btn = event.target.closest('button');
    if (btn) { const orig = btn.innerHTML; btn.innerHTML = '✅ Copié !'; setTimeout(() => btn.innerHTML = orig, 2000); }
  });
}

async function deleteVideo(id) {
  if (!confirm('Supprimer cette vidéo ?')) return;
  await api(`/api/videos/${id}`, { method: 'DELETE' });
  refreshLibrary();
}

