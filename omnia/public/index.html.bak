async function updateConsistencyAnchor() {} // no-op — remplacé par onAvatarChange

// Lancer génération 3 variantes
// ── Provider / Model / Cost helpers ────────────────────────────
// durations: null = durée selon script (HeyGen), sinon tableau des valeurs disponibles
const CLIP_MODELS = {
  // kie.ai : n_frames = '10' (~10s) ou '15' (~15s) — seules valeurs API valides
  // Pro = audio + lip-sync garanti + qualité HD · Standard = audio natif Sora 2
  kie: [
    { value: 'sora-2-pro-text-to-video',  label: 'Sora 2 Pro T2V 🗣⭐', creditsPerClip: 100, perSecond: false, durations: [10,15], defaultDur: 15,
      note: '~100 cr/clip · audio natif + lip-sync · qualité HD · recommandé' },
    { value: 'sora-2-text-to-video',      label: 'Sora 2 T2V 🗣',       creditsPerClip: 40,  perSecond: false, durations: [10,15], defaultDur: 15,
      note: '40 cr/clip (≈ $0.20) · audio natif Sora 2 · T2V standard' },
    { value: 'sora-2-pro-image-to-video', label: 'Sora 2 Pro I2V 🖼⭐',  creditsPerClip: 100, perSecond: false, durations: [10,15], defaultDur: 15, i2v: true,
      note: '~100 cr/clip · produit fidèle HD + audio · I2V Pro' },
    { value: 'sora-2-image-to-video',     label: 'Sora 2 I2V 🖼→🎬',    creditsPerClip: 40,  perSecond: false, durations: [10,15], defaultDur: 15, i2v: true,
      note: '40 cr/clip (≈ $0.20) · produit fidèle via image · I2V standard' },
    { value: 'kling-3.0',                 label: 'Kling 3.0 T2V',        creditsPerSec: 40,   perSecond: true,  durations: [5,10],  defaultDur: 5,
      note: '40 cr/s · 5s = 200 cr ($1) · 10s = 400 cr ($2)' }
  ],
  higgsfield: [
    { value: 'higgsfield-ai/soul/standard',           label: 'HiggsSoul Standard (T2V)',     creditsPerClip: null, durations: [5,10], defaultDur: 5,  i2v: false, note: 'T2V · 5-10s max' },
    { value: 'higgsfield-ai/soul/preview',            label: 'HiggsSoul Preview (T2V)',      creditsPerClip: null, durations: [5],    defaultDur: 5,  i2v: false, note: 'T2V rapide · 5s uniquement' },
    { value: 'kling-video/v2.1/pro/image-to-video',  label: 'Kling 2.1 Pro (I2V 🖼→🎬)',  creditsPerClip: null, durations: null,   defaultDur: null, i2v: true,  note: 'Image → Vidéo · Nécessite une image produit' },
    { value: 'higgsfield-ai/dop/preview',             label: 'DoP Cinematic (I2V 🖼→🎬)',   creditsPerClip: null, durations: null,   defaultDur: null, i2v: true,  note: 'Image → Vidéo · Style cinématique' }
  ],
  heygen: [
    { value: 'avatar-v4', label: 'Avatar IV (recommandé)', creditsPerClip: null, durations: null, defaultDur: null,
      note: 'Durée = longueur du script · Qualité maximale' },
    { value: 'avatar-v3', label: 'Avatar III (rapide)',    creditsPerClip: null, durations: null, defaultDur: null,
      note: 'Durée = longueur du script · Génération plus rapide' }
  ]
};

function updateClipModels() {
  const provider = document.getElementById('clipProvider')?.value || 'kie';
  const modelSel = document.getElementById('clipModel');
  if (!modelSel) return;

  // Mettre à jour les modèles dispo
  modelSel.innerHTML = (CLIP_MODELS[provider] || CLIP_MODELS.kie).map(m =>
    `<option value="${m.value}">${m.label}</option>`
  ).join('');

  // Afficher/masquer les contrôles provider-spécifiques
  const kieCtrl   = document.getElementById('clipKieControls');
  const heyCtrl   = document.getElementById('clipHeygenControls');
  const heyBgSec  = document.getElementById('heygenBgSection');
  const visualSec = document.getElementById('clipVisualPromptSection');
  const higgWarn  = document.getElementById('higgsfieldKeyWarning');
  const heyWarn   = document.getElementById('heygenKeyWarning');

  if (kieCtrl)   kieCtrl.style.display   = provider === 'kie' ? 'block' : 'none';
  if (heyCtrl)   heyCtrl.style.display   = provider === 'heygen' ? 'block' : 'none';
  if (heyBgSec)  { heyBgSec.style.display = provider === 'heygen' ? 'block' : 'none'; if (provider === 'heygen') updateHeygenBg(); }
  // Prompt visuel = T2V seulement (kie + higgsfield)
  if (visualSec) visualSec.style.display = provider === 'heygen' ? 'none' : 'block';

  if (higgWarn) higgWarn.style.display = provider === 'higgsfield' ? 'block' : 'none';
  if (heyWarn)  heyWarn.style.display  = 'none'; // géré par loadHeygenAvatarsVoices()

  // ── Bannière capacités provider ───────────────────────────────
  const cap = document.getElementById('providerCapBanner');
  if (cap) {
    const banners = {
      kie:        { bg: 'rgba(50,180,100,0.08)', border: 'rgba(50,180,100,0.3)', color: '#40c878',
                    html: '🔊 <strong>Audio natif</strong> — Sora 2 génère voix + son directement depuis le prompt visuel (pas d\'injection de script).<br>📦 <strong>T2V</strong> = produit décrit dans le prompt · <strong>I2V 🖼</strong> = produit fidèle depuis ton image (recommandé).' },
      higgsfield: { bg: 'rgba(150,100,255,0.1)', border: 'rgba(150,100,255,0.3)', color: '#a070ff',
                    html: '🔇 <strong>Higgsfield T2V</strong> = vidéo silencieuse (pas de speech).<br>🖼 Modèles <strong>I2V (Kling 2.1 Pro / DoP)</strong> : sélectionne une image produit → rendu fidèle au vrai packaging.<br>👉 Pour voix + parole → utilise <strong>kie.ai</strong> ou <strong>HeyGen</strong>.' },
      heygen:     { bg: 'rgba(50,200,100,0.1)',  border: 'rgba(50,200,100,0.3)',  color: '#32c864',
                    html: '🗣 <strong>HeyGen</strong> fait parler l\'avatar avec le script DE (TTS inclus).<br>✅ Usage correct : témoignage, UGC talking-head, CTA.<br>⚠️ Le produit doit être tenu par l\'avatar ou en fond — le modèle ne génère pas de B-Roll.' },
    };
    const b = banners[provider];
    if (b) {
      cap.style.background  = b.bg;
      cap.style.border      = `1px solid ${b.border}`;
      cap.style.color       = b.color;
      cap.innerHTML         = b.html;
      cap.style.display     = 'block';
    }
  }

  // Sync durées selon le modèle sélectionné
  syncDurationOptions();

  // HeyGen → charger avatars/voix
  if (provider === 'heygen') loadHeygenAvatarsVoices();

  updateClipCost();
}

function onModelChange() {
  syncDurationOptions();
  updateClipCost();
  scheduleVisualPromptGen();
}

function onSceneTypeChange() {
  scheduleVisualPromptGen();
  // Scènes "parlantes" → banner suggestion HeyGen si provider != heygen
  const scene    = document.getElementById('clipSceneType')?.value || '';
  const provider = document.getElementById('clipProvider')?.value  || 'kie';
  const talkingScenes = ['Testimonial', 'CTA', 'Hook', 'Problem', 'Solution'];
  const cap = document.getElementById('providerCapBanner');
  // Warning uniquement pour Higgsfield T2V (silencieux) — kie.ai supporte speech_text
  if (talkingScenes.includes(scene) && provider === 'higgsfield' && cap) {
    // Ajouter une suggestion inline si pas déjà présente
    if (!cap.innerHTML.includes('⚠️ Cette scène implique')) {
      cap.innerHTML += `<br>⚠️ <strong>Cette scène implique un avatar qui parle</strong> → passe sur <strong>HeyGen</strong> pour que le script soit énoncé.`;
    }
  } else if (cap && cap.innerHTML.includes('⚠️ Cette scène implique')) {
    // Retirer la suggestion si scène B-Roll (silencieuse)
    updateClipModels(); // Re-affiche la bannière propre
  }
}

function syncDurationOptions() {
  const provider = document.getElementById('clipProvider')?.value || 'kie';
  const modelVal = document.getElementById('clipModel')?.value    || 'sora-2-text-to-video';
  const durSel   = document.getElementById('clipDuration');
  const durGroup = durSel?.closest('.form-group');
  if (!durSel) return;

  const models   = CLIP_MODELS[provider] || CLIP_MODELS.kie;
  const modelDef = models.find(m => m.value === modelVal) || models[0];
  const durs     = modelDef?.durations;

  if (!durs) {
    // HeyGen / I2V : durée auto
    const isI2V = modelDef?.i2v;
    durSel.innerHTML = `<option value="auto">${isI2V ? 'Selon le modèle I2V' : 'Selon le script'}</option>`;
    durSel.disabled  = true;
    // Afficher/masquer la section image produit selon I2V
    const imgSection = document.querySelector('#clipVisualPromptSection .border-border, #clipVisualPromptSection [style*="border:1px solid var(--border)"]');
    if (durGroup) {
      const lbl = durGroup.querySelector('label');
      if (lbl) lbl.textContent = isI2V ? 'Durée (I2V)' : 'Durée (auto)';
    }
    // Badge I2V sur la section image
    const imgHeader = document.querySelector('#clipVisualPromptSection [style*="border-bottom"]');
    if (imgHeader && isI2V) {
      imgHeader.style.background = 'rgba(108,99,255,0.1)';
      imgHeader.style.borderColor = 'var(--accent)';
    }
  } else {
    const current = parseInt(durSel.value) || modelDef.defaultDur;
    durSel.disabled = false;
    durSel.innerHTML = durs.map(d =>
      `<option value="${d}" ${d === (durs.includes(current) ? current : modelDef.defaultDur) ? 'selected' : ''}>${d} secondes</option>`
    ).join('');
    if (durGroup) {
      const lbl = durGroup.querySelector('label');
      if (lbl) lbl.textContent = 'Durée';
    }
    // Note modèle sous le select
    let noteEl = durGroup?.querySelector('.model-note');
    if (!noteEl && durGroup) {
      noteEl = document.createElement('small');
      noteEl.className = 'model-note';
      noteEl.style.cssText = 'color:#888;font-size:10px;display:block;margin-top:3px';
      durGroup.appendChild(noteEl);
    }
    if (noteEl) noteEl.textContent = modelDef.note || '';
  }
}

function updateHeygenBg() {
  const val       = document.querySelector('input[name="heygenBg"]:checked')?.value || 'color';
  const colorPick = document.getElementById('bgColorPicker');
  const customUrl = document.getElementById('bgCustomUrl');
  const preview   = document.getElementById('bgPreview');

  if (colorPick) colorPick.style.display = val === 'color'  ? 'flex' : 'none';
  if (customUrl) customUrl.style.display = val === 'custom' ? 'block' : 'none';

  // Preview fond
  if (preview) {
    if (val === 'color') {
      const color = document.getElementById('heygenBgColor')?.value || '#f8f4f0';
      preview.style.background = color;
      preview.innerHTML = '';
    } else if (val === 'nellio') {
      preview.style.background = '#000';
      preview.innerHTML = '<img src="/assets/brand/nellio_16.png" style="height:100%;max-height:100%;object-fit:contain">';
    } else {
      const url = document.getElementById('heygenBgUrl')?.value || '';
      preview.style.background = '#111';
      preview.innerHTML = url ? `<img src="${url}" style="width:100%;height:100%;object-fit:cover" onerror="this.parentNode.innerHTML='<span style=color:#f88>URL invalide</span>'">` : '<span>Entrer une URL</span>';
    }
  }
}

function getHeygenBackground() {
  const val = document.querySelector('input[name="heygenBg"]:checked')?.value || 'color';
  if (val === 'nellio') {
    return { type: 'image', url: window.location.origin + '/assets/brand/nellio_16.png' };
  } else if (val === 'custom') {
    const url = document.getElementById('heygenBgUrl')?.value?.trim();
    return url ? { type: 'image', url } : { type: 'color', value: '#f8f4f0' };
  } else {
    const color = document.getElementById('heygenBgColor')?.value || '#f8f4f0';
    return { type: 'color', value: color };
  }
}

function updateClipCost() {
  const provider   = document.getElementById('clipProvider')?.value      || 'kie';
  const modelVal   = document.getElementById('clipModel')?.value         || 'sora-2-text-to-video';
  const duration   = parseInt(document.getElementById('clipDuration')?.value || '15');
  const numV       = parseInt(document.getElementById('clipNumVariants')?.value || '3');
  const btn        = document.getElementById('clipGenerateBtn');
  if (!btn) return;

  let text = '';
  if (provider === 'higgsfield') {
    text = `Higgsfield · ${numV} génération(s)`;
  } else if (provider === 'heygen') {
    text = `HeyGen · ${numV} génération(s) · durée selon script`;
  } else {
    const modelDef = (CLIP_MODELS.kie || []).find(m => m.value === modelVal);
    if (modelDef?.perSecond) {
      const cr = (modelDef.creditsPerSec || 40) * duration;
      text = `${cr} cr × ${numV} = ${cr * numV} cr (Kling ${duration}s/clip)`;
    } else {
      const cr = modelDef?.creditsPerClip || 40;
      text = `${cr} cr × ${numV} = ${cr * numV} cr (~$${((cr * numV) / 200).toFixed(2)})`;
    }
  }

  btn.innerHTML = `🎬 Générer ${numV} variante${numV > 1 ? 's' : ''} <span id="clipCostLabel" style="opacity:0.6;font-size:12px">(${text})</span>`;
}

// loadHeygenAvatarsVoices() définie dans le bloc <script> HeyGen en bas de page

// ── Traduction DE → FR (legacy — remplacée par generateClipPrompt) ──────────
// clearClipTranslation / translateClipScript définis comme stubs dans le bloc generateClipPrompt ci-dessus

async function generateClipVariants() {
  const btn = document.getElementById('clipGenerateBtn'); // défini EN PREMIER (utilisé dans le bloc upload)
  const avatarId = document.getElementById('clipAvatarSelect')?.value;
  const sceneType = document.getElementById('clipSceneType')?.value;
  const scriptDE = document.getElementById('clipScript')?.value;
  const visualPrompt = document.getElementById('clipVisualPrompt')?.value;
  const provider = document.getElementById('clipProvider')?.value || 'kie';
  const model = document.getElementById('clipModel')?.value || 'sora-2-text-to-video';
  const duration = parseInt(document.getElementById('clipDuration')?.value || '15');
  const character_id     = document.getElementById('clipCharacter')?.value    || null;
  const heygen_avatar_id = document.getElementById('clipHeygenAvatar')?.value || null;
  const heygen_voice_id  = document.getElementById('clipHeygenVoice')?.value  || null;
  const heygen_bg        = provider === 'heygen' ? getHeygenBackground() : null;
  const format           = document.getElementById('clipFormat')?.value       || '9:16';
  const numVariants      = parseInt(document.getElementById('clipNumVariants')?.value || '3');

  // ── Pre-flight checks ─────────────────────────────────────────
  const isI2V = (provider === 'higgsfield' && (model.includes('image-to-video') || model.includes('dop')))
             || (provider === 'kie'         && model.includes('image-to-video'));
  // Higgsfield T2V = silencieux → avertir si scène parlante
  const higgsSilent = provider === 'higgsfield' && !isI2V;
  const talkingScenes = ['Testimonial', 'CTA', 'Hook', 'Problem', 'Solution'];
  if (higgsSilent && talkingScenes.includes(sceneType)) {
    const go = confirm(
      `⚠️ Higgsfield génère des vidéos SILENCIEUSES.\n\n` +
      `Le script ne sera PAS prononcé.\n\n` +
      `→ Pour un avatar qui parle : utilise kie.ai (Sora 2) ou HeyGen.\n\n` +
      `Continuer quand même ?`
    );
    if (!go) return;
  }

  if (isI2V && !_selectedImageUrl && !_selectedImageLocal && !_selectedImageBase64) {
    alert('⚠️ Modèle I2V sélectionné mais aucune image produit fournie.\n\nSélectionne une image dans "🖼 Image produit" pour que le produit soit fidèle.');
    return;
  }

  // Résoudre l'URL publique de l'image
  let image_url = _selectedImageUrl || null;
  if (!image_url && (_selectedImageBase64 || _selectedImageLocal)) {
    try {
      btn.innerHTML = '<span class="spinner"></span> Upload image...';
      const body = _selectedImageLocal
        ? { localAsset: _selectedImageLocal }
        : (() => {
            const mimeMatch = _selectedImageBase64.match(/^data:([^;]+);/);
            const mimeType  = mimeMatch ? mimeMatch[1] : 'image/png';
            const ext       = mimeType.split('/')[1] || 'png';
            return { base64: _selectedImageBase64, filename: `upload_${Date.now()}.${ext}`, mimeType };
          })();
      const up = await api('/api/image/host', { method: 'POST', body });
      if (up.url) {
        image_url = up.url;
        _selectedImageUrl = up.url;
        const urlEl = document.getElementById('imgSelectedUrl');
        if (urlEl) urlEl.textContent = up.url;
      }
    } catch(e) {
      console.warn('Image upload failed:', e.message);
      if (isI2V) { alert('⚠️ Upload de l\'image échoué.\n\n' + e.message + '\n\nVérifie ta connexion ou utilise une URL directe.'); return; }
    }
  }
  // I2V sans image_url = erreur garantie côté API
  if (isI2V && !image_url) {
    alert('⚠️ Image produit requise pour le modèle I2V mais aucune URL publique disponible.\n\nSélectionne une image dans l\'onglet 🔗 URL ou 📤 Upload.');
    return;
  }

  if (!visualPrompt) { alert('⚡ Clique "Générer" pour créer le prompt UGC avant de lancer les variantes.'); return; }
  if (provider === 'heygen' && !scriptDE) { alert('Génère le prompt UGC d\'abord — le script DE sera utilisé par HeyGen TTS.'); return; }

  const providerLabel = provider === 'higgsfield' ? 'Higgsfield' : provider === 'heygen' ? 'HeyGen' : 'Sora 2';
  // btn déjà défini au début de la fonction
  btn.disabled = true;
  btn.innerHTML = `<span class="spinner"></span> Envoi à ${providerLabel}...`;

  document.getElementById('variantSection').style.display = 'block';
  document.getElementById('variantPollStatus').style.display = 'block';

  try {
    const r = await fetch('/api/clip/generate-variants', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({ avatarId, sceneType, scriptDE, prompt: visualPrompt, visualPrompt, projectId: currentProjectId, provider, model, duration, character_id, heygen_avatar_id, heygen_voice_id, heygen_bg, format, numVariants, image_url })
    });
    const d = await r.json();
    if (!d.success) throw new Error(d.error || 'Erreur inconnue');
    const jobId = d.variantJobId;
    currentVariantJobId = jobId;
    // Persister dans localStorage pour survie au refresh
    localStorage.setItem('omnia_last_job', JSON.stringify({
      jobId, numVariants, format, provider, model,
      createdAt: new Date().toISOString()
    }));

    // Format + aspect
    const fmt       = format || '9:16';
    const aspectMap = { '9:16': '9/16', '16:9': '16/9', '1:1': '1/1', '4:5': '4/5' };
    const aspectCSS = aspectMap[fmt] || '9/16';

    // Créer un groupe de job indépendant (pas de clear — multi-génération)
    const subId   = document.getElementById('clipSubAvatar')?.options[document.getElementById('clipSubAvatar')?.selectedIndex]?.text || avatarId;
    const angleTxt = document.getElementById('clipAngle')?.options[document.getElementById('clipAngle')?.selectedIndex]?.text?.split('·')[0]?.trim() || '';
    createJobGroup(jobId, numVariants, aspectCSS, { sceneType, provider, model, subId, angleTxt, fmt });
    startJobPolling(jobId, numVariants, aspectCSS);

  } catch(e) {
    alert('Erreur génération: ' + e.message);
  } finally {
    btn.disabled = false;
    updateClipCost();
  }
}

// ── Voiceover sur variante ────────────────────────────────────
async function addVoiceover(variantIndex) {
  const scriptDE = document.getElementById('clipScript')?.value?.trim();
  if (!scriptDE) { alert('Le script DE est vide.'); return; }

  const btn   = document.getElementById(`variant-voice-${variantIndex}`);
  const label = document.getElementById(`variant-label-${variantIndex}`);
  if (!currentVariantJobId) return;

  if (btn) { btn.disabled = true; btn.textContent = '⏳'; }
  if (label) label.textContent = '🎙 Génération voix...';

  try {
    const d = await api('/api/clip/add-voiceover', {
      method: 'POST',
      body: { variantJobId: currentVariantJobId, variantIndex, scriptDE, voice: 'de_female_warm' }
    });
    if (!d.success) throw new Error(d.error);
    // Lancer le polling voiceover
    pollVoiceover(variantIndex, currentVariantJobId);
  } catch(e) {
    if (btn) { btn.disabled = false; btn.textContent = '🎙'; }
    if (label) label.textContent = `❌ ${e.message}`;
  }
}

function pollVoiceover(variantIndex, jobId) {
  const interval = setInterval(async () => {
    try {
      const d = await api(`/api/clip/voiceover-status/${jobId}/${variantIndex}`);
      const label = document.getElementById(`variant-label-${variantIndex}`);
      const btn   = document.getElementById(`variant-voice-${variantIndex}`);
      const vid   = document.getElementById(`variant-video-${variantIndex}`);

      if (d.status === 'done' && d.mergedUrl) {
        clearInterval(interval);
        // Remplacer la vidéo par la version avec voix
        if (vid) { vid.src = d.mergedUrl; vid.load(); }
        if (label) label.innerHTML = '✅ Voix ajoutée <span style="color:#4ade80">🎙</span>';
        if (btn) { btn.disabled = false; btn.textContent = '🔄🎙'; btn.title = 'Re-générer la voix'; }
      } else {
        if (label) label.textContent = '🎙 Merge audio...';
      }
    } catch(e) {
      clearInterval(interval);
      const label = document.getElementById(`variant-label-${variantIndex}`);
      if (label) label.textContent = '❌ Erreur voix';
    }
  }, 5000);
}

// ── Lightbox ──────────────────────────────────────────────────
function openLightbox(src) {
  const lb  = document.getElementById('variantLightbox');
  const vid = document.getElementById('lbVideo');
  const lbOpenBtn = document.getElementById('lbOpenTab');
  if (!lb || !vid) return;
  vid.muted  = false;
  vid.volume = 1.0;
  vid.src    = src;
  if (lbOpenBtn) lbOpenBtn.onclick = () => window.open(src, '_blank');
  lb.style.display        = 'flex';
  document.body.style.overflow = 'hidden';
  // Tenter play() dans le user gesture — Chrome peut le bloquer malgré tout
  vid.play().catch(() => {
    vid.muted = true;
    vid.play().then(() => {
      setTimeout(() => { vid.muted = false; }, 100);
    }).catch(() => {});
  });
}
function closeLightbox() {
  const lb  = document.getElementById('variantLightbox');
  const vid = document.getElementById('lbVideo');
  if (lb) lb.style.display = 'none';
  if (vid) { vid.pause(); vid.src = ''; }
  document.body.style.overflow = '';
}
document.addEventListener('keydown', e => { if (e.key === 'Escape') closeLightbox(); });

// ── Helper rendu cartes (utilisé génération + restauration) ───
// Crée un groupe job complet et l'AJOUTE en tête (sans effacer les précédents)
function createJobGroup(jobId, numVariants, aspectCSS, meta) {
  const wMap = { '9/16': 140, '16/9': 240, '1/1': 160, '4/5': 155 };
  const cardW = wMap[aspectCSS] || 140;
  const cards = Array.from({length: numVariants}, (_, i) => `
    <div class="variant-card" id="variant-card-${jobId}-${i}"
         style="background:rgba(255,255,255,0.05);border-radius:10px;overflow:hidden;border:2px solid transparent;
                width:${cardW}px;flex-shrink:0;transition:border-color .15s">
      <div style="position:relative;aspect-ratio:${aspectCSS};background:#111;overflow:hidden;cursor:pointer"
           onclick="(function(){const v=document.getElementById('variant-video-${jobId}-${i}');if(v&&v.src)openLightbox(v.src);})()">
        <div class="spinner" style="position:absolute;inset:0;margin:auto;width:28px;height:28px;border-width:2px" id="variant-loading-${jobId}-${i}"></div>
        <video id="variant-video-${jobId}-${i}" style="width:100%;height:100%;object-fit:cover;display:none;position:absolute;inset:0" loop muted playsinline
               onmouseenter="this.play()" onmouseleave="this.pause()"></video>
        <div id="variant-overlay-${jobId}-${i}" style="display:none;position:absolute;inset:0;pointer-events:none">
          <button onclick="event.stopPropagation();(function(){const v=document.getElementById('variant-video-${jobId}-${i}');if(v&&v.src)openLightbox(v.src);})()"
                  style="pointer-events:auto;position:absolute;top:5px;right:5px;background:rgba(0,0,0,0.6);border:none;color:#fff;
                         font-size:13px;padding:3px 7px;border-radius:4px;cursor:pointer;line-height:1">⛶</button>
          <button onclick="event.stopPropagation();(function(){const v=document.getElementById('variant-video-${jobId}-${i}');if(v&&v.src)window.open(v.src,'_blank');})()"
                  style="pointer-events:auto;position:absolute;bottom:5px;right:5px;background:rgba(50,200,100,0.75);border:none;color:#fff;
                         font-size:11px;font-weight:600;padding:3px 7px;border-radius:4px;cursor:pointer;line-height:1">🔊 Son</button>
        </div>
      </div>
      <div style="padding:7px 8px;display:flex;gap:4px">
        <button onclick="selectVariantJob(${i},'${jobId}')" class="btn btn-primary"
                style="flex:1;font-size:10px;padding:5px 4px;opacity:0.4" disabled id="variant-select-${jobId}-${i}">✅ Sél.</button>
        <a id="variant-dl-${jobId}-${i}" class="btn btn-secondary"
           style="font-size:11px;padding:5px 7px;display:none;text-decoration:none" title="Télécharger MP4" download>⬇️</a>
        <button onclick="regenerateVariant(0)" class="btn btn-secondary"
                style="font-size:11px;padding:5px 7px" title="Régénérer">🔄</button>
      </div>
      <div style="padding:0 8px 7px;font-size:10px;color:var(--text2)">Variante ${i+1}</div>
    </div>`).join('');

  const group = document.createElement('div');
  group.id = `job-group-${jobId}`;
  group.style.cssText = 'margin-bottom:16px;border:1px solid var(--border);border-radius:10px;overflow:hidden';
  group.innerHTML = `
    <div style="padding:8px 12px;background:rgba(108,99,255,0.1);display:flex;align-items:center;gap:8px;font-size:12px;flex-wrap:wrap">
      <span style="font-weight:600">${meta.sceneType}</span>
      <span style="color:var(--text2)">${meta.subId?.split('·')[0]?.trim() || ''}</span>
      <span style="color:var(--text2)">${meta.angleTxt}</span>
      <span style="color:var(--text2);font-size:10px">${meta.provider} · ${meta.fmt}</span>
      <span id="job-status-${jobId}" style="margin-left:auto;color:#FFB347;font-size:11px">⏳ En cours</span>
      <button onclick="cancelJob('${jobId}')" style="background:rgba(255,80,80,0.15);border:1px solid rgba(255,80,80,0.3);color:#ff6b6b;
              font-size:10px;padding:3px 8px;border-radius:4px;cursor:pointer">✕ Annuler</button>
    </div>
    <div style="display:flex;flex-wrap:wrap;gap:12px;padding:12px;align-items:flex-start" id="job-cards-${jobId}">
      ${cards}
    </div>`;

  // Prepend (newest at top)
  const container = document.getElementById('variantCards');
  container.insertBefore(group, container.firstChild);
}

function buildVariantCards(numVariants, aspectCSS) {
  // Legacy wrapper — no-op (createJobGroup handles everything)
}

// ── Afficher une variante prête dans sa carte (jobId-aware) ───
function fillVariantCard(i, webmUrl, mp4Url, jobId) {
  const src = webmUrl || mp4Url;
  const jid = jobId || currentVariantJobId;
  const vid     = document.getElementById(`variant-video-${jid}-${i}`);
  const loading = document.getElementById(`variant-loading-${jid}-${i}`);
  const selBtn  = document.getElementById(`variant-select-${jid}-${i}`);
  const overlay = document.getElementById(`variant-overlay-${jid}-${i}`);
  const dlBtn   = document.getElementById(`variant-dl-${jid}-${i}`);
  if (!vid || !src) return;
  vid.src = src; vid.style.display = 'block';
  if (loading) loading.style.display = 'none';
  if (overlay) overlay.style.display = 'block';
  if (selBtn)  { selBtn.disabled = false; selBtn.style.opacity = '1'; }
  if (dlBtn && mp4Url) { dlBtn.href = mp4Url; dlBtn.style.display = 'block'; }
}

function toggleCardSound(i) {
  // Ouvrir dans un onglet = son garanti (contourne la politique autoplay Chrome)
  const vid = document.getElementById(`variant-video-${i}`);
  if (vid?.src) { window.open(vid.src, '_blank'); return; }
}

async function checkPendingJob() {
  const raw = localStorage.getItem('omnia_last_job');
  if (!raw) return;
  let saved;
  try { saved = JSON.parse(raw); } catch(e) { return; }
  if (!saved?.jobId) return;

  // Ignorer si > 2h
  if (Date.now() - new Date(saved.createdAt).getTime() > 2 * 3600 * 1000) {
    localStorage.removeItem('omnia_last_job');
    return;
  }

  // Vérifier que le job existe encore sur le serveur
  try {
    const r = await fetch('/api/clip/variants-status/' + saved.jobId);
    if (r.status === 404) { localStorage.removeItem('omnia_last_job'); return; }
    const d = await r.json();

    const numVariants = saved.numVariants || 3;
    const fmt         = saved.format     || '9:16';
    const aspectMap   = { '9:16': '9/16', '16:9': '16/9', '1:1': '1/1', '4:5': '4/5' };
    const aspectCSS   = aspectMap[fmt] || '9/16';

    // Afficher le bandeau de restauration
    const variantSection = document.getElementById('variantSection');
    if (variantSection) variantSection.style.display = 'block';

    const pollStatus = document.getElementById('variantPollStatus');
    if (pollStatus) pollStatus.style.display = 'block';

    // Injecter une bannière de restauration
    const existingBanner = document.getElementById('jobRestoreBanner');
    if (!existingBanner) {
      const banner = document.createElement('div');
      banner.id = 'jobRestoreBanner';
      banner.style.cssText = 'background:rgba(251,191,36,0.12);border:1px solid rgba(251,191,36,0.3);border-radius:8px;padding:10px 14px;margin-bottom:10px;display:flex;align-items:center;gap:10px;font-size:12px;';
      banner.innerHTML = `<span>⚡ Génération récupérée après refresh — ${saved.provider || ''} · ${numVariants} variante(s)</span>
        <button onclick="document.getElementById('jobRestoreBanner').remove()" style="margin-left:auto;padding:3px 10px;font-size:11px;border-radius:4px;border:1px solid rgba(251,191,36,0.4);background:transparent;cursor:pointer;color:var(--text)">✕ Fermer</button>`;
      if (pollStatus) pollStatus.insertAdjacentElement('beforebegin', banner);
    }

    const jobId2 = saved.jobId;
    currentVariantJobId = jobId2;

    // Reconstruire le groupe job
    createJobGroup(jobId2, numVariants, aspectCSS, {
      sceneType: saved.sceneType || 'Clip',
      provider: saved.provider || '',
      model: saved.model || '',
      subId: saved.avatarId || '—',
      angleTxt: '', fmt
    });

    // Remplir les vidéos déjà prêtes
    let allAlreadyDone2 = true;
    (d.variants || []).forEach((v, i) => {
      if ((v.status === 'done' || v.webmUrl) && v.webmUrl) {
        fillVariantCard(i, v.webmUrl, v.mp4Url, jobId2);
      } else if (v.status !== 'done' && v.status !== 'failed') {
        allAlreadyDone2 = false;
      }
    });

    if (!allAlreadyDone2) {
      startJobPolling(jobId2, numVariants, aspectCSS);
    } else {
      const statusEl2 = document.getElementById(`job-status-${jobId2}`);
      if (statusEl2) { statusEl2.textContent = '✅ Restaurée'; statusEl2.style.color='#4ECDC4'; }
    }
  } catch(e) { console.warn('checkPendingJob error:', e.message); }
}

function updateGenMeta(d) {
  const m = d.generationMeta || {};
  const done  = d.doneCount  ?? (d.variants||[]).filter(v=>v.status==='done').length;
  const total = d.totalCount ?? (d.variants||[]).length;

  // Texte principal
  const pollText = document.getElementById('variantPollText');
  if (pollText) pollText.textContent = done > 0
    ? `${done}/${total} variante(s) prête(s)…`
    : `Génération en cours…`;

  // Grille méta
  const setEl = (id, val) => { const el=document.getElementById(id); if(el) el.textContent=val; };

  // Modèle : raccourci lisible
  const modelLabel = (m.model||'—').replace('sora-2-pro-text-to-video','Sora 2 Pro T2V ⭐')
    .replace('sora-2-text-to-video','Sora 2 T2V').replace('sora-2-pro-image-to-video','Sora 2 Pro I2V ⭐')
    .replace('sora-2-image-to-video','Sora 2 I2V').replace('kling-3.0','Kling 3.0');
  setEl('genMetaModel', modelLabel);

  // Elapsed
  const sec = m.elapsedSec || 0;
  setEl('genMetaElapsed', sec < 60 ? `${sec}s` : `${Math.floor(sec/60)}m${sec%60}s`);

  // State
  const stateLabel = { generating:'⏳ Generating', success:'✅ Done', failed:'❌ Failed', done:'✅ Done' };
  setEl('genMetaState', stateLabel[m.state] || m.state || '—');

  // Duration
  setEl('genMetaDuration', m.duration ? `n_frames ${m.duration>=15?'15':'10'} (~${m.duration}s)` : 'Auto');

  // Compteur variantes
  setEl('genMetaVariants', `${done}/${total}`);

  // Barre de progression (kie.ai)
  const bar = document.getElementById('genProgressBar');
  const fill = document.getElementById('genProgressFill');
  const pct  = document.getElementById('genProgressPct');
  if (m.progress !== null && m.progress !== undefined && bar) {
    bar.style.display = 'block';
    const p = Math.round(m.progress);
    if (fill) fill.style.width = p + '%';
    if (pct)  pct.textContent  = p + '%';
  } else if (bar) {
    bar.style.display = 'none';
  }
}

// Per-job polling — chaque génération a son propre interval
function startJobPolling(jobId, numVariants, aspectCSS) {
  if (activeJobs[jobId]) clearInterval(activeJobs[jobId].interval);
  const startTime = Date.now();
  const interval = setInterval(async () => {
    try {
      const r = await fetch('/api/clip/variants-status/' + jobId);
      const d = await r.json();
      let allDone = true;
      (d.variants || []).forEach((v, i) => {
        if ((v.status === 'done' || v.webmUrl) && v.webmUrl) {
          const vid = document.getElementById(`variant-video-${jobId}-${i}`);
          if (vid && !vid.src) fillVariantCard(i, v.webmUrl, v.mp4Url, jobId);
        }
        if (v.status !== 'done' && v.status !== 'failed') allDone = false;
      });
      // Update status badge
      const statusEl = document.getElementById(`job-status-${jobId}`);
      const ready = (d.variants||[]).filter(v=>v.status==='done'||v.webmUrl).length;
      const elapsed = Math.round((Date.now()-startTime)/1000);
      if (statusEl) statusEl.textContent = allDone ? `✅ Prêtes (${elapsed}s)` : `⏳ ${ready}/${numVariants} (${elapsed}s)`;
      if (statusEl && allDone) statusEl.style.color = '#4ECDC4';
      // Also update global poll status panel (last active job)
      if (jobId === currentVariantJobId) updateGenMeta(d);
      if (allDone || d.status === 'done') {
        clearInterval(activeJobs[jobId]?.interval);
        delete activeJobs[jobId];
        if (jobId === currentVariantJobId) {
          const statusPanel = document.getElementById('variantPollStatus');
          if (statusPanel) statusPanel.style.display = 'none';
          localStorage.removeItem('omnia_last_job');
        }
      }
    } catch(e) { console.warn(`Job ${jobId} poll error:`, e.message); }
  }, 8000);
  activeJobs[jobId] = { interval, numVariants, aspectCSS };
  // Legacy compat
  variantPollInterval = interval;
}

function cancelJob(jobId) {
  if (activeJobs[jobId]) { clearInterval(activeJobs[jobId].interval); delete activeJobs[jobId]; }
  const group = document.getElementById(`job-group-${jobId}`);
  if (group) group.style.opacity = '0.4';
  const statusEl = document.getElementById(`job-status-${jobId}`);
  if (statusEl) statusEl.textContent = '🛑 Annulé';
}

// Legacy selectVariant re-routed to job-aware version
async function selectVariantJob(variantIndex, jobId) {
  currentVariantJobId = jobId;
  await selectVariant(variantIndex);
}

function startVariantPolling() { /* legacy no-op — replaced by startJobPolling */ }

async function selectVariant(variantIndex) {
  if (!currentVariantJobId) return;
  const sceneType = document.getElementById('clipSceneType')?.value || 'Scene';
  const btn = document.getElementById('variant-select-' + variantIndex);
  if (btn) { btn.disabled = true; btn.textContent = '⏳...'; }

  try {
    const r = await fetch('/api/clip/select', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({
        variantJobId: currentVariantJobId,
        selectedIndex: variantIndex,
        projectId: currentProjectId,
        sceneType,
        label: sceneType + ' — ' + new Date().toLocaleTimeString('fr-FR')
      })
    });
    const d = await r.json();
    if (d.success) {
      // Highlight la card sélectionnée
      [0,1,2].forEach(i => {
        const card = document.getElementById('variant-card-' + i);
        if (card) card.style.border = i === variantIndex ? '2px solid #4ECDC4' : '2px solid transparent';
      });
      // Recharger le projet si actif
      if (currentProjectId) loadStudioProject();
      alert('✅ Clip "' + sceneType + '" ajouté au projet !');
    } else {
      alert('❌ Erreur: ' + (d.error || 'inconnue'));
    }
  } catch(e) { alert('Erreur: ' + e.message); }
  if (btn) { btn.disabled = false; btn.textContent = '✅ Sélectionner'; }
}

async function regenerateVariant(variantIndex) {
  if (confirm('Régénérer les 3 variantes avec le même prompt ?')) {
    clearInterval(variantPollInterval);
    variantPollInterval = null;
    generateClipVariants();
  }
}

// ─── GESTION DES PROJETS STUDIO ─────────────────────────────

async function loadStudioProjects() {
  try {
    const r = await fetch('/api/projects/list');
    const projects = await r.json();
    const sel = document.getElementById('studioProjectSelect');
    if (!sel) return;
    sel.innerHTML = '<option value="">-- Sélectionner un projet --</option>' +
      projects.map(p => `<option value="${p.projectId}">${p.projectName}${p.clips?.length ? ' (' + p.clips.length + ' clips)' : ''}</option>`).join('');
  } catch(e) { console.warn('loadStudioProjects:', e); }
}

async function loadStudioProject() {
  const projectId = document.getElementById('studioProjectSelect')?.value;
  const panel = document.getElementById('studioProjectPanel');
  if (!projectId) { if (panel) panel.style.display = 'none'; currentProjectId = null; return; }
  currentProjectId = projectId;

  try {
    const r = await fetch('/api/projects/' + projectId);
    const proj = await r.json();

    if (panel) panel.style.display = 'block';
    const nameEl = document.getElementById('studioProjectName');
    if (nameEl) nameEl.textContent = proj.projectName;

    const list = document.getElementById('studioClipsList');
    if (list) {
      list.innerHTML = proj.clips?.length
        ? proj.clips.map((c, i) => `
          <div style="display:flex;align-items:center;gap:12px;padding:10px;background:rgba(255,255,255,0.05);border-radius:8px">
            <span style="color:#4ECDC4;font-size:16px">🎬</span>
            <div style="flex:1">
              <span style="font-weight:600;font-size:13px">${c.sceneType}</span>
              <span style="color:var(--text2);font-size:11px;margin-left:8px">${c.label || ''}</span>
              ${c.scriptDE ? `<div style="font-size:11px;color:var(--text2);margin-top:2px;font-style:italic">"${c.scriptDE.slice(0,60)}..."</div>` : ''}
            </div>
            <a href="${c.mp4Url}" download style="color:#4ECDC4;font-size:12px;text-decoration:none" title="Télécharger">↓ MP4</a>
          </div>
        `).join('')
        : '<p style="color:var(--text2);font-style:italic;font-size:13px">Aucun clip sélectionné pour l\'instant — générez et sélectionnez des variantes ci-dessus</p>';
    }

    // Pré-remplir le script complet pour le voiceover
    const fullScript = proj.clips?.map(c => c.scriptDE || '').filter(Boolean).join('\n\n') || '';
    const scriptEl = document.getElementById('fullScriptDE');
    if (scriptEl && !scriptEl.value && fullScript) scriptEl.value = fullScript;

    // Charger l'avatar du projet dans le sélecteur clip
    if (proj.avatarId) {
      const clipSel = document.getElementById('clipAvatarSelect');
      if (clipSel) clipSel.value = proj.avatarId;
      updateConsistencyAnchor();
    }
  } catch(e) { console.warn('loadStudioProject:', e); }
}

function showCreateProjectModal() {
  const name = prompt('Nom du projet\n\nEx: "Batch 2 Cortisol SA-02" ou "Hook Test Mars 2026"');
  if (!name) return;
  const concept = prompt('Concept (optionnel)\n\nEx: "Der Cortisol-Wecker — Avatar SA-02"') || '';
  createStudioProject(name, concept);
}

async function createStudioProject(projectName, concept) {
  const avatarId = document.getElementById('clipAvatarSelect')?.value || '';
  try {
    const r = await fetch('/api/projects/create', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({ projectName, avatarId, concept })
    });
    const d = await r.json();
    if (d.success) {
      await loadStudioProjects();
      const sel = document.getElementById('studioProjectSelect');
      if (sel) sel.value = d.projectId;
      await loadStudioProject();
    } else {
      alert('Erreur: ' + (d.error || 'inconnue'));
    }
  } catch(e) { alert('Erreur: ' + e.message); }
}

async function generateProjectVoiceover() {
  const scriptDE = document.getElementById('fullScriptDE')?.value;
  if (!scriptDE) { alert('Script vide — colle le texte complet en allemand'); return; }
  const btn = event?.target;
  if (btn) { btn.disabled = true; btn.textContent = '⏳ Génération...'; }

  try {
    const r = await fetch('/api/voiceover/generate-project', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({ scriptDE, projectId: currentProjectId, stability: 0.85, similarityBoost: 0.90 })
    });
    const d = await r.json();
    if (d.audioUrl) {
      alert('✅ Voiceover généré !\n\n' + d.audioUrl);
    } else if (d.error || d.message) {
      alert('⚠️ ' + (d.message || d.error));
    }
  } catch(e) { alert('Erreur: ' + e.message); }
  if (btn) { btn.disabled = false; btn.textContent = '🎵 Générer voiceover DE complet (ElevenLabs)'; }
}

function exportProjectZip() {
  if (!currentProjectId) { alert('Sélectionne d\'abord un projet'); return; }
  window.open('/api/projects/' + currentProjectId + '/export-zip', '_blank');
}

