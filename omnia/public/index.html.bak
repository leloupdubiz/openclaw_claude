      <div class="cc-form-grid">
        <div><label>Nom du projet</label><input id="pf-name" placeholder="ex: Nellio Studio — Batch Generator"></div>
        <div><label>Horizon</label>
          <select id="pf-horizon">
            <option value="CT">Court Terme (CT)</option>
