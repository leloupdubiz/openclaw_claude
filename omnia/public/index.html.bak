})();

// ─────────────────────────────────────────────────────────────
// STUDIO CLIP — SUB-TABS
// ─────────────────────────────────────────────────────────────
function showStudioTab(tab) {
  document.querySelectorAll('.studio-tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.studio-pane').forEach(p => p.classList.remove('active'));
  const btn = document.querySelector(`.studio-tab[data-tab="${tab}"]`);
  if (btn) btn.classList.add('active');
  const pane = document.getElementById(`studio-pane-${tab}`);
  if (pane) pane.classList.add('active');
  // Init Long Form models on first open
  if (tab === 'longform') updateLFModels();
}

// ─────────────────────────────────────────────────────────────
// LONG FORM — GÉNÉRATION MULTI-SCÈNES
// ─────────────────────────────────────────────────────────────

// Sync LF models with UGC CLIP_MODELS (same structure)
function updateLFModels() {
  const provider = document.getElementById('lfProvider')?.value || 'kie';
  const modelSel = document.getElementById('lfModel');
  if (!modelSel || typeof CLIP_MODELS === 'undefined') return;
  const models = CLIP_MODELS[provider] || [];
  modelSel.innerHTML = models.map(m =>
    `<option value="${m.value}">${m.label}</option>`
  ).join('');
  updateLFCost();
}

function updateLFCost() {
  const el = document.getElementById('lfCostEstimate');
  if (!el) return;
  const scenes = document.querySelectorAll('#lfSceneList .lf-scene-item').length;
  const provider = document.getElementById('lfProvider')?.value || 'kie';
  const modelVal = document.getElementById('lfModel')?.value || '';
  if (typeof CLIP_MODELS === 'undefined') return;
  const models = CLIP_MODELS[provider] || [];
  const m = models.find(x => x.value === modelVal) || models[0];
  if (!m) { el.textContent = '—'; return; }
  const credPerClip = m.creditsPerClip || (m.creditsPerSec ? m.creditsPerSec * 10 : 40);
  const total = credPerClip * scenes;
  el.innerHTML = `${provider === 'kie' ? 'kie.ai' : provider} · ${scenes} scène${scenes>1?'s':''} × ${credPerClip} cr = <strong>${total} crédits (~$${(total*0.005).toFixed(2)})</strong>`;
}

// Add / remove scene rows
function addLFScene() {
  const list = document.getElementById('lfSceneList');
  const items = list.querySelectorAll('.lf-scene-item');
  if (items.length >= 8) return;
  const idx = items.length;
  const div = document.createElement('div');
  div.className = 'lf-scene-item';
  div.dataset.index = idx;
  div.innerHTML = `
    <div class="lf-scene-header">
      <span class="lf-scene-num">#${idx+1}</span>
      <select class="lf-scene-type" style="flex:1;font-size:13px">
        <option value="Hook">🎣 Hook</option>
        <option value="Problem">😰 Problème</option>
        <option value="Solution" selected>✨ Solution</option>
        <option value="CTA">📣 CTA</option>
        <option value="Testimonial">💬 Témoignage</option>
      </select>
      <span class="lf-scene-status" style="font-size:11px;color:var(--text2);min-width:72px;text-align:right">⏸ En attente</span>
    </div>
    <div class="lf-scene-body"><div class="lf-scene-prompt"></div><div class="lf-scene-clips" style="margin-top:8px"></div></div>`;
  list.appendChild(div);
  document.getElementById('lfSceneCount').textContent = `${idx+1} scènes`;
  updateLFCost();
}

function removeLFScene() {
  const list = document.getElementById('lfSceneList');
  const items = list.querySelectorAll('.lf-scene-item');
  if (items.length <= 2) return;
  items[items.length - 1].remove();
  document.getElementById('lfSceneCount').textContent = `${items.length-1} scènes`;
  updateLFCost();
}

// Reset scene statuses
function resetLFScenes() {
  document.querySelectorAll('#lfSceneList .lf-scene-item').forEach(item => {
    item.className = 'lf-scene-item';
    item.querySelector('.lf-scene-status').textContent = '⏸ En attente';
    item.querySelector('.lf-scene-prompt').textContent = '';
    const clips = item.querySelector('.lf-scene-clips');
    if (clips) clips.innerHTML = '';
    item.querySelector('.lf-scene-body').style.display = 'none';
  });
}

// Poll a single Long Form scene job
function pollLFScene(sceneEl, jobId, onDone) {
  const statusEl = sceneEl.querySelector('.lf-scene-status');
  const clipsEl = sceneEl.querySelector('.lf-scene-clips');
  sceneEl.classList.add('lf-generating');
  sceneEl.querySelector('.lf-scene-body').style.display = 'block';

  const iv = setInterval(async () => {
    try {
      const r = await fetch(`/api/clip/variants-status/${jobId}`);
      const d = await r.json();
      if (!d.variants) return;
      const ready = d.variants.filter(v => v.status === 'done' || v.webmUrl || v.mp4Url);
      statusEl.textContent = `⏳ ${ready.length}/${d.numVariants||1} prête(s)`;
      if (d.status === 'done' || ready.length >= (d.numVariants||1)) {
        clearInterval(iv);
        sceneEl.classList.remove('lf-generating');
        sceneEl.classList.add('lf-done');
        statusEl.textContent = '✅ Prête';
        // Show first clip inline
        const v = d.variants.find(x => x.webmUrl || x.mp4Url);
        if (v && clipsEl) {
          const url = v.webmUrl || v.mp4Url;
          clipsEl.innerHTML = `<video src="${url}" controls playsinline muted style="width:100%;max-width:180px;border-radius:8px"></video>
            <a href="${url}" target="_blank" class="btn btn-secondary btn-sm" style="display:inline-block;margin-top:4px">🔊 Son</a>`;
        }
        onDone();
      }
    } catch(e) { /* ignore */ }
  }, 4000);
}

// Main Long Form generation
async function generateLongForm() {
  const avatarId = document.getElementById('lfAvatarSelect').value;
  const angle = document.getElementById('lfAngle').value;
  const provider = document.getElementById('lfProvider').value;
  const model = document.getElementById('lfModel').value;
  const format = document.getElementById('lfFormat').value;
  const sceneItems = Array.from(document.querySelectorAll('#lfSceneList .lf-scene-item'));
  const N = sceneItems.length;

  if (!avatarId || !model) { alert('Sélectionne un avatar et un modèle'); return; }

  const btn = document.getElementById('btnGenerateLF');
  btn.disabled = true;
  btn.textContent = '⏳ Génération en cours...';

  const progressEl = document.getElementById('lfProgress');
  const fillEl = document.getElementById('lfProgressFill');
  const progressTxt = document.getElementById('lfProgressText');
  progressEl.style.display = 'block';
  document.getElementById('btnLFExport').style.display = 'none';

  const timeline = document.getElementById('lfTimeline');
  timeline.innerHTML = '';

  // Reset all scenes
  resetLFScenes();

  let doneCount = 0;

  function updateProgress() {
    doneCount++;
    const pct = Math.round(doneCount / N * 100);
    fillEl.style.width = pct + '%';
    progressTxt.textContent = `${doneCount}/${N} scènes prêtes`;
    if (doneCount >= N) {
      btn.disabled = false;
      btn.textContent = '✅ Toutes les scènes prêtes — Regénérer';
      document.getElementById('btnLFExport').style.display = 'block';
    }
  }

  for (let i = 0; i < sceneItems.length; i++) {
    const item = sceneItems[i];
    const sceneType = item.querySelector('.lf-scene-type').value;
    const statusEl = item.querySelector('.lf-scene-status');
    const promptEl = item.querySelector('.lf-scene-prompt');

    statusEl.textContent = '⏳ Prompt...';
    item.querySelector('.lf-scene-body').style.display = 'block';

    try {
      // Step 1: generate prompt
      const pRes = await fetch('/api/generate/clip-prompt', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ avatarId, angle, sceneType, format, provider, model })
      });
      const pData = await pRes.json();
      if (pData.error) throw new Error(pData.error);
      promptEl.textContent = pData.prompt.substring(0, 120) + '...';
      statusEl.textContent = '⏳ Variante...';

      // Step 2: launch variant
      const vRes = await fetch('/api/clip/generate-variants', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          avatarId, sceneType, scriptDE: pData.scriptDE,
          prompt: pData.prompt, visualPrompt: pData.prompt,
          provider, model, format, numVariants: 1
        })
      });
      const vData = await vRes.json();
      if (vData.error) throw new Error(vData.error);
      item.dataset.jobId = vData.variantJobId;

      // Step 3: poll (non-blocking for next scene)
      pollLFScene(item, vData.variantJobId, updateProgress);

      // Update timeline
      const tRow = document.createElement('div');
      tRow.style.cssText = 'display:flex;align-items:center;gap:8px;padding:6px 0;border-bottom:1px solid var(--border);font-size:12px';
      tRow.innerHTML = `<span style="font-weight:600;min-width:20px">#${i+1}</span>
        <span style="color:var(--text2)">${sceneType}</span>
        <span class="lf-tl-status-${i}" style="margin-left:auto;color:#4ECDC4">⏳</span>`;
      timeline.appendChild(tRow);

    } catch(err) {
      statusEl.textContent = `❌ Erreur: ${err.message}`;
      item.classList.add('lf-error');
      updateProgress();
    }
  }
}

// Export Long Form ZIP (uses existing variantJobs via project or direct download list)
async function exportLongFormZip() {
  const items = Array.from(document.querySelectorAll('#lfSceneList .lf-scene-item'));
  const urls = [];
  for (const item of items) {
    const video = item.querySelector('video');
    if (video) urls.push(video.src);
  }
  if (urls.length === 0) { alert('Aucun clip prêt'); return; }
  // Open each in new tab for manual download
  urls.forEach((url, i) => {
    setTimeout(() => window.open(url, '_blank'), i * 300);
  });
  // Also try ZIP via project if available
  const jobIds = items.map(i => i.dataset.jobId).filter(Boolean);
  if (jobIds.length > 0) {
    const msg = `📦 ${urls.length} clips ouverts dans de nouveaux onglets.\nTélécharge chaque fichier et importe dans CapCut/Premiere.`;
    alert(msg);
  }
}

// Init LF models on page load
document.addEventListener('DOMContentLoaded', () => {
  // updateLFModels will be called when Long Form tab is opened
  // Attach cost update listeners
  ['lfProvider', 'lfModel', 'lfFormat'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.addEventListener('change', updateLFCost);
  });

  // Init cascade Core → Sub-Avatar → Angle au chargement
  onCoreAvatarChange();

  // Init agent cards
  initAgentCards();
  // Restaurer les résultats de missions persistés
  restoreMissionResults();
  // Studio Clip actif par défaut dans la Creation Layer
  showCreationPanel('multiscene');
});

