// Chat history per agent
const _agentChats = {};

function showAgentsLayer(layer) {
  document.querySelectorAll('.agents-layer-tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.agents-layer-pane').forEach(p => p.classList.remove('active'));
  const tab = document.getElementById(`agtab-${layer}`);
  const pane = document.getElementById(`aglayer-${layer}`);
  if (tab) tab.classList.add('active');
  if (pane) pane.classList.add('active');
  if (layer === 'creation') showCreationPanel('multiscene');
}

function showEvolveSection(layer) {
  const layerToLabel = { research: 'Recherche', strategy: 'Stratégie', creation: 'Création', execution: 'Exécution', optimization: 'Optimisation' };
  // Afficher la page agents (va reset les nav-items)
  showPage('agents');
  // Re-appliquer l'item actif + ouvrir le bon layer après le reset
  setTimeout(() => {
    document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
    document.querySelectorAll('.nav-item').forEach(n => {
      if (n.textContent.trim().includes(layerToLabel[layer])) n.classList.add('active');
    });
    showAgentsLayer(layer);
  }, 30);
}

// ─── Image Ad Generator ───────────────────────────────────────────────────
function generateImageAdPrompt() {
  const avatar  = document.getElementById('imgad-avatar').value;
  const angle   = document.getElementById('imgad-angle').value;
  const format  = document.getElementById('imgad-format').value;
  const style   = document.getElementById('imgad-style').value;
  const hook    = document.getElementById('imgad-hook').value.trim();

  const avatarVisual = {
    sonja:   'German woman early 30s, professional look, tired but hopeful, Munich apartment',
    markus:  'German man 35-40, dad energy, slightly exhausted, home office setting',
    julia:   'German woman late 20s, wellness aesthetic, clean natural makeup, Berlin loft',
    generic: 'diverse German adults 25-55, relatable everyday setting'
  };
  const angleContext = {
    cortisol:  'cortisol biology visualization, brain activity, 3AM clock, molecular overlay, dark bedroom',
    schlaf:    'sleepless night, racing thoughts visualization, exhausted person transitioning to peaceful sleep',
    identite:  'professional in modern German city office, calm focus, high-performance energy',
    natural:   'natural herbs and powder flat lay, clean minimal aesthetic, clinical credibility'
  };
  const styleVisual = {
    ugc:        'vertical smartphone selfie style, raw authentic lighting, no color grading, real person vibe, conversational energy',
    lifestyle:  'editorial lifestyle photography, natural window light, muted warm tones, aspirational but approachable',
    product:    'product photography hero shot, Nellio UltraCalm raspberry-lemon powder stick-pack (slim metallic tube ~2.5cm×15cm, pink-blue gradient), clean background, dramatic lighting',
    scientific: 'medical-science visual, data overlay, clean infographic elements, white lab background, credibility-first'
  };
  const formatSpec = { story:'9:16 (1080×1920px)', feed:'1:1 (1080×1080px)', portrait:'4:5 (1080×1350px)', banner:'16:9 (1200×628px)' };
  const arRatio    = { story:'9:16', feed:'1:1', portrait:'4:5', banner:'16:9' };
  const hookPos    = format === 'story' ? 'top 1/4 of frame' : 'lower third';

  let prompt = `Midjourney prompt — Meta Ad ${formatSpec[format]}\n\n`;
  prompt += `${styleVisual[style]}\n\n`;
  prompt += `SUBJECT: ${avatarVisual[avatar]}\n\n`;
  prompt += `CONTEXT: ${angleContext[angle]}\n\n`;
  prompt += `BRAND: Nellio UltraCalm raspberry-lemon stick-pack visible (slim metallic tube, drinknellio.com)\n\n`;
  prompt += `MOOD: Before/after emotional arc — stress resolved by Nellio. German premium DTC aesthetic.\n\nMETA ADS: High contrast, thumb-stop visual, clear focal point`;
  if (hook) prompt += `\n\nTEXT OVERLAY (bold white font, ${hookPos}): "${hook}"`;
  prompt += `\n\n--ar ${arRatio[format]} --v 6.1 --style raw --q 2`;

  const out = document.getElementById('imgad-output');
  out.style.display = 'block';
  out.style.alignItems = 'flex-start';
  out.style.justifyContent = 'flex-start';
  out.style.color = 'var(--text)';
  out.textContent = prompt;
  document.getElementById('imgad-copy-btn').style.display = 'inline-flex';
}

function copyImageAdPrompt() {
  const text = document.getElementById('imgad-output').textContent;
  navigator.clipboard.writeText(text).then(() => {
    const btn = document.getElementById('imgad-copy-btn');
    btn.textContent = '✅ Copié !';
    setTimeout(() => { btn.textContent = '📋 Copier'; }, 2000);
  });
}

// ─── Creation Layer sub-tabs ──────────────────────────────────────────────
function showCreationPanel(name) {
  // Mettre à jour les onglets actifs
  document.querySelectorAll('.creation-tab').forEach(t => {
    t.style.background = 'none';
    t.style.color = 'var(--text2)';
    t.style.borderColor = 'var(--border)';
  });
  const tabMap = { multiscene: 'ctab-studio', batchgen: 'ctab-batch', hookbank: 'ctab-hooks', library: 'ctab-historique', imagead: 'ctab-imagead' };
  const activeTab = document.getElementById(tabMap[name]);
  if (activeTab) {
    activeTab.style.background = 'rgba(108,99,255,0.15)';
    activeTab.style.color = 'var(--accent)';
    activeTab.style.borderColor = 'rgba(108,99,255,0.3)';
  }
  // Cacher tous les panneaux
  document.querySelectorAll('.creation-panel').forEach(p => p.style.display = 'none');
  // Afficher le panneau demandé
  const panel = document.getElementById('cpanel-' + name);
  if (panel) panel.style.display = 'block';
  // Callbacks spécifiques
  if (name === 'library') refreshLibrary();
  if (name === 'hookbank') loadHookBank();
  if (name === 'batchgen') { loadCharacterSelects(); refreshBatchJobs(); const ce = document.getElementById('batchCredits'); const cd = document.getElementById('creditsDisplay'); if(ce && cd) ce.textContent = cd.textContent; }
  if (name === 'multiscene') { loadAvatarsList(); loadStudioProjects(); updateSceneCards(); updateClipCost(); syncDurationOptions(); loadCharacterSelects(); checkPendingJob(); }
}

// Rediriger les anciens showPage vers la creation layer quand approprié
const _origShowPage = typeof showPage === 'function' ? showPage : null;

function initAgentCards() {
  ['research','strategy','creation','execution','optimization'].forEach(layer => {
    const container = document.getElementById(`agents-${layer}-list`);
    if (!container) return;
    const agents = Object.entries(AGENTS_CONFIG).filter(([,a]) => a.layer === layer);
    container.innerHTML = agents.map(([id, a]) => {
      const statusClass = a.status === 'active' ? 'agent-status-active' : a.status === 'done' ? 'agent-status-done' : 'agent-status-standby';
      const statusLabel = a.status === 'active' ? '🟢 Actif' : a.status === 'done' ? '✅ Complété' : '⏸ Standby';
      return `
      <div class="agent-card" id="agcard-${id}">
        <div class="agent-card-header">
          <div class="agent-emoji-big">${a.emoji}</div>
          <div class="agent-info">
            <div class="agent-name">${a.name}</div>
            <div class="agent-desc">${a.desc}</div>
          </div>
          <div class="agent-actions">
            <span class="agent-status ${statusClass}">${statusLabel}</span>
            <button class="btn btn-sm btn-secondary" onclick="toggleAgentPanel('${id}')">💬 Chat</button>
            <button class="btn btn-sm btn-primary" onclick="launchAgentMission('${id}', true)">🚀 Mission</button>
          </div>
        </div>
        <div class="agent-panel" id="agpanel-${id}">
          <div class="agent-chat-side">
            <div class="agent-panel-title">💬 Chat avec ${a.name}</div>
            <div class="agent-chat-msgs" id="agchat-${id}">
              <div class="agent-msg-sys">Je suis ${a.name}. Comment puis-je t'aider sur drinknellio.com ?</div>
            </div>
            <div class="agent-chat-input-row">
              <input type="text" id="aginput-${id}" placeholder="Question à ${a.name.split(' ')[0]}…"
                onkeydown="if(event.key==='Enter')sendAgentMessage('${id}')">
              <button class="btn btn-primary btn-sm" onclick="sendAgentMessage('${id}')">→</button>
            </div>
          </div>
          <div class="agent-mission-side">
            <div class="mission-card">
              <h4>🎯 Mission par défaut</h4>
              <div class="mission-desc-text">${a.mission}</div>
              <button class="btn btn-primary btn-sm" id="agmission-btn-${id}" onclick="launchAgentMission('${id}', false)">
                🚀 Lancer cette mission
              </button>
              <div class="mission-output-box" id="agmission-out-${id}" style="font-size:11px;max-height:80px"></div>
            </div>
          </div>
        </div>
        <div class="agent-report-dashboard" id="agdash-${id}"></div>
      </div>`;
    }).join('');
  });
}

function toggleAgentPanel(id) {
  const panel = document.getElementById(`agpanel-${id}`);
  if (!panel) return;
  panel.classList.toggle('open');
}

async function sendAgentMessage(id) {
  const input = document.getElementById(`aginput-${id}`);
  const msgs = document.getElementById(`agchat-${id}`);
  if (!input || !msgs || !input.value.trim()) return;
  const text = input.value.trim();
  input.value = '';
  if (!_agentChats[id]) _agentChats[id] = [];

  msgs.insertAdjacentHTML('beforeend', `<div class="agent-msg agent-msg-user">${text.replace(/</g,'&lt;')}</div>`);
  msgs.scrollTop = msgs.scrollHeight;

  const thinkId = `think-${id}-${Date.now()}`;
  msgs.insertAdjacentHTML('beforeend', `<div class="agent-msg agent-msg-bot" id="${thinkId}"><span class="spinner"></span></div>`);
  msgs.scrollTop = msgs.scrollHeight;

  _agentChats[id].push({ role:'user', content:text });
  try {
    const r = await fetch('/api/agents/chat', {
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({ agentId:id, history:_agentChats[id] })
    });
    const d = await r.json();
    document.getElementById(thinkId)?.remove();
    const reply = d.response || d.error || 'Erreur';
    _agentChats[id].push({ role:'assistant', content:reply });
    msgs.insertAdjacentHTML('beforeend', `<div class="agent-msg agent-msg-bot">${reply.replace(/\n/g,'<br>').replace(/</g,'&lt;')}</div>`);
    msgs.scrollTop = msgs.scrollHeight;
  } catch(e) {
    document.getElementById(thinkId)?.remove();
    msgs.insertAdjacentHTML('beforeend', `<div class="agent-msg agent-msg-bot" style="color:var(--error)">Erreur réseau</div>`);
  }
}

async function launchAgentMission(id, openPanel = true) {
  const agent = AGENTS_CONFIG[id];
  if (!agent) return;
  if (openPanel) {
    const panel = document.getElementById(`agpanel-${id}`);
    if (panel && !panel.classList.contains('open')) panel.classList.add('open');
  }
  const btn = document.getElementById(`agmission-btn-${id}`);
  const out = document.getElementById(`agmission-out-${id}`);
  if (!out) return;
  if (btn) { btn.disabled = true; btn.innerHTML = '<span class="spinner"></span> Mission en cours…'; }
  out.className = 'mission-output-box visible';
  out.textContent = '⚡ Mission lancée — génération en cours…';

  try {
    const r = await fetch('/api/agents/mission', {
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({ agentId:id })
    });
    const d = await r.json();
    const output = d.output || d.error || 'Erreur';
    out.textContent = output;

    // Update status badge
    const statusEl = document.querySelector(`#agcard-${id} .agent-status`);
    if (statusEl) { statusEl.className = 'agent-status agent-status-done'; statusEl.textContent = '✅ Complété'; }

    // Add to chat
    const msgs = document.getElementById(`agchat-${id}`);
    if (msgs) {
      msgs.insertAdjacentHTML('beforeend', `<div class="agent-msg-sys">✅ Mission complétée — rapport disponible →</div>`);
      msgs.scrollTop = msgs.scrollHeight;
    }

    // Show inline dashboard
    showInlineReport(id, output);

  } catch(e) {
    out.textContent = 'Erreur réseau: ' + e.message;
  } finally {
    if (btn) { btn.disabled = false; btn.innerHTML = '🚀 Lancer cette mission'; }
  }
}

// ═══════════════════════════════════════════════════════
// 📊 MISSION REPORT — Markdown + Visuals
// ═══════════════════════════════════════════════════════

let _reportRawText = '';

// ── Markdown renderer ──────────────────────────────────
function escHtml(s) {
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}
function inlineMd(s) {
  return escHtml(s)
    .replace(/\*\*\*(.+?)\*\*\*/g,'<strong><em>$1</em></strong>')
    .replace(/\*\*(.+?)\*\*/g,'<strong>$1</strong>')
    .replace(/\*([^*\n]+)\*/g,'<em>$1</em>')
    .replace(/`([^`]+)`/g,'<code>$1</code>')
    .replace(/\[([^\]]+)\]\(([^)]+)\)/g,'<a href="$2" target="_blank" style="color:var(--accent)">$1</a>');
}
function renderMarkdown(md) {
  const lines = md.split('\n');
  let html = '', inUL = false, inOL = false, inPre = false, preContent = '';
  const closeList = () => {
    if (inUL) { html += '</ul>'; inUL = false; }
    if (inOL) { html += '</ol>'; inOL = false; }
  };
  for (let i = 0; i < lines.length; i++) {
    const line = lines[i];
    if (line.trim().startsWith('```')) {
      if (inPre) { html += `<pre>${escHtml(preContent)}</pre>`; inPre = false; preContent = ''; }
      else { closeList(); inPre = true; }
      continue;
    }
    if (inPre) { preContent += line + '\n'; continue; }
    if (/^####\s/.test(line)) { closeList(); html += `<h4>${inlineMd(line.slice(5))}</h4>`; continue; }
    if (/^###\s/.test(line)) { closeList(); html += `<h3>${inlineMd(line.slice(4))}</h3>`; continue; }
    if (/^##\s/.test(line)) { closeList(); html += `<h2>${inlineMd(line.slice(3))}</h2>`; continue; }
    if (/^#\s/.test(line)) { closeList(); html += `<h1>${inlineMd(line.slice(2))}</h1>`; continue; }
    if (/^---+$/.test(line.trim())) { closeList(); html += '<hr>'; continue; }
    if (/^>\s/.test(line)) { html += `<blockquote>${inlineMd(line.slice(2))}</blockquote>`; continue; }
    if (/^[-•]\s/.test(line)) {
      if (!inUL) { if (inOL) { html += '</ol>'; inOL = false; } html += '<ul>'; inUL = true; }
      html += `<li>${inlineMd(line.slice(2))}</li>`; continue;
    }
    if (/^\d+\.\s/.test(line)) {
      if (!inOL) { if (inUL) { html += '</ul>'; inUL = false; } html += '<ol>'; inOL = true; }
      html += `<li>${inlineMd(line.replace(/^\d+\.\s/,''))}</li>`; continue;
    }
    closeList();
    if (line.trim() === '') { html += '<div style="height:8px"></div>'; continue; }
    html += `<p>${inlineMd(line)}</p>`;
  }
  closeList();
  if (inPre) html += `<pre>${escHtml(preContent)}</pre>`;
  return html;
}

// ── Report modal open/close ────────────────────────────
function openMissionReport(agentId, output) {
  const agent = AGENTS_CONFIG[agentId] || {};
  _reportRawText = output;
  document.getElementById('reportEmoji').textContent = agent.emoji || '🤖';
  document.getElementById('reportTitle').textContent = `Rapport Mission — ${agent.name || agentId}`;
  document.getElementById('reportLayerBadge').textContent = (agent.layer || '').toUpperCase() + ' LAYER';
  document.getElementById('reportContent').innerHTML = renderMarkdown(output);
  renderReportVisuals(agentId, output, document.getElementById('reportVisuals'));
  document.getElementById('reportModal').classList.add('open');
  // Animate bars after DOM render
  setTimeout(() => {
    document.querySelectorAll('.bar-fill').forEach(el => {
      const w = el.dataset.width;
      if (w) el.style.width = w + '%';
    });
  }, 100);
}
function closeReport() {
  document.getElementById('reportModal').classList.remove('open');
}
function copyReportText() {
  navigator.clipboard.writeText(_reportRawText).then(() => {
    const btn = event.currentTarget;
    const orig = btn.textContent; btn.textContent = '✅ Copié !';
    setTimeout(() => btn.textContent = orig, 1800);
  });
}
function saveReportMd() {
  const name = document.getElementById('reportTitle').textContent.replace(/[^a-z0-9À-ÿ]/gi,'-').toLowerCase();
  const blob = new Blob([_reportRawText], { type: 'text/plain' });
  const a = document.createElement('a'); a.href = URL.createObjectURL(blob);
  a.download = `${name}.md`; a.click();
}

// ── Inline dashboard ───────────────────────────────────
function showInlineReport(id, output, timestamp, doScroll = true) {
  const agent = AGENTS_CONFIG[id] || {};
  const dash = document.getElementById(`agdash-${id}`);
  if (!dash) return;
  _reportRawText = output;

  const now = timestamp
    ? new Date(timestamp).toLocaleString('fr-FR', { day:'2-digit', month:'2-digit', hour:'2-digit', minute:'2-digit' })
    : new Date().toLocaleString('fr-FR', { day:'2-digit', month:'2-digit', hour:'2-digit', minute:'2-digit' });

  dash.innerHTML = `
    <div class="ard-header">
      <span style="font-size:20px">${agent.emoji || '🤖'}</span>
      <div class="ard-title">Rapport Mission — ${agent.name || id}</div>
      <span class="ard-ts">🕐 ${now}</span>
      <div style="display:flex;gap:6px;margin-left:auto">
        <button class="btn btn-sm btn-secondary" onclick="navigator.clipboard.writeText(document.getElementById('agdash-${id}').querySelector('.ard-content').innerText); this.textContent='✅'; setTimeout(()=>this.textContent='📋 Copier',1500)">📋 Copier</button>
        <button class="btn btn-sm btn-secondary" onclick="saveReportMdFrom('${id}')">💾 .md</button>
        <button class="btn btn-sm btn-secondary" onclick="document.getElementById('agdash-${id}').classList.remove('visible')">↑ Réduire</button>
      </div>
    </div>
    <div class="ard-body">
      <div class="ard-content" id="ardcontent-${id}">${renderMarkdown(output)}</div>
      <div class="ard-visuals" id="ardvisuals-${id}"></div>
    </div>`;

  dash.classList.add('visible');

  // Update status badge
  const statusEl = document.querySelector(`#agcard-${id} .agent-status`);
  if (statusEl) { statusEl.className = 'agent-status agent-status-done'; statusEl.textContent = '✅ Complété'; }

  // Update mission btn label
  const out = document.getElementById(`agmission-out-${id}`);
  if (out) { out.className = 'mission-output-box visible'; out.textContent = '✅ Rapport affiché ci-dessous'; }

  // Render visuals in right column
  renderReportVisuals(id, output, document.getElementById(`ardvisuals-${id}`));

  // Animate bars
  setTimeout(() => {
    dash.querySelectorAll('.bar-fill[data-width]').forEach(el => {
      el.style.width = el.dataset.width + '%';
    });
  }, 120);

  if (doScroll) setTimeout(() => dash.scrollIntoView({ behavior:'smooth', block:'start' }), 80);
}

function saveReportMdFrom(id) {
  const raw = document.getElementById(`agmission-out-${id}`)?.previousTextContent
    || _reportRawText;
  const agent = AGENTS_CONFIG[id] || {};
  const blob = new Blob([_reportRawText], { type: 'text/plain' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = `rapport-${(agent.name || id).replace(/[^a-z0-9]/gi,'-').toLowerCase()}.md`;
  a.click();
}

// ── Visuals dispatcher ─────────────────────────────────
function renderReportVisuals(agentId, output, container) {
  container.innerHTML = '';
  // 1. Always: summary card
  container.insertAdjacentHTML('beforeend', buildSummaryCard(output));
  // 2. Agent-specific
  const specials = {
    'market-researcher': buildDesireChart,
    'research-synth': buildDesireChart,
    'avatar-architect': buildAvatarCards,
    'strategy-lead': () => buildEvolveTimeline() + build322Matrix(),
    'hook-writer': buildHookPatterns,
    'script-writer': buildScriptInfo,
    'campaign-builder': () => build322Matrix() + buildCampaignInfo(),
    'budget-optimizer': buildBudgetRules,
    'perf-monitor': buildKPIGrid,
    'scale-strategist': buildScaleTimeline,
    'iteration-creator': buildHookPatterns,
    'learning-analyst': buildEvolveTimeline,
    // Nouveaux agents — Phase 2 audit
    'sub-avatar-specialist': () => buildAvatarCards() + buildSubAvatarFramework(),
    'angle-extractor': () => buildAngleMatrix() + buildDesireChart(),
    'concept-strategist': () => buildMarksman3x4() + build322Matrix(),
    'review-analyzer': () => buildVerbatimGrid() + buildAvatarCards(),
    // Agents audit 2026-02-25
    'awareness-mapper': () => buildAwarenessMatrix() + buildAvatarCards(),
    'market-sophistication-analyst': () => buildMarketStageChart() + buildDesireChart(),
    'creative-roadmap-manager': () => buildMarksman3x4() + buildEvolveTimeline(),
    'foreplay-curator': () => buildVerbatimGrid() + buildAngleMatrix(),
  };
  const builder = specials[agentId] || (() => buildGenericFlow(agentId));
  container.insertAdjacentHTML('beforeend', builder());
}

// ── Visual builders ────────────────────────────────────
function buildSummaryCard(output) {
  const bullets = [];
  for (const l of output.split('\n')) {
    const m = l.match(/\*\*(.{10,80}?)\*\*/);
    if (m && !l.startsWith('#') && bullets.length < 6) bullets.push(m[1]);
  }
  if (bullets.length < 3) {
    for (const l of output.split('\n')) {
      if (l.trim().length > 25 && !l.startsWith('#') && !l.startsWith('---') && !l.startsWith('```') && bullets.length < 5)
        bullets.push(l.replace(/\*+/g,'').trim().slice(0,90));
    }
  }
  return `<div class="vis-section">
    <div class="vis-title">📋 Points Clés</div>
    <div class="summary-card">${bullets.slice(0,6).map(b =>
      `<div class="summary-item"><span class="summary-item-icon">→</span><span style="font-size:12px">${escHtml(b)}</span></div>`
    ).join('')}</div></div>`;
}

function buildDesireChart() {
  const data = [
    { l:'Sommeil récupérateur', s:7820, p:false },
    { l:'Reprendre contrôle (CORTISOL) ⭐', s:7020, p:true },
    { l:'Performance mentale · focus', s:6120, p:false },
    { l:'Solution naturelle qui marche', s:5984, p:false },
    { l:'Retrouver son vrai moi', s:5330, p:false },
    { l:'Corps détendu · tensions', s:5304, p:false },
    { l:'Dégonfler · viral ⚡', s:4675, p:false },
    { l:'Briser le cycle', s:4400, p:false },
  ];
  const mx = data[0].s;
  return `<div class="vis-section">
    <div class="vis-title">📊 Desire Map — Intensité × Scope</div>
    <div class="bar-chart">${data.map((d,i) => {
      const pct = Math.round(d.s/mx*100);
      return `<div class="bar-row">
        <div class="bar-label">
          <span style="font-size:10px">#${i+1} ${d.l}</span>
          <span style="font-weight:700;color:${d.p?'var(--accent3)':'var(--text2)'}">${d.s}</span>
        </div>
        <div class="bar-track"><div class="bar-fill ${d.p?'primary':''}" data-width="${pct}" style="width:0"></div></div>
      </div>`;
    }).join('')}</div>
    <div style="margin-top:10px;padding:8px 12px;background:rgba(78,205,196,0.08);border-radius:8px;font-size:11px;color:var(--accent3)">
      ⭐ PRIMARY DESIRE · Angle différenciateur : <em>"Dein Cortisol auch."</em>
    </div>
  </div>`;
}

function buildAvatarCards() {
  const avs = [
    { id:'A1', name:'Die Erschöpfte Berufstätige', age:'28-42', prio:'⭐⭐⭐', hook:'Ich kann nicht abschalten.' },
    { id:'A2', name:'Die Überlastete Mutter', age:'30-45', prio:'⭐⭐⭐', hook:'Ich bin nicht mehr ich selbst.' },
    { id:'A3', name:'Der Burnout-Gefährdete', age:'28-45', prio:'⭐⭐⭐⭐⭐', hook:'Um 3 Uhr nachts wach.' },
    { id:'A4', name:'Der Biohacker', age:'25-40', prio:'⭐⭐', hook:'Was ist die beste Kombi?' },
  ];
  return `<div class="vis-section">
    <div class="vis-title">🎭 Core Avatars — Phase 2</div>
    ${avs.map(a => `<div class="avatar-chip" style="margin-bottom:8px">
      <div style="display:flex;justify-content:space-between">
        <span class="avatar-chip-id">${a.id} ${a.prio}</span>
        <span style="font-size:10px;color:var(--text2)">${a.age} ans</span>
      </div>
      <div class="avatar-chip-name">${a.name}</div>
      <div class="avatar-chip-hook">"${a.hook}"</div>
    </div>`).join('')}
    <div style="font-size:11px;color:var(--text2);margin-top:6px">+ 15 sub-avatars · A3 = priorité max</div>
  </div>`;
}

function buildEvolveTimeline() {
  const phases = [
    { t:'Phase 1 — Research', d:'Desire Map · 19 Avatars · Competitors', cls:'tdone' },
    { t:'Phase 2 — Strategy ← ici', d:'3 angles Marksman · 12 ads · Budget €150/j', cls:'tactive' },
    { t:'Phase 3 — Création', d:'Hooks DE · Scripts · Briefs UGC · Tournage', cls:'' },
    { t:'Phase 4 — Execution', d:'Meta ABO · 72h Marksman Test · 3-2-2', cls:'' },
    { t:'Phase 5 — Scale', d:'Sniper winner · €2K-5K/j · DACH expansion', cls:'' },
  ];
  return `<div class="vis-section">
    <div class="vis-title">⚡ Roadmap EVOLVE</div>
    <div class="timeline">${phases.map(p => `
      <div class="timeline-item">
        <div class="timeline-dot ${p.cls}"></div>
        <div class="timeline-item-title" style="color:${p.cls==='tdone'?'var(--success)':p.cls==='tactive'?'var(--accent)':'var(--text)'}">${p.t}</div>
        <div class="timeline-item-desc">${p.d}</div>
      </div>`).join('')}
    </div>
  </div>`;
}

function build322Matrix() {
  return `<div class="vis-section">
    <div class="vis-title">⚙️ Structure 3-2-2 — 12 ads/ABO</div>
    <div class="matrix-322">
      <div class="mcell mcell-h" style="background:transparent"></div>
      <div class="mcell mcell-h">Body Copy 1</div>
      <div class="mcell mcell-h">Body Copy 2</div>
      ${[1,2,3].map(c => `
      <div class="mcell mcell-l">C${c}</div>
      <div class="mcell mcell-ad">Ad ${(c-1)*4+1}<br><small style="color:var(--text2)">× H1+H2</small></div>
      <div class="mcell mcell-ad">Ad ${(c-1)*4+3}<br><small style="color:var(--text2)">× H1+H2</small></div>`).join('')}
    </div>
    <div style="margin-top:10px;font-size:11px;color:var(--text2)">
      3 créatifs × 2 body × 2 headlines = <strong style="color:var(--success)">12 ads</strong> · €150/j ABO
    </div>
  </div>`;
}

function buildCampaignInfo() {
  return `<div class="vis-section">
    <div class="vis-title">🎯 Config Campagne</div>
    ${[
      { k:'Objectif', v:'Achats (Purchase)' },
      { k:'Type', v:'ABO · Budget campagne' },
      { k:'Budget test', v:'€150/j total' },
      { k:'Attribution', v:'7j click / 1j view' },
      { k:'Ad sets', v:'3 (Broad · Interest · LAL)' },
      { k:'Durée test', v:'72h minimum' },
    ].map(r => `<div style="display:flex;justify-content:space-between;padding:6px 0;border-bottom:1px solid rgba(255,255,255,0.05);font-size:12px">
      <span style="color:var(--text2)">${r.k}</span><span style="font-weight:600">${r.v}</span>
    </div>`).join('')}
  </div>`;
}

function buildHookPatterns() {
  const patterns = [
    { name:'Question', color:'#6c63ff', desc:'Micro-pause cognitive → le cerveau cherche' },
    { name:'Stat chiffrée', color:'#4ecdc4', desc:'Crédibilité + curiosité + urgence' },
    { name:'Provocation', color:'#ff6b6b', desc:'Dissonance → attention forcée' },
    { name:'Identification', color:'#fbbf24', desc:'Miroir avatar → empathie immédiate' },
    { name:'Révélation', color:'#4ade80', desc:'Mécanisme caché → FOMO informationnel' },
  ];
  return `<div class="vis-section">
    <div class="vis-title">🎯 5 Patterns Hook</div>
    ${patterns.map(p => `<div class="hook-pattern">
      <div class="hook-dot" style="background:${p.color}"></div>
      <div>
        <div style="font-size:12px;font-weight:700">${p.name}</div>
        <div style="font-size:11px;color:var(--text2)">${p.desc}</div>
      </div>
    </div>`).join('')}
    <div style="margin-top:12px;padding:10px;background:rgba(108,99,255,0.06);border-radius:8px;font-size:11px">
      Règle : <strong>1 phrase · &lt; 8 mots</strong> · stopper scroll &lt; 3s
    </div>
  </div>`;
}

function buildScriptInfo() {
  return `<div class="vis-section">
    <div class="vis-title">🎬 Structure UGC Marketing Mania</div>
    <div class="timeline">${[
      { t:'Hook 0-3s', d:'1 phrase · < 8 mots · stopper scroll', cls:'tactive' },
      { t:'Problème 3-11s', d:'Agitation douleur avatar · mots exacts', cls:'' },
      { t:'Mécanisme 11-23s', d:'Cortisol + Ashwagandha + L-Théanine', cls:'' },
      { t:'Preuve 23-38s', d:'20K Bewertungen · 4.8/5 · -27.9% cortisol', cls:'' },
      { t:'CTA 38-45s', d:'Link bio · Geld-zurück-Garantie', cls:'' },
    ].map(p => `<div class="timeline-item">
      <div class="timeline-dot ${p.cls}"></div>
      <div class="timeline-item-title">${p.t}</div>
      <div class="timeline-item-desc">${p.d}</div>
    </div>`).join('')}</div>
    <div style="margin-top:10px;padding:8px 12px;background:rgba(78,205,196,0.06);border-radius:8px;font-size:11px;color:var(--accent3)">
      🇩🇪 Langue : Allemand · Ton : authentique phone-recorded · 35-50 mots
    </div>
  </div>`;
}

function buildBudgetRules() {
  const rules = [
    { n:'Stop Loss', t:'Dépense > 2× CPA cible sans achat', a:'Pause adset', c:'var(--error)' },
    { n:'Kill Rule', t:'Dépense > €50 sans 1 conversion', a:'Couper immédiatement', c:'var(--error)' },
    { n:'Scale Rule', t:'ROAS > 3.0 · 48h consécutives', a:'+20% budget', c:'var(--success)' },
    { n:'Fatigue Rule', t:'Fréquence > 3.5 sur 7j', a:'Rafraîchir créatif', c:'var(--warning)' },
  ];
  return `<div class="vis-section">
    <div class="vis-title">💰 Règles Automatiques Meta</div>
    ${rules.map(r => `<div class="rule-card" style="border-left-color:${r.c}">
      <div style="font-size:12px;font-weight:700;color:${r.c};margin-bottom:4px">${r.n}</div>
      <div style="font-size:11px;color:var(--text2);margin-bottom:3px">Si : ${r.t}</div>
      <div style="font-size:11px;font-weight:600">→ ${r.a}</div>
    </div>`).join('')}
  </div>`;
}

function buildKPIGrid() {
  const kpis = [
    { l:'CPM cible', v:'< €12', s:'DE marché' },
    { l:'CTR cible', v:'> 1.5%', s:'Feed' },
    { l:'CPA cible', v:'< €25', s:'Achat' },
    { l:'ROAS scale', v:'> 3.0', s:'48h stable' },
    { l:'ROAS min', v:'> 2.0', s:'Viable' },
    { l:'Fréquence', v:'< 3.5', s:'Avant fatigue' },
  ];
  return `<div class="vis-section">
    <div class="vis-title">📊 KPIs Cibles — Marché DE</div>
    <div class="kpi-grid">${kpis.map(k => `<div class="kpi-item">
      <div class="kpi-value">${k.v}</div>
      <div class="kpi-label">${k.l}</div>
      <div style="font-size:10px;color:var(--text2)">${k.s}</div>
    </div>`).join('')}</div>
  </div>`;
}

function buildScaleTimeline() {
  const steps = [
    { d:'J1-3', b:'€150/j', a:'Marksman · 3 angles · 12 ads' },
    { d:'J4-7', b:'€300/j', a:'Winner identifié · couper losers' },
    { d:'J8-14', b:'€600/j', a:'Sniper · deep-dive winner' },
    { d:'J15-21', b:'€1,200/j', a:'Scale horiz · LAL 1%+2%' },
    { d:'J22-30', b:'€2,500/j', a:'DACH · AT+CH · LAL 5%' },
  ];
  return `<div class="vis-section">
    <div class="vis-title">🚀 Budget Scale — 30 Jours</div>
    <div class="timeline">${steps.map((s,i) => `<div class="timeline-item">
      <div class="timeline-dot" style="background:${i===0?'var(--success)':'var(--accent)'}"></div>
      <div class="timeline-item-title">${s.d} · <span style="color:var(--accent3);font-weight:700">${s.b}</span></div>
      <div class="timeline-item-desc">${s.a}</div>
    </div>`).join('')}</div>
    <div style="margin-top:10px;padding:8px 12px;background:rgba(74,222,128,0.06);border-radius:8px;font-size:11px;color:var(--success)">
      🎯 Objectif J30 : <strong>€2,500/j</strong> rentable · ROAS > 3.0 · DACH
    </div>
  </div>`;
}

async function restoreMissionResults() {
  try {
    const r = await fetch('/api/agents/results');
    if (!r.ok) return;
    const results = await r.json();
    Object.entries(results).forEach(([agentId, data]) => {
      if (!data?.output) return;
      showInlineReport(agentId, data.output, data.timestamp, false); // false = ne pas scroller
    });
  } catch(e) { console.warn('[restore]', e.message); }
}

function buildGenericFlow(agentId) {
  const agent = AGENTS_CONFIG[agentId] || {};
  const layerColors = { research:'var(--accent3)', strategy:'var(--accent)',
    creation:'#ff6b6b', execution:'var(--warning)', optimization:'var(--success)' };
  const layerEmojis = { research:'🔍', strategy:'⚡', creation:'✨', execution:'⚙️', optimization:'📊' };
  const color = layerColors[agent.layer] || 'var(--accent)';
  return `<div class="vis-section">
    <div class="vis-title">🔄 Position EVOLVE</div>
    <div style="text-align:center;padding:16px;background:rgba(108,99,255,0.05);border-radius:10px;margin-bottom:16px">
      <div style="font-size:36px;margin-bottom:8px">${agent.emoji||'🤖'}</div>
      <div style="font-weight:700;color:${color};font-size:14px">${agent.name||agentId}</div>
      <div style="font-size:11px;color:var(--text2);text-transform:uppercase;letter-spacing:0.8px;margin-top:4px">${(agent.layer||'').toUpperCase()} LAYER</div>
    </div>
    <div>${['Research','Strategy','Creation','Execution','Optimization'].map((l,i) => {
      const isActive = l.toLowerCase() === agent.layer;
      return `<div style="display:flex;align-items:center;gap:8px;padding:7px 0;border-bottom:1px solid rgba(255,255,255,0.04)">
        <span>${layerEmojis[l.toLowerCase()]||'•'}</span>
        <span style="font-size:12px;${isActive?`color:${color};font-weight:700`:'color:var(--text2)'}">${l} Layer</span>
        ${isActive?`<span style="margin-left:auto;font-size:10px;padding:2px 8px;background:${color};color:#000;border-radius:10px;font-weight:700">ICI</span>`:''}
      </div>`;
    }).join('')}</div>
  </div>`;
}

// ── Visual builders — Nouveaux agents ─────────────────────────

function buildSubAvatarFramework() {
  const steps = [
    { n:'1', label:'Contexte Précis', desc:'Lieu exact · Moment de la journée · Situation déclenchante', color:'#6c63ff' },
    { n:'2', label:'Douleur Spécifique', desc:'UNE douleur précise — pas générique', color:'#ff6b6b' },
    { n:'3', label:'Solutions Essayées', desc:'Baldrian, Melatonin, médecin — pourquoi ça a échoué', color:'#f97316' },
    { n:'4', label:'Verbatim EXACT (DE)', desc:'La phrase qu\'il dirait à un ami dans ce moment', color:'#4ecdc4' },
    { n:'5', label:'Désir Caché vs Exprimé', desc:'Exprimé = symptôme · Caché = vérité émotionnelle profonde', color:'#fbbf24' },
  ];
  return `<div class="vis-section">
    <div class="vis-title">🔬 Framework Sub-Avatar (5 étapes)</div>
    ${steps.map(s => `
      <div style="display:flex;gap:10px;align-items:flex-start;padding:8px 0;border-bottom:1px solid rgba(255,255,255,0.04)">
        <div style="min-width:24px;height:24px;border-radius:50%;background:${s.color};display:flex;align-items:center;justify-content:center;font-weight:700;font-size:11px;color:#000">${s.n}</div>
        <div>
          <div style="font-size:12px;font-weight:600;color:${s.color}">${s.label}</div>
          <div style="font-size:11px;color:var(--text2);margin-top:2px">${s.desc}</div>
        </div>
      </div>`).join('')}
    <div style="margin-top:10px;padding:8px;background:rgba(108,99,255,0.08);border-radius:6px;font-size:11px;color:var(--text2)">
      ✅ Bon sub-avatar : 1 personne se reconnaît immédiatement<br>
      ❌ Trop générique : 10 personnes différentes pourraient se reconnaître
    </div>
  </div>`;
}

function buildAngleMatrix() {
  const angles = [
    { name:'CORTISOL ⭐', score:95, color:'#ff6b6b', hook:'Dein Cortisol macht Überstunden' },
    { name:'SCHLAF', score:82, color:'#6c63ff', hook:'Warum du nachts wach liegst' },
    { name:'IDENTITE', score:78, color:'#4ecdc4', hook:'Das bist nicht du — das ist Cortisol' },
    { name:'BURNOUT', score:71, color:'#f97316', hook:'Prävention kostet €1,16/Tag' },
    { name:'PERFORMANCE', score:65, color:'#fbbf24', hook:'3 Kaffee. Immer noch erschöpft.' },
    { name:'OBJECTION', score:60, color:'#a78bfa', hook:'Baldrian. Nichts hat geholfen.' },
    { name:'PHARMA ALT.', score:55, color:'#34d399', hook:'Ein Schritt vor Lexapro' },
    { name:'SCIENCE', score:50, color:'#60a5fa', hook:'PMC 31517876 : -27,9% Cortisol' },
    { name:'STACK', score:40, color:'#f472b6', hook:'8 Kapseln → 1 Sachet' },
  ];
  return `<div class="vis-section">
    <div class="vis-title">🎯 9 Angles — Scoring Différenciation</div>
    ${angles.map(a => `
      <div style="margin-bottom:8px">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:3px">
          <span style="font-size:11px;font-weight:600;color:${a.color}">${a.name}</span>
          <span style="font-size:11px;color:var(--text2)">${a.score}/100</span>
        </div>
        <div style="height:6px;background:rgba(255,255,255,0.06);border-radius:3px;overflow:hidden">
          <div class="bar-fill" data-width="${a.score}%" style="height:100%;background:${a.color};border-radius:3px;width:0;transition:width 0.8s ease"></div>
        </div>
        <div style="font-size:10px;color:var(--text2);margin-top:2px;font-style:italic">"${a.hook}"</div>
      </div>`).join('')}
  </div>`;
}

function buildMarksman3x4() {
  const grid = [
    { angle:'CORTISOL', sub:'A3-e', hook:'3 Uhr morgens...', fmt:'UGC 45s', priority:'P1' },
    { angle:'CORTISOL', sub:'A1-b', hook:'Laptop zu — Kopf...', fmt:'B-Roll 30s', priority:'P1' },
    { angle:'CORTISOL', sub:'A2-a', hook:'Es gibt keinen...', fmt:'UGC 45s', priority:'P1' },
    { angle:'CORTISOL', sub:'A3-c', hook:'Baldrian. Nichts...', fmt:'Static', priority:'P1' },
    { angle:'SCHLAF', sub:'A3-e', hook:'Warum du wach liegst', fmt:'UGC 45s', priority:'P2' },
    { angle:'SCHLAF', sub:'A1-a', hook:'Aggressiv wegen...', fmt:'B-Roll 30s', priority:'P2' },
    { angle:'SCHLAF', sub:'A2-b', hook:'Mein Körper fremd...', fmt:'UGC 45s', priority:'P2' },
    { angle:'SCHLAF', sub:'A4-a', hook:'KSM-66 — der Unterschied', fmt:'Static', priority:'P2' },
    { angle:'IDENTITE', sub:'A2-a', hook:'Ich bin nicht mehr ich', fmt:'UGC 45s', priority:'P3' },
    { angle:'IDENTITE', sub:'A1-a', hook:'Wann bist du wieder du', fmt:'B-Roll 30s', priority:'P3' },
    { angle:'IDENTITE', sub:'A3-a', hook:'Alles hängt dran', fmt:'UGC 45s', priority:'P3' },
    { angle:'IDENTITE', sub:'A1-c', hook:'Ich helfe allen...', fmt:'Static', priority:'P3' },
  ];
  const angleColors = { CORTISOL:'#ff6b6b', SCHLAF:'#6c63ff', IDENTITE:'#4ecdc4' };
  return `<div class="vis-section">
    <div class="vis-title">🗺️ Marksman Batch — 3 Angles × 4 Créatifs</div>
    <div style="overflow-x:auto">
      <table style="width:100%;border-collapse:collapse;font-size:11px">
        <tr style="color:var(--text2);border-bottom:1px solid var(--border)">
          <th style="text-align:left;padding:4px 6px">#</th>
          <th style="text-align:left;padding:4px 6px">Angle</th>
          <th style="text-align:left;padding:4px 6px">Sub-Avatar</th>
          <th style="text-align:left;padding:4px 6px">Hook DE</th>
          <th style="text-align:left;padding:4px 6px">Format</th>
        </tr>
        ${grid.map((r,i) => `
          <tr style="border-bottom:1px solid rgba(255,255,255,0.04)">
            <td style="padding:5px 6px;color:var(--text2)">${i+1}</td>
            <td style="padding:5px 6px"><span style="color:${angleColors[r.angle]||'#888'};font-weight:600">${r.angle}</span></td>
            <td style="padding:5px 6px;color:var(--text2)">${r.sub}</td>
            <td style="padding:5px 6px;font-style:italic">${r.hook}</td>
            <td style="padding:5px 6px;color:var(--text2)">${r.fmt}</td>
          </tr>`).join('')}
      </table>
    </div>
    <div style="margin-top:8px;display:flex;gap:6px">
      <span style="font-size:10px;padding:3px 8px;background:rgba(255,107,107,0.15);color:#ff6b6b;border-radius:10px">P1 CORTISOL</span>
      <span style="font-size:10px;padding:3px 8px;background:rgba(108,99,255,0.15);color:#6c63ff;border-radius:10px">P2 SCHLAF</span>
      <span style="font-size:10px;padding:3px 8px;background:rgba(78,205,196,0.15);color:#4ecdc4;border-radius:10px">P3 IDENTITE</span>
    </div>
  </div>`;
}

function buildVerbatimGrid() {
  const cats = [
    { label:'DOULEUR', color:'#ff6b6b', icon:'😔', examples:['Ich kann einfach nicht abschalten', 'Mein Kopf dreht sich die ganze Nacht', 'Ich bin so müde aber kann nicht schlafen'] },
    { label:'TRANSFORMATION', color:'#4ecdc4', icon:'✨', examples:['Zum ersten Mal seit Monaten schlafe ich durch', 'Ich bin endlich wieder ich selbst', 'Mein Mann sagt ich bin eine andere Person geworden'] },
    { label:'ECHEC SOLUTION', color:'#f97316', icon:'❌', examples:['Baldrian hat nichts gebracht', 'Melatonin macht mich morgens noch schlimmer', 'Der Arzt wollte mir einfach Antidepressiva geben'] },
    { label:'DESIRE CACHÉ', color:'#fbbf24', icon:'💛', examples:['Ich will einfach wieder normal sein', 'Ich will abends lachen können', 'Ich will morgens aufwachen und froh sein'] },
  ];
  return `<div class="vis-section">
    <div class="vis-title">💬 Catégories de Verbatims</div>
    ${cats.map(c => `
      <div style="margin-bottom:12px">
        <div style="font-size:11px;font-weight:700;color:${c.color};margin-bottom:6px">${c.icon} ${c.label}</div>
        ${c.examples.map(ex => `
          <div style="font-size:11px;padding:5px 8px;background:rgba(255,255,255,0.03);border-left:2px solid ${c.color};border-radius:0 4px 4px 0;margin-bottom:3px;font-style:italic;color:var(--text2)">"${ex}"</div>
        `).join('')}
      </div>`).join('')}
    <div style="margin-top:8px;padding:6px;background:rgba(255,255,255,0.03);border-radius:6px;font-size:10px;color:var(--text2)">
      💡 Les meilleurs hooks = verbatims DOULEUR reformulés en < 8 mots
    </div>
  </div>`;
}

function buildAwarenessMatrix() {
  const levels = [
    { level:'UNAWARE', pct:'35%', color:'#6b7280', hook:'Um 3 Uhr wach. Jeden Nacht.', rule:'ZÉRO mention produit — symptôme pur'},
    { level:'PROBLEM AWARE', pct:'30%', color:'#f97316', hook:'Das ist nicht Müdigkeit. Das ist Cortisol.', rule:'Valider + nommer la cause'},
    { level:'SOLUTION AWARE', pct:'25%', color:'#fbbf24', hook:'Warum dein Ashwagandha nichts gemacht hat', rule:'Différencier avant Nellio'},
    { level:'PRODUCT AWARE', pct:'8%', color:'#4ecdc4', hook:'KSM-66 ist nicht das gleiche wie Standard-Ashwagandha', rule:'Comparaison directe'},
    { level:'MOST AWARE', pct:'2%', color:'#22c55e', hook:'20.000+ Bewertungen. 45 Tage risikofrei.', rule:'Offre + garantie + preuve sociale'},
  ];
  return `<div class="vis-section">
    <div class="vis-title">🧭 Matrice 5 Niveaux d'Awareness</div>
    ${levels.map(l => `
      <div style="margin-bottom:10px">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:4px">
          <span style="font-size:11px;font-weight:700;color:${l.color}">${l.level}</span>
          <span style="font-size:10px;color:var(--text2)">${l.pct} marché DE</span>
        </div>
        <div style="font-size:10px;font-style:italic;color:var(--text2);margin-bottom:3px;padding:4px 8px;background:rgba(255,255,255,0.04);border-left:2px solid ${l.color};border-radius:0 4px 4px 0">"${l.hook}"</div>
        <div style="font-size:10px;color:var(--text3)">${l.rule}</div>
      </div>`).join('')}
  </div>`;
}

function buildMarketStageChart() {
  const stages = [
    { n:'1', label:'Nouveau claim', status:'🔓', desc:'Premier à dire ce que ça fait', nellio:false},
    { n:'2', label:'Claim élargi', status:'🔒', desc:'Altapharma, Baldrian DM — "naturel"', nellio:false},
    { n:'3', label:'Nouveau mécanisme', status:'🔒', desc:'Women\'s Best, Sensilab — "cortisol"', nellio:false},
    { n:'4', label:'Mécanisme élargi', status:'⭐', desc:'KSM-66 / Absorption liquide / Synergie 4', nellio:true},
    { n:'5', label:'Identification', status:'🔮', desc:'Stage futur — identité "retrouver qui j\'étais"', nellio:false},
  ];
  return `<div class="vis-section">
    <div class="vis-title">📡 Market Sophistication — Marché DE = Stage 3→4</div>
    ${stages.map(s => `
      <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;padding:7px 10px;background:${s.nellio?'rgba(78,205,196,0.08)':'rgba(255,255,255,0.02)'};border-radius:8px;border:1px solid ${s.nellio?'var(--accent)':'var(--border)'}">
        <div style="width:22px;height:22px;border-radius:50%;background:${s.nellio?'var(--accent)':'var(--border)'};display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;flex-shrink:0">${s.n}</div>
        <div style="flex:1">
          <div style="font-size:11px;font-weight:700;color:${s.nellio?'var(--accent)':'var(--text)'}">${s.status} ${s.label}${s.nellio?' ← NELLIO JOUE ICI':''}</div>
          <div style="font-size:10px;color:var(--text2)">${s.desc}</div>
        </div>
      </div>`).join('')}
  </div>`;
}
</script>

<!-- ══════════════════════════════════════════════════════════════
     MODAL — AVATAR PICKER HEYGEN
══════════════════════════════════════════════════════════════ -->
<div id="avatarPickerModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.85);z-index:9999;padding:16px;overflow-y:auto">
  <div style="max-width:960px;margin:0 auto;background:var(--surface);border-radius:16px;padding:24px;border:1px solid var(--border)">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px">
      <div>
        <div style="font-size:18px;font-weight:700">👤 Choisir un Avatar HeyGen</div>
        <div style="font-size:12px;color:var(--text2);margin-top:2px" id="avatarPickerCount">1287 avatars disponibles</div>
      </div>
      <button onclick="closeAvatarPicker()" class="btn btn-secondary" style="padding:8px 16px">✕ Fermer</button>
    </div>
    <!-- Filtres -->
    <div style="display:flex;gap:8px;margin-bottom:10px;flex-wrap:wrap">
      <input type="text" id="avatarSearch" placeholder="🔍 Rechercher par nom..."
             oninput="filterAvatars()" style="flex:1;min-width:160px">
      <select id="avatarGenderFilter" onchange="filterAvatars()" style="width:130px">
        <option value="">Tous genres</option>
        <option value="female">👩 Femme</option>
        <option value="male">👨 Homme</option>
      </select>
    </div>
    <!-- Filtre âge -->
    <div style="display:flex;gap:6px;margin-bottom:12px;flex-wrap:wrap">
      <span style="font-size:11px;color:var(--text2);align-self:center;margin-right:2px">Âge :</span>
      <button class="age-filter-btn active" data-age="" onclick="setAgeFilter(this,'')"
              style="padding:4px 10px;font-size:11px;border-radius:20px;border:1px solid var(--accent);background:rgba(108,99,255,0.2);cursor:pointer;color:var(--text)">Tous</button>
      <button class="age-filter-btn" data-age="young" onclick="setAgeFilter(this,'young')"
              style="padding:4px 10px;font-size:11px;border-radius:20px;border:1px solid var(--border);background:transparent;cursor:pointer;color:var(--text)">🧑 Jeune (20-30)</button>
      <button class="age-filter-btn" data-age="adult" onclick="setAgeFilter(this,'adult')"
              style="padding:4px 10px;font-size:11px;border-radius:20px;border:1px solid var(--border);background:transparent;cursor:pointer;color:var(--text)">👤 Adulte (30-50)</button>
      <button class="age-filter-btn" data-age="senior" onclick="setAgeFilter(this,'senior')"
              style="padding:4px 10px;font-size:11px;border-radius:20px;border:1px solid var(--border);background:transparent;cursor:pointer;color:var(--text)">🧓 Senior (50+)</button>
    </div>
    <!-- Grille avatars -->
    <div id="avatarGrid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(130px,1fr));gap:10px;max-height:55vh;overflow-y:auto;padding-right:4px"></div>
    <div style="display:flex;justify-content:center;margin-top:14px">
      <button id="loadMoreAvatarsBtn" onclick="loadMoreAvatars()" class="btn btn-secondary" style="font-size:12px">Charger 24 de plus</button>
    </div>
  </div>
</div>

<script>
// ══════════════════════════════════════════════════════════════
//  IMAGE PRODUIT PICKER
// ══════════════════════════════════════════════════════════════
let _selectedImageUrl    = null; // URL publique finale (pour génération)
let _selectedImageBase64 = null; // base64 pour fichiers uploadés depuis le browser
let _selectedImageLocal  = null; // Filename d'un brand asset (serveur le gère)
let _brandAssetsLoaded   = false;

async function loadBrandAssets() {
  if (_brandAssetsLoaded) return;
  const grid = document.getElementById('brandAssetsGrid');
  if (!grid) return;
  try {
    const d = await api('/api/assets/brand');
    const assets = d.assets || [];
    grid.innerHTML = assets.length ? assets.map(a => `
      <div onclick="selectBrandAsset('${a.name}','${a.url}')"
           data-name="${a.name}" data-url="${a.url}"
           style="aspect-ratio:3/4;border-radius:6px;overflow:hidden;cursor:pointer;border:2px solid transparent;
                  background:#111;display:flex;align-items:center;justify-content:center;transition:border-color .15s"
           onmouseenter="this.style.borderColor='var(--accent)'" onmouseleave="this.style.borderColor='transparent'"
           title="${a.name}">
        <img src="${a.url}" style="width:100%;height:100%;object-fit:cover" loading="lazy">
      </div>
    `).join('') : '<div style="font-size:11px;color:var(--text2)">Aucun asset trouvé</div>';
    _brandAssetsLoaded = true;
  } catch(e) {
    if (grid) grid.innerHTML = '<div style="font-size:11px;color:#f88">Erreur chargement</div>';
  }
}

function switchImgTab(tab, btn) {
  ['assets','upload','url'].forEach(t => {
    const el = document.getElementById('imgTab' + t.charAt(0).toUpperCase() + t.slice(1));
    if (el) el.style.display = t === tab ? 'block' : 'none';
  });
  document.querySelectorAll('.img-tab-btn').forEach(b => {
    const isActive = b === btn;
    b.style.background   = isActive ? 'rgba(108,99,255,0.2)' : 'transparent';
    b.style.borderColor  = isActive ? 'var(--accent)'        : 'var(--border)';
  });
  if (tab === 'assets') loadBrandAssets();
}

function selectBrandAsset(name, localUrl) {
  _selectedImageLocal  = name;
  _selectedImageBase64 = null;
  _selectedImageUrl    = null;
  showImagePreview(name, localUrl, localUrl);
  scheduleVisualPromptGen();
  // Highlight
  document.querySelectorAll('[data-name]').forEach(c => c.style.borderColor = 'transparent');
  if (card) card.style.borderColor = 'var(--accent)';
}

async function handleImgUpload(input) {
  const file = input.files[0];
  if (!file) return;
  const status = document.getElementById('imgUploadStatus');
  if (status) status.textContent = '⏳ Lecture du fichier...';

  const reader = new FileReader();
  reader.onload = e => {
    _selectedImageBase64 = e.target.result;
    _selectedImageUrl    = null;
    _selectedImageLocal  = null;
    showImagePreview(file.name, null, e.target.result);
    if (status) status.textContent = `✅ ${file.name} prêt · sera uploadé lors de la génération`;
    scheduleVisualPromptGen();
  };
  reader.readAsDataURL(file);
}

let _imgUrlTimer = null;

function onImgUrlInput(url) {
  if (!url || url.length < 10) return;
  clearTimeout(_imgUrlTimer);
  _imgUrlTimer = setTimeout(() => {
    const isImageUrl = /\.(png|jpg|jpeg|webp|gif)(\?.*)?$/i.test(url);
    if (isImageUrl) {
      setImageFromUrl(url);
    } else if (url.startsWith('http')) {
      extractImagesFromUrl(url);
    }
  }, 800);
}

async function extractImagesFromUrl(url) {
  const status  = document.getElementById('imgUrlStatus');
  const gallery = document.getElementById('imgUrlGallery');
  if (status)  status.textContent = '⏳ Extraction des images produit...';
  if (gallery) gallery.style.display = 'none';

  try {
    const d = await api('/api/image/extract-from-url', { method: 'POST', body: { url } });
    const images = d.images || [];

    if (!images.length) {
      if (status) status.textContent = '❌ Aucune image trouvée sur cette page. Colle une URL directe d\'image (.png/.jpg).';
      return;
    }
    if (status) status.textContent = `✅ ${images.length} image(s) trouvée(s) — clique pour sélectionner :`;
    if (gallery) {
      gallery.innerHTML = `<div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(80px,1fr));gap:6px;max-height:220px;overflow-y:auto">` +
        images.map((img, i) => `
          <div onclick="selectExtractedImage('${img.url.replace(/'/g,"\\'")}','${(img.name||'').replace(/'/g,"\\'")}')
" data-ext-url="${img.url.replace(/"/g,'&quot;')}"
               style="aspect-ratio:1;border-radius:6px;overflow:hidden;cursor:pointer;border:2px solid transparent;
                      background:#111;transition:border-color .15s"
               onmouseenter="this.style.borderColor='var(--accent)'" onmouseleave="this.style.borderColor='transparent'"
               title="${img.name || img.url.split('/').pop()}">
            <img src="${img.url}" style="width:100%;height:100%;object-fit:cover" loading="lazy"
                 onerror="this.parentElement.style.display='none'">
          </div>`).join('') + `</div>`;
      gallery.style.display = 'block';
    }
  } catch(e) {
    if (status) status.textContent = '❌ Erreur extraction : ' + e.message;
  }
}

function selectExtractedImage(url, name) {
  setImageFromUrl(url);
  // Highlight la carte sélectionnée
  document.querySelectorAll('[data-ext-url]').forEach(c => c.style.borderColor = 'transparent');
  const card = document.querySelector(`[data-ext-url="${url.replace(/"/g,'&quot;')}"]`);
  if (card) card.style.borderColor = 'var(--accent)';
  const status = document.getElementById('imgUrlStatus');
  if (status) status.textContent = `✅ Sélectionnée : ${name || url.split('/').pop()}`;
}

function setImageFromUrl(url) {
  if (!url || !url.startsWith('http')) return;
  _selectedImageUrl    = url;
  _selectedImageBase64 = null;
  _selectedImageLocal  = null;
  showImagePreview(url.split('/').pop().split('?')[0] || 'image', url, url);
  scheduleVisualPromptGen();
}

function showImagePreview(name, url, thumbSrc) {
  const preview = document.getElementById('imgSelectedPreview');
  const thumb   = document.getElementById('imgSelectedThumb');
  const nm      = document.getElementById('imgSelectedName');
  const urlEl   = document.getElementById('imgSelectedUrl');
  if (thumb) thumb.src = thumbSrc;
  if (nm)    nm.textContent  = name;
  if (urlEl) urlEl.textContent = url || '(asset local — sera hébergé à la génération)';
  if (preview) preview.style.display = 'flex';
}

function clearSelectedImage() {
  _selectedImageUrl = _selectedImageBase64 = _selectedImageLocal = null;
  const preview = document.getElementById('imgSelectedPreview');
  if (preview) preview.style.display = 'none';
  document.querySelectorAll('[data-name]').forEach(c => c.style.borderColor = 'transparent');
  scheduleVisualPromptGen(); // Regen sans image → réintroduit la description produit
}

// Appeler loadBrandAssets au chargement initial de la page multiscene
document.addEventListener('DOMContentLoaded', () => {
  const multiscenePage = document.getElementById('cpanel-multiscene');
  if (multiscenePage) loadBrandAssets();
});

// ══════════════════════════════════════════════════════════════
//  HEYGEN AVATAR + VOICE PICKER
// ══════════════════════════════════════════════════════════════
let _heygenAvatars = [];
let _heygenVoices  = [];
let _avatarPage    = 0;
let _ageFilter     = '';
const AVATAR_PAGE_SIZE = 24;

// Mots-clés par tranche d'âge (noms HeyGen)
const AGE_KEYWORDS = {
  young:  ['young', 'junior', 'teen', 'student', 'youthful', 'girl', '20', '22', '24', '25', '26'],
  adult:  ['professional', 'business', 'manager', 'adult', '30', '32', '35', '38', '40', '42', '45'],
  senior: ['senior', 'mature', 'elder', 'old', '50', '55', '60', '65', '70', 'grandm', 'grandf']
};

async function loadHeygenAvatarsVoices() {
  const avatarBtn   = document.getElementById('heygenAvatarPickerBtn');
  const heyWarn     = document.getElementById('heygenKeyWarning');
  const higgWarn    = document.getElementById('higgsfieldKeyWarning');
  const provider    = document.getElementById('clipProvider')?.value;

  if (_heygenAvatars.length && _heygenVoices.length) {
    // Déjà chargé — juste re-render voices
    renderHeygenVoiceList();
    return;
  }

  try {
    const [avatarData, voiceData] = await Promise.all([
      api('/api/heygen/avatars'),
      api('/api/heygen/voices')
    ]);
    _heygenAvatars = avatarData.avatars || [];
    _heygenVoices  = voiceData.voices  || [];

    // Warning : n'afficher que si vraiment vide (clé manquante)
    if (heyWarn)  heyWarn.style.display  = (_heygenAvatars.length === 0) ? 'block' : 'none';
    if (higgWarn) higgWarn.style.display = (provider === 'higgsfield') ? 'block' : 'none';

    // Mise à jour meta
    const meta = document.getElementById('heygenSelectedMeta');
    if (meta) meta.textContent = `${_heygenAvatars.length} avatars · cliquer pour choisir`;
    const cnt  = document.getElementById('avatarPickerCount');
    if (cnt)  cnt.textContent  = `${_heygenAvatars.length} avatars disponibles`;

    renderHeygenVoiceList();
  } catch(e) {
    console.warn('HeyGen load error:', e.message);
  }
}

// ── AVATAR MODAL ──────────────────────────────────────────────
function openAvatarPicker() {
  document.getElementById('avatarPickerModal').style.display = 'block';
  document.body.style.overflow = 'hidden';
  _avatarPage = 0;
  document.getElementById('avatarGrid').innerHTML = '';
  document.getElementById('avatarSearch').value = '';
  document.getElementById('avatarGenderFilter').value = '';
  renderAvatarGrid();
}
function closeAvatarPicker() {
  document.getElementById('avatarPickerModal').style.display = 'none';
  document.body.style.overflow = '';
}

function getFilteredAvatars() {
  const q      = (document.getElementById('avatarSearch')?.value || '').toLowerCase();
  const gender = document.getElementById('avatarGenderFilter')?.value || '';
  return _heygenAvatars.filter(a => {
    const name = a.name.toLowerCase();
    if (q      && !name.includes(q))       return false;
    if (gender && a.gender !== gender)     return false;
    if (_ageFilter) {
      const keywords = AGE_KEYWORDS[_ageFilter] || [];
      if (!keywords.some(k => name.includes(k))) return false;
    }
    return true;
  });
}

function setAgeFilter(btn, age) {
  _ageFilter = age;
  document.querySelectorAll('.age-filter-btn').forEach(b => {
    const active = b.dataset.age === age;
    b.style.background = active ? 'rgba(108,99,255,0.2)' : 'transparent';
    b.style.borderColor = active ? 'var(--accent)' : 'var(--border)';
  });
  _avatarPage = 0;
  const grid = document.getElementById('avatarGrid');
  if (grid) grid.innerHTML = '';
  renderAvatarGrid();
}

function renderAvatarGrid(reset = false) {
  const grid     = document.getElementById('avatarGrid');
  const filtered = getFilteredAvatars();
  const start    = _avatarPage * AVATAR_PAGE_SIZE;
  const slice    = filtered.slice(start, start + AVATAR_PAGE_SIZE);
  const total    = filtered.length;

  if (reset) { grid.innerHTML = ''; _avatarPage = 0; }

  const selectedId = document.getElementById('clipHeygenAvatar')?.value || '';

  slice.forEach(av => {
    const card = document.createElement('div');
    const sel  = av.id === selectedId;
    card.style.cssText = `position:relative;cursor:pointer;border-radius:10px;overflow:hidden;border:2px solid ${sel ? 'var(--accent)' : 'transparent'};background:var(--surface2);transition:border-color .15s`;
    card.dataset.id = av.id;

    card.innerHTML = `
      <div style="position:relative;aspect-ratio:3/4;background:#111;overflow:hidden">
        <img src="${av.preview || ''}" alt="${av.name}"
             style="width:100%;height:100%;object-fit:cover;display:block"
             onerror="this.style.display='none'">
        ${av.preview_video ? `<video src="${av.preview_video}" muted loop preload="none"
             style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:0;transition:opacity .3s"
             id="vid_${av.id}"></video>` : ''}
        <div style="position:absolute;bottom:0;left:0;right:0;padding:4px 6px;background:rgba(0,0,0,0.6);font-size:9px;color:rgba(255,255,255,0.7)">${av.gender === 'female' ? '👩' : '👨'}</div>
      </div>
      <div style="padding:6px 8px;font-size:11px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis" title="${av.name}">${av.name}</div>
    `;

    // Hover → play video
    if (av.preview_video) {
      card.addEventListener('mouseenter', () => {
        const v = card.querySelector('video');
        if (v) { v.style.opacity = '1'; v.play().catch(() => {}); }
      });
      card.addEventListener('mouseleave', () => {
        const v = card.querySelector('video');
        if (v) { v.style.opacity = '0'; v.pause(); v.currentTime = 0; }
      });
    }

    card.addEventListener('click', () => selectAvatar(av));
    grid.appendChild(card);
  });

  // Bouton "charger plus"
  const btn = document.getElementById('loadMoreAvatarsBtn');
  const shown = Math.min((_avatarPage + 1) * AVATAR_PAGE_SIZE, total);
  if (btn) {
    btn.textContent = shown < total ? `Charger plus (${total - shown} restants)` : 'Tout affiché';
    btn.disabled    = shown >= total;
  }
}

function filterAvatars() {
  _avatarPage = 0;
  const grid = document.getElementById('avatarGrid');
  if (grid) grid.innerHTML = '';
  renderAvatarGrid();
}

function loadMoreAvatars() {
  _avatarPage++;
  renderAvatarGrid();
}

function selectAvatar(av) {
  // Mettre à jour l'input hidden
  const input = document.getElementById('clipHeygenAvatar');
  if (input) input.value = av.id;

  // Mettre à jour le bouton d'affichage
  const thumb = document.getElementById('heygenSelectedThumb');
  if (thumb) thumb.innerHTML = av.preview
    ? `<img src="${av.preview}" style="width:100%;height:100%;object-fit:cover">`
    : '👤';

  const name = document.getElementById('heygenSelectedName');
  if (name) name.textContent = av.name;

  const meta = document.getElementById('heygenSelectedMeta');
  if (meta) meta.textContent = `${av.gender === 'female' ? 'Femme' : 'Homme'} · cliquer pour changer`;

  // Highlight dans la grille
  document.querySelectorAll('#avatarGrid [data-id]').forEach(c => {
    c.style.borderColor = c.dataset.id === av.id ? 'var(--accent)' : 'transparent';
  });

  closeAvatarPicker();
}

// ── VOICE LIST ────────────────────────────────────────────────
let _currentAudio = null;

function renderHeygenVoiceList() {
  const list = document.getElementById('heygenVoiceList');
  if (!list) return;

  const q      = (document.getElementById('heygenVoiceSearch')?.value || '').toLowerCase();
  const lang   = document.getElementById('heygenVoiceLangFilter')?.value || 'de';
  const selId  = document.getElementById('clipHeygenVoice')?.value || '';

  const filtered = _heygenVoices.filter(v => {
    const matchLang = lang === 'all' || v.language?.toLowerCase() === 'german' || v.locale?.startsWith('de');
    const matchQ    = !q || v.name.toLowerCase().includes(q);
    return matchLang && matchQ;
  });

  // Si aucun résultat en DE → fallback toutes langues
  const display = filtered.length ? filtered : _heygenVoices.filter(v => !q || v.name.toLowerCase().includes(q));

  list.innerHTML = display.slice(0, 80).map(v => {
    const isSelected = v.id === selId;
    const hasPreview = !!v.preview_audio;
    const isNello    = v.name.toLowerCase().includes('nello') || v.name.toLowerCase().includes('ugc');
    return `
    <div onclick="selectVoice('${v.id}','${v.name.replace(/'/g, "\\'")}')"
         style="display:flex;align-items:center;gap:8px;padding:6px 8px;border-radius:6px;cursor:pointer;
                background:${isSelected ? 'rgba(108,99,255,0.15)' : 'transparent'};
                border:1px solid ${isSelected ? 'var(--accent)' : 'transparent'};
                transition:background .15s"
         onmouseenter="this.style.background='rgba(255,255,255,0.05)'"
         onmouseleave="this.style.background='${isSelected ? 'rgba(108,99,255,0.15)' : 'transparent'}'">
      <div style="flex:1;min-width:0">
        <div style="font-size:12px;font-weight:${isNello ? '700' : '500'};color:${isNello ? 'var(--accent3)' : 'var(--text)'};white-space:nowrap;overflow:hidden;text-overflow:ellipsis">
          ${isNello ? '⭐ ' : ''}${v.name}
        </div>
        <div style="font-size:10px;color:var(--text2)">${v.language || '?'} · ${v.gender || '?'}</div>
      </div>
      ${hasPreview
        ? `<button onclick="event.stopPropagation();previewVoice('${v.preview_audio}',this)"
                  style="padding:3px 8px;font-size:11px;background:rgba(255,255,255,0.08);border:1px solid var(--border);border-radius:4px;cursor:pointer;color:var(--text);flex-shrink:0"
                  title="Écouter aperçu">▶</button>`
        : `<span style="font-size:10px;color:var(--accent3);flex-shrink:0;padding:2px 6px;background:rgba(78,205,196,0.1);border-radius:4px">🎤 Perso</span>`
      }
    </div>`;
  }).join('');
}

function filterHeygenVoices() { renderHeygenVoiceList(); }

function selectVoice(id, name) {
  const input = document.getElementById('clipHeygenVoice');
  if (input) input.value = id;
  renderHeygenVoiceList();
}

function previewVoice(url, btn) {
  if (_currentAudio) { _currentAudio.pause(); _currentAudio = null; }
  const audio = new Audio(url);
  _currentAudio = audio;
  const orig = btn.textContent;
  btn.textContent = '⏹';
  audio.play();
  audio.onended = () => { btn.textContent = orig; _currentAudio = null; };
  btn.onclick = (e) => { e.stopPropagation(); audio.pause(); btn.textContent = orig; _currentAudio = null; };
}
</script>

