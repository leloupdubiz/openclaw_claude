        <div id="img-batch-cards" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:14px"></div>
      </div>
    </div>

    <!-- ─── Tab Automation ─────────────────────────────────── -->
    <div id="ftab-automation-content" class="factory-tab-content" style="display:none">
      <div style="display:grid;grid-template-columns:2fr 1fr;gap:16px;margin-bottom:20px">

        <!-- Status card -->
        <div class="card">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px">
            <h3 style="margin:0;font-size:16px">⚡ Automation Engine</h3>
            <div id="automation-running-badge" style="padding:4px 12px;border-radius:20px;font-size:12px;font-weight:600;background:rgba(78,205,196,0.15);color:#4ECDC4">● Actif</div>
          </div>

          <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:16px">
            <div style="text-align:center;background:var(--surface);border-radius:8px;padding:12px">
              <div id="auto-stat-pending" style="font-size:22px;font-weight:700;color:var(--accent)">0</div>
              <div style="font-size:11px;color:var(--text2)">En attente</div>
            </div>
            <div style="text-align:center;background:var(--surface);border-radius:8px;padding:12px">
              <div id="auto-stat-processing" style="font-size:22px;font-weight:700;color:#f0a500">0</div>
              <div style="font-size:11px;color:var(--text2)">En cours</div>
            </div>
            <div style="text-align:center;background:var(--surface);border-radius:8px;padding:12px">
              <div id="auto-stat-completed" style="font-size:22px;font-weight:700;color:#4ECDC4">0</div>
              <div style="font-size:11px;color:var(--text2)">Complétés</div>
            </div>
            <div style="text-align:center;background:var(--surface);border-radius:8px;padding:12px">
              <div id="auto-stat-failed" style="font-size:22px;font-weight:700;color:#FF6B6B">0</div>
              <div style="font-size:11px;color:var(--text2)">Échoués</div>
            </div>
          </div>

          <div style="display:flex;gap:10px;flex-wrap:wrap">
            <button onclick="runAllPipeline()" style="background:linear-gradient(135deg,#6c63ff,#FF6B6B);color:#fff;border:none;padding:12px 24px;border-radius:8px;cursor:pointer;font-weight:700;font-size:14px">
              🚀 Run All Pipeline
            </button>
            <button onclick="refreshAutomationStatus()" style="background:var(--surface2);color:var(--text);border:1px solid var(--border);padding:10px 16px;border-radius:8px;cursor:pointer;font-size:13px">
              🔄 Rafraîchir
            </button>
            <button onclick="clearQueue()" style="background:rgba(255,107,107,0.1);color:#FF6B6B;border:1px solid rgba(255,107,107,0.3);padding:10px 16px;border-radius:8px;cursor:pointer;font-size:13px">
              🗑️ Vider queue
            </button>
          </div>
        </div>

        <!-- Uptime -->
        <div class="card" style="display:flex;flex-direction:column;justify-content:center;align-items:center;text-align:center">
          <div style="font-size:40px;margin-bottom:8px">🏭</div>
          <div style="font-size:13px;color:var(--text2);margin-bottom:4px">Uptime</div>
          <div id="auto-uptime" style="font-size:18px;font-weight:600;color:var(--accent)">—</div>
          <div style="font-size:11px;color:var(--text2);margin-top:8px">Poll HeyGen toutes les 30s</div>
        </div>
      </div>

      <!-- Log feed -->
      <div class="card">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:14px">
          <h3 style="margin:0;font-size:15px">📋 Log Automation</h3>
          <span style="font-size:12px;color:var(--text2)">20 dernières actions</span>
        </div>
        <div id="auto-log-feed" style="font-family:monospace;font-size:12px;max-height:400px;overflow-y:auto;background:var(--surface);border-radius:8px;padding:12px">
          <div style="color:var(--text2)">Chargement du log...</div>
        </div>
      </div>
    </div>

  </div><!-- /padding -->
</div><!-- /page-factory -->

</main>
</div>

<script>
// ─── SCRIPTS MARKSMAN ───────────────────────────────────────
